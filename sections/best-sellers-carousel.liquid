{% assign max_products = section.settings.product_limit | default: 5 %}
<section id="best-sellers-{{ section.id }}" class="best-sellers" data-section-id="{{ section.id }}">
  <header class="best-sellers__header">
    <h2>OUR BEST SELLERS</h2>
  </header>

  <div class="best-sellers__stage">
    <div class="best-sellers__marquee" aria-hidden="true">
      <div class="best-sellers__marquee-line best-sellers__marquee-line--ltr">
        OUR BEST SELLERS • OUR BEST SELLERS • OUR BEST SELLERS • OUR BEST SELLERS • OUR BEST SELLERS •
      </div>
      <div class="best-sellers__marquee-line best-sellers__marquee-line--rtl">
        OUR BEST SELLERS • OUR BEST SELLERS • OUR BEST SELLERS • OUR BEST SELLERS • OUR BEST SELLERS •
      </div>
    </div>
    <div class="best-sellers__prev-peek" data-prev-peek></div>

    <div class="best-sellers__center">
      <div class="best-sellers__active-slide" data-active-slide></div>

      <aside class="best-sellers__info" data-info>
        <p class="best-sellers__info-eyebrow">NOW TRENDING</p>
        <h3 data-info-title></h3>
        <p class="best-sellers__info-price" data-info-price></p>
        <p class="best-sellers__info-desc" data-info-desc></p>
        <a class="best-sellers__cta" data-info-link href="#">SHOP NOW</a>
      </aside>

      <nav class="best-sellers__nav best-sellers__nav--mobile" aria-label="Best sellers carousel mobile controls">
        <button class="best-sellers__arrow" type="button" data-prev aria-label="Show previous product">
          <span aria-hidden="true">&#8592;</span>
        </button>
        <button class="best-sellers__arrow" type="button" data-next aria-label="Show next product">
          <span aria-hidden="true">&#8594;</span>
        </button>
      </nav>
    </div>

    <div class="best-sellers__next-peek" data-next-peek></div>
  </div>

  <nav class="best-sellers__nav best-sellers__nav--desktop" aria-label="Best sellers carousel controls">
    <button class="best-sellers__arrow" type="button" data-prev aria-label="Show previous product">
      <span aria-hidden="true">&#8592;</span>
    </button>
    <button class="best-sellers__arrow" type="button" data-next aria-label="Show next product">
      <span aria-hidden="true">&#8594;</span>
    </button>
  </nav>
</section>

<style>
  :root {
    --best-sellers-bg: #fff8f0;
    --best-sellers-surface: #ffffff;
    --best-sellers-text: #2b2b2b;
    --best-sellers-muted: rgba(43, 43, 43, 0.55);
    --best-sellers-highlight: #e28c2a;
    --best-sellers-cta-bg: #78c043;
    --best-sellers-cta-text: #0d2609;
    --best-sellers-cta-hover: #5b972f;
    --best-sellers-radius: 32px;
  }

  #best-sellers-{{ section.id }} {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    background: var(--best-sellers-bg);
    color: var(--best-sellers-text);
    position: relative;
    overflow: hidden;
    padding: clamp(2.5rem, 4vw, 4rem) 0;
    border-radius: var(--best-sellers-radius);
    
  }

  #best-sellers-{{ section.id }} .best-sellers__header {
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin-bottom: clamp(2rem, 4vw, 4rem);
    position: relative;
    z-index: 2;
  }

  #best-sellers-{{ section.id }} .best-sellers__header h2 {
   
    margin: 0;
  
  }

  #best-sellers-{{ section.id }} .best-sellers__stage {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    width: 100%;
    position: relative;
    z-index: 0;
    min-height: 380px;
    
    border-radius: calc(var(--best-sellers-radius) - 12px);
    margin-inline: clamp(1rem, 4vw, 3rem);
  
    overflow: hidden;
  }

  #best-sellers-{{ section.id }} .best-sellers__prev-peek,
  #best-sellers-{{ section.id }} .best-sellers__next-peek {
    position: relative;
    z-index: 2;
    overflow: hidden;
    height: 100%;
    display: flex;
    align-items: center;
    border-radius: calc(var(--best-sellers-radius) - 16px);
  }

  #best-sellers-{{ section.id }} .best-sellers__prev-peek {
    justify-content: flex-start;
    margin-left: -30%;
  }

  #best-sellers-{{ section.id }} .best-sellers__next-peek {
    justify-content: flex-end;
    margin-right: -30%;
  }

  #best-sellers-{{ section.id }} .best-sellers__peek-img {
    height: clamp(380px, 48vw, 520px);
    width: auto;
    max-width: none;
    object-fit: cover;
    opacity: 1;
    transition: opacity 0.5s ease;
    border-radius: calc(var(--best-sellers-radius) - 12px);
  }

  #best-sellers-{{ section.id }} .best-sellers__center {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.5rem, 3vw, 3rem);
    padding: 0 clamp(1rem, 2vw, 2rem);
  }

  #best-sellers-{{ section.id }} .best-sellers__active-slide {
    flex-shrink: 0;
  }

  #best-sellers-{{ section.id }} .best-sellers__active-slide img {
    height: clamp(380px, 48vw, 520px);
    width: auto;
    max-width: clamp(300px, 38vw, 420px);
    object-fit: cover;
    border-radius: calc(var(--best-sellers-radius) - 12px);
    box-shadow: 0 18px 45px rgba(0,0,0,0.12);
    transition: opacity 0.4s ease;
  }

  #best-sellers-{{ section.id }} .best-sellers__info {
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    letter-spacing: 0.05em;
    max-width: 280px;
    transition: opacity 0.3s ease;
  }

  #best-sellers-{{ section.id }} .best-sellers__info-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--best-sellers-muted);
    margin: 0;
  }

  #best-sellers-{{ section.id }} .best-sellers__info h3 {
    
    margin: 0;
    
   
    line-height: 1.2;
  }

  #best-sellers-{{ section.id }} .best-sellers__info-price {
    font-size: 0.9rem;
    color: var(--best-sellers-muted);
    margin: 0;
  }

  #best-sellers-{{ section.id }} .best-sellers__info-desc {
    text-transform: none;
    letter-spacing: 0.01em;
    line-height: 1.5;
    font-size: 0.9rem;
    margin: 0;
  }

  #best-sellers-{{ section.id }} .best-sellers__cta {
    align-self: flex-start;
    background: var(--best-sellers-cta-bg);
    color: var(--best-sellers-cta-text);
    padding: 0.9rem 2.5rem;
    border-radius: 999px;
    text-decoration: none;
    letter-spacing: 0.15em;
    font-size: 0.8rem;
    margin-top: 0.5rem;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  #best-sellers-{{ section.id }} .best-sellers__cta:hover {
    transform: translateY(-2px);
    background: var(--best-sellers-cta-hover);
  }

  #best-sellers-{{ section.id }} .best-sellers__info.is-transitioning {
    opacity: 0.4;
  }

  #best-sellers-{{ section.id }} .best-sellers__nav {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    position: relative;
    z-index: 2;
  }

  #best-sellers-{{ section.id }} .best-sellers__nav--desktop {
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
  }

  #best-sellers-{{ section.id }} .best-sellers__nav--mobile {
    display: none;
    width: 100%;
    margin-top: 1rem;
    order: 2;
  }

  #best-sellers-{{ section.id }} .best-sellers__arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(120, 192, 67, 0.15);
    color: var(--best-sellers-text);
    font-size: 1.25rem;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  #best-sellers-{{ section.id }} .best-sellers__arrow:hover {
    background: rgba(120, 192, 67, 0.3);
    transform: translateY(-2px);
  }

  #best-sellers-{{ section.id }} .best-sellers__marquee {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 15%;
    z-index: 1;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    opacity: 0.1;
    font-size: clamp(1.2rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--best-sellers-text);
    line-height: 1.1;
  }

  #best-sellers-{{ section.id }} .best-sellers__marquee-line {
    white-space: nowrap;
    animation-duration: 25s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    color: var(--best-sellers-highlight);
  }

  #best-sellers-{{ section.id }} .best-sellers__marquee-line--ltr {
    animation-name: marquee-ltr-{{ section.id }};
  }

  #best-sellers-{{ section.id }} .best-sellers__marquee-line--rtl {
    animation-name: marquee-rtl-{{ section.id }};
  }

  @keyframes marquee-ltr-{{ section.id }} {
    from { transform: translateX(-50%); }
    to { transform: translateX(0%); }
  }

  @keyframes marquee-rtl-{{ section.id }} {
    from { transform: translateX(0%); }
    to { transform: translateX(-50%); }
  }

  @media (max-width: 1024px) {
    #best-sellers-{{ section.id }} .best-sellers__center {
      flex-direction: column;
      text-align: center;
    }

    #best-sellers-{{ section.id }} .best-sellers__info {
      align-items: center;
      max-width: 100%;
    }

    #best-sellers-{{ section.id }} .best-sellers__cta {
      align-self: center;
    }
  }

  @media (max-width: 768px) {
    #best-sellers-{{ section.id }} .best-sellers__stage {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      grid-template-rows: auto auto auto;
      grid-template-areas:
        "prev center next"
        "nav nav nav"
        "info info info";
      align-items: center;
      gap: 0.5rem;
      padding-inline: 0;
      min-height: auto;
      width: 100%;
    }

    #best-sellers-{{ section.id }} .best-sellers__prev-peek {
      grid-area: prev;
      margin: 0;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      height: clamp(140px, 38vw, 180px);
    }

    #best-sellers-{{ section.id }} .best-sellers__next-peek {
      grid-area: next;
      margin: 0;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      height: clamp(140px, 38vw, 180px);
    }

    #best-sellers-{{ section.id }} .best-sellers__peek-img {
      height: clamp(140px, 38vw, 180px);
      width: auto;
      object-fit: cover;
      opacity: 1;
      filter: none;
    }

    #best-sellers-{{ section.id }} .best-sellers__center {
      grid-area: center;
      display: contents;
    }

    #best-sellers-{{ section.id }} .best-sellers__active-slide {
      grid-row: 1;
      grid-column: 2;
      display: flex;
      justify-content: center;
      align-items: center;
      height: clamp(140px, 38vw, 180px);
    }

    #best-sellers-{{ section.id }} .best-sellers__active-slide img {
      height: clamp(140px, 38vw, 180px);
      width: auto;
      max-width: clamp(180px, 50vw, 240px);
      border-radius: 20px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
      object-fit: cover;
    }

    #best-sellers-{{ section.id }} .best-sellers__info {
      grid-area: info;
      width: 100%;
      max-width: 100%;
      text-align: center;
      padding-inline: clamp(1.5rem, 6vw, 3rem);
      gap: 0.4rem;
      margin-top: 0.5rem;
    }

    #best-sellers-{{ section.id }} .best-sellers__info-eyebrow {
      letter-spacing: 0.25em;
      font-size: 0.7rem;
    }

    #best-sellers-{{ section.id }} .best-sellers__info h3 {
      font-size: clamp(1.1rem, 4.5vw, 1.4rem);
    }

    #best-sellers-{{ section.id }} .best-sellers__info-price {
      font-size: 0.85rem;
    }

    #best-sellers-{{ section.id }} .best-sellers__info-desc {
      font-size: 0.85rem;
      line-height: 1.4;
    }

    #best-sellers-{{ section.id }} .best-sellers__cta {
      width: auto;
      min-width: 180px;
      padding: 0.8rem 2rem;
      justify-content: center;
      text-align: center;
      align-self: center;
      margin-top: 0.5rem;
    }

    #best-sellers-{{ section.id }} .best-sellers__nav--desktop {
      display: none;
    }

    #best-sellers-{{ section.id }} .best-sellers__nav--mobile {
      grid-area: nav;
      display: flex;
      justify-content: center;
      margin-top: 0.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #best-sellers-{{ section.id }} .best-sellers__marquee-line {
      animation: none;
    }
  }
</style>

{% capture best_sellers_products %}
[
  {% if section.settings.collection != blank %}
    {% for product in section.settings.collection.products limit: max_products %}
      {
        "title": {{ product.title | json }},
        "price": {{ product.price | money | json }},
        "desc": {{ product.description | strip_html | strip_newlines | truncate: 110 | json }},
        "img": {% if product.featured_image %}{{ product.featured_image | image_url: width: 900 | json }}{% else %}null{% endif %},
        "url": {{ product.url | json }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  {% endif %}
]
{% endcapture %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('#best-sellers-{{ section.id }}');
    if (!section) return;

    const productsData = {{ best_sellers_products | strip | default: '[]' }};
    const fallbackProducts = [
      {
        title: 'GOLD POLISHING CLOTH',
        price: 'Rs. 400.00',
        desc: "Revive your gold's natural brilliance",
        img: 'https://cdn.shopify.com/s/files/1/0664/2982/0000/files/best-1.jpg?v=1',
        url: '/products/gold-polishing-cloth'
      },
      {
        title: 'SMILEY SIGNET RING',
        price: 'From Rs. 8,500.00',
        desc: 'Bold design with playful charm',
        img: 'https://cdn.shopify.com/s/files/1/0664/2982/0000/files/best-2.jpg?v=1',
        url: '/products/smiley-signet-ring'
      },
      {
        title: 'STARDUST STUD SET',
        price: 'Rs. 6,200.00',
        desc: 'Twinkling pavé studs for everyday glow',
        img: 'https://cdn.shopify.com/s/files/1/0664/2982/0000/files/best-3.jpg?v=1',
        url: '/products/stardust-stud-set'
      },
      {
        title: 'HEIRLOOM PEARL CHAIN',
        price: 'Rs. 12,000.00',
        desc: 'Hand-knotted freshwater pearls',
        img: 'https://cdn.shopify.com/s/files/1/0664/2982/0000/files/best-4.jpg?v=1',
        url: '/products/heirloom-pearl-chain'
      },
      {
        title: 'ROSE QUARTZ CUFF',
        price: 'Rs. 5,300.00',
        desc: 'Soft blush quartz with brushed gold',
        img: 'https://cdn.shopify.com/s/files/1/0664/2982/0000/files/best-5.jpg?v=1',
        url: '/products/rose-quartz-cuff'
      }
    ];
    const products = productsData.length ? productsData : fallbackProducts;
    if (products.length < 2) return;

    const prevPeek = section.querySelector('[data-prev-peek]');
    const activeSlideContainer = section.querySelector('[data-active-slide]');
    const nextPeek = section.querySelector('[data-next-peek]');
    const prevButtons = section.querySelectorAll('[data-prev]');
    const nextButtons = section.querySelectorAll('[data-next]');
    const infoPanel = section.querySelector('[data-info]');
    const infoTitle = infoPanel.querySelector('[data-info-title]');
    const infoPrice = infoPanel.querySelector('[data-info-price]');
    const infoDesc = infoPanel.querySelector('[data-info-desc]');
    const infoLink = infoPanel.querySelector('[data-info-link]');

    let activeIndex = 0;
    let startX = 0;
    let deltaX = 0;
    let isDragging = false;

    function getPrevIndex() {
      return (activeIndex - 1 + products.length) % products.length;
    }

    function getNextIndex() {
      return (activeIndex + 1) % products.length;
    }

    function updateDisplay() {
      const prev = products[getPrevIndex()];
      const current = products[activeIndex];
      const next = products[getNextIndex()];

      prevPeek.innerHTML = prev.img ? `<img class="best-sellers__peek-img" src="${prev.img}" alt="${prev.title}" loading="lazy" />` : '';
      activeSlideContainer.innerHTML = current.img ? `<img src="${current.img}" alt="${current.title}" loading="lazy" />` : '';
      nextPeek.innerHTML = next.img ? `<img class="best-sellers__peek-img" src="${next.img}" alt="${next.title}" loading="lazy" />` : '';

      infoPanel.classList.add('is-transitioning');
      infoTitle.textContent = current.title;
      infoPrice.textContent = current.price;
      infoDesc.textContent = current.desc;
      infoLink.href = current.url;
      window.setTimeout(() => infoPanel.classList.remove('is-transitioning'), 200);
    }

    function goToPrev() {
      activeIndex = getPrevIndex();
      updateDisplay();
    }

    function goToNext() {
      activeIndex = getNextIndex();
      updateDisplay();
    }

    let autoplayInterval = null;

    function startAutoplay() {
      stopAutoplay();
      autoplayInterval = window.setInterval(goToNext, 5000);
    }

    function stopAutoplay() {
      if (autoplayInterval) {
        window.clearInterval(autoplayInterval);
        autoplayInterval = null;
      }
    }

    function onPointerDown(event) {
      isDragging = true;
      startX = event.clientX || event.touches?.[0].clientX;
      deltaX = 0;
      stopAutoplay();
    }

    function onPointerMove(event) {
      if (!isDragging) return;
      const currentX = event.clientX || event.touches?.[0].clientX;
      deltaX = currentX - startX;
    }

    function onPointerUp() {
      if (!isDragging) return;
      isDragging = false;
      if (Math.abs(deltaX) > 50) {
        deltaX < 0 ? goToNext() : goToPrev();
      }
      startAutoplay();
    }

    updateDisplay();

    prevButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        goToPrev();
        startAutoplay();
      });
    });

    nextButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        goToNext();
        startAutoplay();
      });
    });

    section.addEventListener('pointerdown', onPointerDown, { passive: true });
    section.addEventListener('pointermove', onPointerMove, { passive: true });
    section.addEventListener('pointerup', onPointerUp, { passive: true });
    section.addEventListener('pointerleave', onPointerUp);
    section.addEventListener('touchstart', onPointerDown, { passive: true });
    section.addEventListener('touchmove', onPointerMove, { passive: true });
    section.addEventListener('touchend', onPointerUp);

    startAutoplay();
  });
</script>

{% schema %}
{
  "name": "Our Best Sellers Carousel",
  "tag": "section",
  "class": "section-best-sellers",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Best sellers collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to display",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    }
  ],
  "presets": [
    {
      "name": "Our Best Sellers",
      "category": "Products"
    }
  ]
}
{% endschema %}
