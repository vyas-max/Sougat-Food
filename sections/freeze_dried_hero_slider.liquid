{% comment %}
  Freeze Dried Hero Slider
  Editorial-style slider with overlay heading and bottom-right navigation
{% endcomment %}

{% schema %}
{
  "name": "Freeze Dried Hero Slider",
  "tag": "section",
  "class": "section-freeze-dried-hero-slider",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 4
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Image corner radius",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Snack Smart. Feel Light."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Discover snacks"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA link"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "Enjoy clean, freeze-dried fruit snacks made from real fruits — no added sugar, no preservatives, no nonsense. Snack guilt-free anytime, anywhere."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Freeze Dried Hero Slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "heading": "Snack Smart. Feel Light.",
            "cta_label": "Discover snacks",
            "cta_link": "/collections/snacks",
            "caption": "Enjoy clean, freeze-dried fruit snacks made from real fruits — no added sugar, no preservatives, no nonsense. Snack guilt-free anytime, anywhere."
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "Real Fruit. Real Nutrition.",
            "cta_label": "Know what you eat",
            "cta_link": "/collections/all",
            "caption": "Our freeze-drying process locks in natural vitamins, minerals, and flavor — giving you the goodness of fresh fruit in a light, crunchy form."
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "Fuel Your Day, Naturally",
            "cta_label": "Shop now",
            "cta_link": "/collections/best-sellers",
            "caption": "Perfect for work, travel, workouts, or quick cravings. Light on calories, rich in nutrients, and easy to carry wherever life takes you."
          }
        }
      ]
    }
  ]
}
{% endschema %}

{% style %}
  #freeze-dried-hero-slider-{{ section.id }} {
    background: #fff;
    position: relative;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slider-container {
    position: relative;
    max-width: 1440px;
    margin: 0 auto;
    padding: 3rem 4rem 5rem;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slides-viewport {
    overflow: hidden;
    width: 100%;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slides-track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #freeze-dried-hero-slider-{{ section.id }} .slide {
    flex: 0 0 100%;
    position: relative;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slide-inner {
    display: grid;
    grid-template-columns: 55% 45%;
    min-height: 480px;
    position: relative;
    align-items: start;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-image {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-image img,
  #freeze-dried-hero-slider-{{ section.id }} .slick-image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: {{ section.settings.image_radius }}px;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-slider-heading {
    position: absolute;
    top: 6%;
    left: 38%;
    z-index: 10;
    font-size: clamp(2.8rem, 4vw, 4.2rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #000;
    margin: 0;
    max-width: 600px;
    white-space: nowrap;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-content {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 140px 0 3rem 3rem;
    box-sizing: border-box;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-content-link {
    margin-bottom: 24px;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-content-link a {
    font-size: 1.3rem;
    text-decoration: none;
    color: #000;
    display: inline-block;
    padding-bottom: 4px;
    border-bottom: 1px solid #000;
    transition: opacity 0.25s ease;
    letter-spacing: 0.03em;
    text-transform: lowercase;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-content-link a:hover {
    opacity: 0.6;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-caption {
    font-size: 1.3rem;
    line-height: 1.65;
    color: #555;
    max-width: 320px;
    text-align: right;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-nav {
    position: absolute;
    bottom: 3rem;
    right: 4rem;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    z-index: 20;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-nav button {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.25s ease;
    color: #000;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-nav button:hover {
    opacity: 0.5;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-nav button svg {
    width: 20px;
    height: 20px;
    stroke-width: 1.5;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-counter {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 1.8rem;
    font-weight: 400;
    color: #000;
    font-style: italic;
    font-family: serif;
  }

  #freeze-dried-hero-slider-{{ section.id }} .slick-counter .sep {
    margin: 0 0.4rem;
    opacity: 0.5;
  }

  @media screen and (max-width: 990px) {
    #freeze-dried-hero-slider-{{ section.id }} .slider-container {
      padding: 2rem;
    }

    #freeze-dried-hero-slider-{{ section.id }} .slide-inner {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    #freeze-dried-hero-slider-{{ section.id }} .slick-image {
      aspect-ratio: 4 / 3;
      border-radius: {{ section.settings.image_radius }}px;
    }

    #freeze-dried-hero-slider-{{ section.id }} .slick-slider-heading {
      position: static;
      font-size: clamp(2.4rem, 7vw, 3rem);
      line-height: 1.2;
      max-width: 100%;
      margin: 1.5rem 0 1rem;
      white-space: normal;
    }

    #freeze-dried-hero-slider-{{ section.id }} .slick-content {
      padding: 0 0 2rem 0;
      align-items: flex-start;
    }

    #freeze-dried-hero-slider-{{ section.id }} .slick-caption {
      max-width: 100%;
      text-align: left;
    }

    #freeze-dried-hero-slider-{{ section.id }} .slick-content-link a {
      text-transform: none;
    }

    #freeze-dried-hero-slider-{{ section.id }} .slick-nav {
      bottom: 1.5rem;
      right: 2rem;
    }
  }

  @media screen and (max-width: 600px) {
    #freeze-dried-hero-slider-{{ section.id }} .slider-container {
      padding: 1.5rem;
    }

    #freeze-dried-hero-slider-{{ section.id }} .slick-slider-heading {
      font-size: clamp(2rem, 8vw, 2.4rem);
    }

    #freeze-dried-hero-slider-{{ section.id }} .slick-content-link a,
    #freeze-dried-hero-slider-{{ section.id }} .slick-caption {
      font-size: 1.1rem;
      line-height: 1.5;
    }

    #freeze-dried-hero-slider-{{ section.id }} .slick-nav {
      gap: 0.8rem;
    }

    #freeze-dried-hero-slider-{{ section.id }} .slick-counter {
      font-size: 1.4rem;
    }
  }
{% endstyle %}

<div id="freeze-dried-hero-slider-{{ section.id }}">
  <div class="slider-container" data-enable-autoplay="{{ section.settings.autoplay }}" data-autoplay-speed="{{ section.settings.autoplay_speed }}">
    <div class="slides-viewport">
      <ul class="slides-track">
        {% for block in section.blocks %}
          <li class="slide" {{ block.shopify_attributes }}>
            <div class="slide-inner">
              <div class="slick-image">
                {% if block.settings.image %}
                  {{
                    block.settings.image
                    | image_url: width: 1800
                    | image_tag:
                      loading: 'lazy',
                      sizes: '(min-width: 990px) 62vw, 100vw',
                      widths: '550, 750, 990, 1100, 1500, 1800',
                      alt: block.settings.image.alt | default: block.settings.heading
                  }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
              <h2 class="slick-slider-heading">{{ block.settings.heading }}</h2>
              <div class="slick-content">
                <div class="slick-content-link">
                  {% if block.settings.cta_label != blank and block.settings.cta_link != blank %}
                    <a href="{{ block.settings.cta_link }}">{{ block.settings.cta_label }}</a>
                  {% endif %}
                </div>
                <div class="slick-caption">{{ block.settings.caption }}</div>
              </div>
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>
    <div class="slick-nav">
      <button class="prev" aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
      </button>
      <div class="slick-counter">
        <span class="current">1</span>
        <span class="sep">/</span>
        <span class="total">{{ section.blocks.size }}</span>
      </div>
      <button class="next" aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    function initFreezeDriedSlider(sectionId) {
      const wrapper = document.getElementById('freeze-dried-hero-slider-' + sectionId);
      if (!wrapper) return;

      const container = wrapper.querySelector('.slider-container');
      const track = wrapper.querySelector('.slides-track');
      const slides = track ? track.querySelectorAll('.slide') : [];
      const totalSlides = slides.length;
      const prevBtn = wrapper.querySelector('.slick-nav .prev');
      const nextBtn = wrapper.querySelector('.slick-nav .next');
      const currentEl = wrapper.querySelector('.slick-counter .current');

      if (totalSlides < 2) {
        const nav = wrapper.querySelector('.slick-nav');
        if (nav) nav.style.display = 'none';
        return;
      }

      const enableAutoplay = container.dataset.enableAutoplay === 'true';
      const autoplaySpeed = (parseInt(container.dataset.autoplaySpeed) || 4) * 1000;
      let currentIndex = 0;
      let autoplayInterval = null;

      function goToSlide(index) {
        currentIndex = index;
        track.style.transform = 'translateX(' + (index * -100) + '%)';
        if (currentEl) currentEl.textContent = index + 1;
      }

      function nextSlide() {
        goToSlide((currentIndex + 1) % totalSlides);
      }

      function prevSlide() {
        goToSlide((currentIndex - 1 + totalSlides) % totalSlides);
      }

      function startAutoplay() {
        if (enableAutoplay && !autoplayInterval) {
          autoplayInterval = setInterval(nextSlide, autoplaySpeed);
        }
      }

      function stopAutoplay() {
        if (autoplayInterval) {
          clearInterval(autoplayInterval);
          autoplayInterval = null;
        }
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          stopAutoplay();
          nextSlide();
          startAutoplay();
        });
      }

      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          stopAutoplay();
          prevSlide();
          startAutoplay();
        });
      }

      container.addEventListener('mouseenter', stopAutoplay);
      container.addEventListener('mouseleave', startAutoplay);

      container.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') {
          stopAutoplay();
          prevSlide();
          startAutoplay();
        } else if (e.key === 'ArrowRight') {
          stopAutoplay();
          nextSlide();
          startAutoplay();
        }
      });

      container.setAttribute('tabindex', '0');
      startAutoplay();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        initFreezeDriedSlider('{{ section.id }}');
      });
    } else {
      initFreezeDriedSlider('{{ section.id }}');
    }
  })();
</script>
