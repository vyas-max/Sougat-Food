{%- liquid
  assign accent_color = section.settings.accent_color
  assign section_bg = section.settings.bg_color
  assign card_bg = '#ffffff'
  assign title_color = '#2D6A4F'
  assign text_color = '#555555'
-%}

{%- style -%}
  .text-dividers-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    position: relative;
    overflow: hidden;
  }

  .text-dividers-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Decorative Dividers ── */
  .text-dividers-{{ section.id }} .section-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .text-dividers-{{ section.id }} .divider-line {
    height: 1px;
    flex-grow: 1;
    background: linear-gradient(90deg, transparent, {{ accent_color }}, transparent);
    max-width: 200px;
  }

  .text-dividers-{{ section.id }} .divider-leaf {
    width: 40px;
    height: 20px;
    color: {{ accent_color }};
  }

  /* ── 3-Column Grid ── */
  .text-dividers-{{ section.id }} .blocks-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .text-dividers-{{ section.id }} .content-card {
    background: {{ card_bg }};
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border: 1px solid rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .text-dividers-{{ section.id }} .content-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.08);
  }

  /* Icon Wrap */
  .text-dividers-{{ section.id }} .card-icon-wrap {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #40916C, #1B4332);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    margin-bottom: 1.5rem;
    flex-shrink: 0;
    box-shadow: 0 5px 15px rgba(45, 106, 79, 0.3);
  }

  .text-dividers-{{ section.id }} .card-icon-wrap svg {
    width: 30px;
    height: 30px;
  }

  .text-dividers-{{ section.id }} .card-title {
    font-family: serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: {{ title_color }};
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .text-dividers-{{ section.id }} .card-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: {{ text_color }};
    margin: 0;
  }

  @media screen and (max-width: 990px) {
    .text-dividers-{{ section.id }} .blocks-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .text-dividers-{{ section.id }} .blocks-grid {
      grid-template-columns: 1fr;
    }
    .text-dividers-{{ section.id }} .content-card {
      padding: 1.5rem;
    }
  }
{%- endstyle -%}

<section class="text-dividers-{{ section.id }}">
  <div class="container">
    
    <div class="section-divider">
      <div class="divider-line"></div>
      <div class="divider-leaf">
        <svg viewBox="0 0 100 50" fill="currentColor"><path d="M50 0C50 0 100 25 100 50C100 50 50 50 50 50C50 50 0 50 0 50C0 25 50 0 50 0Z"/></svg>
      </div>
      <div class="divider-line"></div>
    </div>

    <div class="blocks-grid">
      {%- for block in section.blocks -%}
        <div class="content-card" {{ block.shopify_attributes }}>
          <div class="card-icon-wrap">
            {%- if block.settings.icon_svg != blank -%}
              {{ block.settings.icon_svg }}
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 2v20M2 12h20"></path></svg>
            {%- endif -%}
          </div>
          <div class="card-info">
            <h3 class="card-title">{{ block.settings.title }}</h3>
            <div class="card-text">{{ block.settings.text }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="section-divider" style="margin-top: 4rem; margin-bottom: 0;">
      <div class="divider-line"></div>
      <div class="divider-leaf">
        <svg viewBox="0 0 100 50" fill="currentColor" style="transform: rotate(180deg)"><path d="M50 0C50 0 100 25 100 50C100 50 50 50 50 50C50 50 0 50 0 50C0 25 50 0 50 0Z"/></svg>
      </div>
      <div class="divider-line"></div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "3-Column Info Cards",
  "tag": "section",
  "class": "section-text-dividers",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F8F3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Gold)",
      "default": "#C5A47E"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1200
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Info Card",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG Code"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Global Presence"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "With a strong export network, we cater to clients across multiple international markets."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "3-Column Info Cards",
      "blocks": [
        { "type": "text_block", "settings": { "title": "Global Presence" } },
        { "type": "text_block", "settings": { "title": "Our Vision" } },
        { "type": "text_block", "settings": { "title": "Our Mission" } }
      ]
    }
  ]
}
{% endschema %}
