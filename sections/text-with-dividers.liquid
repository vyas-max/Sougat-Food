{%- liquid
  assign accent_color = section.settings.accent_color
  assign section_bg = section.settings.bg_color
  assign card_bg = '#ffffff'
  assign title_color = '#2D6A4F'
  assign text_color = '#555555'
-%}

{%- style -%}
  .text-dividers-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    position: relative;
    overflow: hidden;
  }

  @media screen and (max-width: 767px) {
    .text-dividers-{{ section.id }} {
      padding-top: 30px;
      padding-bottom: 30px;
    }
  }

  .text-dividers-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Decorative Dividers ── */
  .text-dividers-{{ section.id }} .section-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0;
  }

  @media screen and (max-width: 767px) {
    .text-dividers-{{ section.id }} .section-divider {
      margin-bottom: 2rem;
    }
  }

  .text-dividers-{{ section.id }} .divider-line {
    height: 1px;
    flex-grow: 1;
    background: linear-gradient(90deg, transparent, {{ accent_color }}, transparent);
    max-width: 200px;
  }

  .text-dividers-{{ section.id }} .divider-leaf {
    width: 40px;
    height: 20px;
    color: {{ accent_color }};
  }

  /* ── 3-Column Grid ── */
  .text-dividers-{{ section.id }} .blocks-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .text-dividers-{{ section.id }} .content-card {
    background: {{ card_bg }};
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border: 1px solid rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .text-dividers-{{ section.id }} .content-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.08);
  }

  /* Icon Wrap */
  .text-dividers-{{ section.id }} .card-icon-wrap {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #40916C, #1B4332);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    margin-bottom: 1.5rem;
    flex-shrink: 0;
    box-shadow: 0 5px 15px rgba(45, 106, 79, 0.3);
  }

  .text-dividers-{{ section.id }} .card-icon-wrap svg {
    width: 30px;
    height: 30px;
  }

  .text-dividers-{{ section.id }} .card-title {
    font-family: serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: {{ title_color }};
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .text-dividers-{{ section.id }} .card-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: {{ text_color }};
    margin: 0;
  }

  @media screen and (max-width: 990px) {
    .text-dividers-{{ section.id }} .blocks-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .text-dividers-{{ section.id }} .container {
      padding: 0;
    }

    .text-dividers-{{ section.id }} .blocks-grid {
      display: flex;
      flex-wrap: nowrap;
      align-items: stretch;
      overflow-x: auto;
      overflow-y: hidden;
      overscroll-behavior-x: contain;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 14px;
      padding: 4px 20px 8px;
      scroll-padding-left: 20px;
    }

    .text-dividers-{{ section.id }} .blocks-grid::-webkit-scrollbar {
      display: none;
    }

    .text-dividers-{{ section.id }} .content-card {
      flex: 0 0 calc(88vw - 40px);
      min-width: calc(88vw - 40px);
      max-width: calc(88vw - 40px);
      height: auto;
      scroll-snap-align: start;
      box-sizing: border-box;
      padding: 1.5rem;
      margin: 0;
    }

    .text-dividers-{{ section.id }} .blocks-grid .content-card:last-child {
      margin-right: 20px;
    }

    .text-dividers-{{ section.id }} .slider-nav {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 16px;
      padding: 0 20px;
    }

    .text-dividers-{{ section.id }} .slider-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: {{ accent_color | default: '#C5A47E' | color_modify: 'alpha', 0.25 }};
      border: none;
      padding: 0;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .text-dividers-{{ section.id }} .slider-dot.is-active {
      width: 24px;
      border-radius: 10px;
      background: {{ accent_color | default: '#C5A47E' }};
    }

    .text-dividers-{{ section.id }} .section-divider {
      padding: 0 20px;
    }
  }

  @media screen and (min-width: 750px) {
    .text-dividers-{{ section.id }} .slider-nav {
      display: none;
    }
  }
{%- endstyle -%}

<section class="text-dividers-{{ section.id }}">
  <div class="container">
    
    <div class="section-divider">
      <div class="divider-line"></div>
      <div class="divider-leaf">
        <svg viewBox="0 0 100 50" fill="currentColor"><path d="M50 0C50 0 100 25 100 50C100 50 50 50 50 50C50 50 0 50 0 50C0 25 50 0 50 0Z"/></svg>
      </div>
      <div class="divider-line"></div>
    </div>

    <div class="blocks-grid" data-slider-track>
      {%- for block in section.blocks -%}
        <div class="content-card" {{ block.shopify_attributes }}>
          <div class="card-icon-wrap">
            {%- if block.settings.icon_svg != blank -%}
              {{ block.settings.icon_svg }}
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 2v20M2 12h20"></path></svg>
            {%- endif -%}
          </div>
          <div class="card-info">
            <h3 class="card-title">{{ block.settings.title }}</h3>
            <div class="card-text">{{ block.settings.text }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="slider-nav" data-slider-nav>
        {%- for block in section.blocks -%}
          <button type="button" class="slider-dot{% if forloop.first %} is-active{% endif %}" data-slide-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="section-divider" style="margin-top: 2rem; margin-bottom: 0;">
      <div class="divider-line"></div>
      <div class="divider-leaf">
        <svg viewBox="0 0 100 50" fill="currentColor" style="transform: rotate(180deg)"><path d="M50 0C50 0 100 25 100 50C100 50 50 50 50 50C50 50 0 50 0 50C0 25 50 0 50 0Z"/></svg>
      </div>
      <div class="divider-line"></div>
    </div>

  </div>
</section>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var sectionEl = document.querySelector('.text-dividers-' + sectionId);
    if (!sectionEl) return;

    var track = sectionEl.querySelector('[data-slider-track]');
    var nav = sectionEl.querySelector('[data-slider-nav]');
    if (!track) return;

    var cards = Array.from(track.querySelectorAll('.content-card'));
    var dots = nav ? Array.from(nav.querySelectorAll('.slider-dot')) : [];
    if (cards.length <= 1) return;

    var currentIndex = 0;
    var autoPlayInterval;
    var autoPlayDelay = 3000;

    function getPadding() {
      var style = window.getComputedStyle(track);
      return parseFloat(style.paddingLeft) || 0;
    }

    function scrollToIndex(index) {
      if (index < 0) index = 0;
      if (index >= cards.length) index = cards.length - 1;
      currentIndex = index;

      var card = cards[index];
      var paddingLeft = getPadding();
      var scrollLeft = card.offsetLeft - paddingLeft;
      track.scrollTo({ left: scrollLeft, behavior: 'smooth' });

      dots.forEach(function(dot, i) {
        dot.classList.toggle('is-active', i === index);
      });
    }

    function handleScroll() {
      var scrollLeft = track.scrollLeft;
      var closest = 0;
      var minDist = Infinity;
      cards.forEach(function(card, i) {
        var paddingLeft = getPadding();
        var dist = Math.abs(card.offsetLeft - paddingLeft - scrollLeft);
        if (dist < minDist) {
          minDist = dist;
          closest = i;
        }
      });
      currentIndex = closest;
      dots.forEach(function(dot, i) {
        dot.classList.toggle('is-active', i === closest);
      });
    }

    function startAutoPlay() {
      stopAutoPlay();
      autoPlayInterval = setInterval(function() {
        var next = (currentIndex + 1) % cards.length;
        scrollToIndex(next);
      }, autoPlayDelay);
    }

    function stopAutoPlay() {
      if (autoPlayInterval) clearInterval(autoPlayInterval);
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        scrollToIndex(parseInt(dot.dataset.slideIndex));
        startAutoPlay();
      });
    });

    var scrollRaf;
    track.addEventListener('scroll', function() {
      if (scrollRaf) cancelAnimationFrame(scrollRaf);
      scrollRaf = requestAnimationFrame(handleScroll);
    }, { passive: true });

    track.addEventListener('touchstart', stopAutoPlay, { passive: true });
    track.addEventListener('mouseenter', stopAutoPlay);

    function isMobile() {
      return window.innerWidth <= 749;
    }

    function init() {
      if (isMobile()) {
        startAutoPlay();
      }
    }

    init();

    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        stopAutoPlay();
        if (isMobile()) startAutoPlay();
      }, 250);
    });
  })();
</script>

{% schema %}
{
  "name": "3-Column Info Cards",
  "tag": "section",
  "class": "section-text-dividers",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F8F3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Gold)",
      "default": "#C5A47E"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1200
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Info Card",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG Code"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Global Presence"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "With a strong export network, we cater to clients across multiple international markets."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "3-Column Info Cards",
      "blocks": [
        { "type": "text_block", "settings": { "title": "Global Presence" } },
        { "type": "text_block", "settings": { "title": "Our Vision" } },
        { "type": "text_block", "settings": { "title": "Our Mission" } }
      ]
    }
  ]
}
{% endschema %}
