{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign section_bg = section.settings.bg_color
  assign divider_color = section.settings.divider_color
-%}

{%- style -%}
  .text-dividers-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    position: relative;
    overflow: hidden;
    font-display: swap;
  }

  .text-dividers-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      radial-gradient(ellipse at 10% 20%, {{ accent_color | color_modify: 'alpha', 0.03 }} 0%, transparent 50%),
      radial-gradient(ellipse at 90% 80%, {{ heading_color | color_modify: 'alpha', 0.02 }} 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .text-dividers-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeInLeft {
    from { opacity: 0; transform: translateX(-30px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes scaleIn {
    from { opacity: 0; transform: scaleX(0); }
    to { opacity: 1; transform: scaleX(1); }
  }
  @keyframes slideInIcon {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .text-dividers-{{ section.id }} .anim-fade {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
  .text-dividers-{{ section.id }} .anim-block {
    opacity: 0;
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .text-dividers-{{ section.id }} .anim-icon {
    animation: slideInIcon 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
  .text-dividers-{{ section.id }} .anim-divider {
    animation: scaleIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    transform-origin: left;
    opacity: 0;
  }

  .text-dividers-{{ section.id }} .section-header {
    text-align: center;
    margin-bottom: clamp(3.5rem, 7vw, 6rem);
    position: relative;
  }

  .text-dividers-{{ section.id }} .section-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: {{ heading_color }};
    margin: 0;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.1;
    position: relative;
    display: inline-block;
  }

  .text-dividers-{{ section.id }} .section-title::after {
    content: '';
    position: absolute;
    bottom: -15px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, {{ accent_color }}, {{ accent_color | color_lighten: 20 }});
    border-radius: 2px;
  }

  .text-dividers-{{ section.id }} .blocks-wrap {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .text-dividers-{{ section.id }} .text-block {
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 24px;
    position: relative;
  }

  .text-dividers-{{ section.id }} .text-block:hover {
    background: rgba(255, 255, 255, 0.5);
  }

  .text-dividers-{{ section.id }} .text-block:hover .block-title {
    color: {{ accent_color }};
  }

  .text-dividers-{{ section.id }} .text-block:hover .block-icon {
    transform: translateX(5px);
    border-left-color: {{ accent_color | color_lighten: 15 }};
  }

  .text-dividers-{{ section.id }} .block-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.75rem;
  }

  .text-dividers-{{ section.id }} .block-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, {{ accent_color | color_modify: 'alpha', 0.12 }} 0%, {{ accent_color | color_modify: 'alpha', 0.05 }} 100%);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  .text-dividers-{{ section.id }} .block-icon::before {
    content: '';
    width: 0;
    height: 0;
    border-top: 8px solid transparent;
    border-bottom: 8px solid transparent;
    border-left: 14px solid {{ accent_color }};
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .text-dividers-{{ section.id }} .block-title {
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    color: {{ heading_color }};
    margin: 0;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    transition: color 0.4s ease;
  }

  .text-dividers-{{ section.id }} .block-content {
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    color: {{ text_color }};
    line-height: 1.8;
    margin: 0;
    font-weight: 400;
    opacity: 0.85;
    max-width: 900px;
    padding-left: calc(48px + 1.25rem);
  }

  .text-dividers-{{ section.id }} .block-content p {
    margin-bottom: 1.25rem;
  }
  .text-dividers-{{ section.id }} .block-content p:last-child {
    margin-bottom: 0;
  }

  .text-dividers-{{ section.id }} .divider {
    height: 2px;
    width: 100%;
    background: linear-gradient(90deg, {{ divider_color }}, {{ divider_color | color_modify: 'alpha', 0.3 }} 70%, transparent);
    margin-top: clamp(2.5rem, 5vw, 4rem);
    position: relative;
  }

  .text-dividers-{{ section.id }} .divider::before {
    content: '';
    position: absolute;
    left: 0;
    top: -1px;
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, {{ accent_color }}, {{ accent_color | color_lighten: 20 }});
    border-radius: 2px;
    transform: translateY(-50%);
  }

  .text-dividers-{{ section.id }} .text-block.no-divider .divider {
    display: none;
  }

  @media screen and (max-width: 767px) {
    .text-dividers-{{ section.id }} .container {
      padding: 0 1.25rem;
    }
    .text-dividers-{{ section.id }} .block-content {
      padding-left: 0;
    }
    .text-dividers-{{ section.id }} .block-icon {
      width: 42px;
      height: 42px;
      border-radius: 12px;
    }
    .text-dividers-{{ section.id }} .block-icon::before {
      border-top-width: 6px;
      border-bottom-width: 6px;
      border-left-width: 10px;
    }
    .text-dividers-{{ section.id }} .divider::before {
      width: 40px;
    }
  }
{%- endstyle -%}

<section class="text-dividers-{{ section.id }}" id="TextDividers-{{ section.id }}">
  <div class="container">
    
    {%- if section.settings.title != blank -%}
      <div class="section-header anim-fade">
        <h2 class="section-title">{{ section.settings.title }}</h2>
      </div>
    {%- endif -%}

    <div class="blocks-wrap">
      {%- for block in section.blocks -%}
        {%- assign delay_factor = forloop.index | times: 0.15 -%}
        <div class="text-block anim-block {% if block.settings.show_divider == false %}no-divider{% endif %}" style="animation-delay: {{ delay_factor }}s;" {{ block.shopify_attributes }}>
          
          {%- if block.settings.title != blank -%}
            <div class="block-header">
              {%- if block.settings.show_icon -%}
                <div class="block-icon anim-icon" style="animation-delay: {{ delay_factor | plus: 0.1 }}s;"></div>
              {%- endif -%}
              <h3 class="block-title">{{ block.settings.title }}</h3>
            </div>
          {%- endif -%}
          
          {%- if block.settings.text != blank -%}
            <div class="block-content">
              {{ block.settings.text }}
            </div>
          {%- endif -%}

          {%- if block.settings.show_divider -%}
            <div class="divider anim-divider" style="animation-delay: {{ delay_factor | plus: 0.3 }}s;"></div>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Text with Dividers",
  "tag": "section",
  "class": "section-text-dividers",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Optional Section Heading"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1300
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F8FBFA"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / Icon Color",
      "default": "#B3B3B3"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Line Color",
      "default": "#D1D5DB"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Text Block",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_icon",
          "label": "Show Triangle Icon",
          "default": true
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Content Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description text",
          "default": "<p>Add your detailed description here. This block is perfect for conveying long-form information elegantly.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_divider",
          "label": "Show Line Below Block",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text with Dividers",
      "blocks": [
        {
          "type": "text_block",
          "settings": {
            "title": "Global Presence",
            "show_icon": true,
            "text": "<p>With a strong export network, we cater to clients across multiple international markets. Our focus is on building long-term partnerships by offering reliability, competitive pricing, and premium quality products.</p>",
            "show_divider": true
          }
        },
        {
          "type": "text_block",
          "settings": {
            "title": "Our Vision",
            "show_icon": false,
            "text": "<p>To become a trusted global food brand that promotes healthier eating habits, especially for children, by offering natural and nutritious freeze-dried foods. We aim to support a healthier future while staying honest, responsible, and true to our values.</p>",
            "show_divider": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
