{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign section_bg = section.settings.bg_color
-%}

{%- style -%}
  .text-dividers-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    position: relative;
  }

  .text-dividers-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Decorative Dividers ── */
  .text-dividers-{{ section.id }} .top-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .text-dividers-{{ section.id }} .divider-line {
    height: 1px;
    flex-grow: 1;
    background: linear-gradient(90deg, transparent, {{ accent_color }}, transparent);
    max-width: 300px;
  }

  .text-dividers-{{ section.id }} .divider-diamond {
    width: 12px;
    height: 12px;
    background: {{ accent_color }};
    transform: rotate(45deg);
    box-shadow: 0 0 10px {{ accent_color | color_modify: 'alpha', 0.5 }};
  }

  .text-dividers-{{ section.id }} .swirl-divider {
    display: flex;
    justify-content: center;
    margin: 3rem 0;
    color: {{ accent_color }};
    opacity: 0.8;
  }

  .text-dividers-{{ section.id }} .swirl-divider svg {
    width: 100px;
    height: auto;
  }

  /* ── Content Cards ── */
  .text-dividers-{{ section.id }} .blocks-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .text-dividers-{{ section.id }} .content-card {
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    padding: clamp(2rem, 5vw, 3.5rem);
    border-radius: 12px;
    border: 1.5px solid {{ accent_color | color_modify: 'alpha', 0.4 }};
    box-shadow: 0 15px 35px rgba(0,0,0,0.06);
    transition: transform 0.3s ease;
    position: relative;
  }

  .text-dividers-{{ section.id }} .content-card:hover {
    transform: translateY(-5px);
  }

  /* Card Variants */
  .text-dividers-{{ section.id }} .card-light {
    background: #fff;
    color: #333;
  }

  .text-dividers-{{ section.id }} .card-dark {
    background: {{ heading_color }};
    color: #fff;
  }

  .text-dividers-{{ section.id }} .card-dark .card-title {
    color: {{ accent_color }};
  }

  .text-dividers-{{ section.id }} .card-dark .card-text {
    color: rgba(255,255,255,0.9);
  }

  /* Icons */
  .text-dividers-{{ section.id }} .card-icon-wrap {
    flex-shrink: 0;
    width: clamp(80px, 12vw, 120px);
    height: clamp(80px, 12vw, 120px);
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, {{ accent_color }} 0%, {{ accent_color | color_darken: 15 }} 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    border: 2px solid rgba(255,255,255,0.2);
  }

  .text-dividers-{{ section.id }} .card-icon-wrap svg {
    width: 50%;
    height: auto;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
  }

  .text-dividers-{{ section.id }} .card-info {
    flex-grow: 1;
  }

  .text-dividers-{{ section.id }} .card-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-family: serif;
    font-weight: 500;
    margin: 0 0 1rem;
    color: {{ accent_color }};
  }

  .text-dividers-{{ section.id }} .card-text {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 767px) {
    .text-dividers-{{ section.id }} .content-card {
      flex-direction: column;
      text-align: center;
      padding: 2rem 1.5rem;
    }
    .text-dividers-{{ section.id }} .card-icon-wrap {
      margin-bottom: 1rem;
    }
  }
{%- endstyle -%}

<section class="text-dividers-{{ section.id }}">
  <div class="container">
    
    <div class="top-divider">
      <div class="divider-line"></div>
      <div class="divider-diamond"></div>
      <div class="divider-line"></div>
    </div>

    <div class="blocks-grid">
      {%- for block in section.blocks -%}
        {%- if forloop.index > 1 -%}
          <div class="swirl-divider">
            <svg viewBox="0 0 100 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0 10C20 10 30 0 50 0C70 0 80 10 100 10C80 10 70 20 50 20C30 20 20 10 0 10Z" fill="currentColor" fill-opacity="0.3"/>
              <circle cx="50" cy="10" r="2" fill="currentColor"/>
            </svg>
          </div>
        {%- endif -%}

        <div class="content-card card-{{ block.settings.style_mode }}" {{ block.shopify_attributes }}>
          <div class="card-icon-wrap">
            {%- if block.settings.icon_svg != blank -%}
              {{ block.settings.icon_svg }}
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 2v20M2 12h20"></path>
              </svg>
            {%- endif -%}
          </div>
          <div class="card-info">
            <h3 class="card-title">{{ block.settings.title }}</h3>
            <div class="card-text">{{ block.settings.text }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="top-divider" style="margin-top: 4rem; margin-bottom: 0;">
      <div class="divider-line"></div>
      <div class="divider-diamond"></div>
      <div class="divider-line"></div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Text with Dividers",
  "tag": "section",
  "class": "section-text-dividers",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F8F3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Dark Style Background",
      "default": "#003D2B"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Gold)",
      "default": "#C5A47E"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1100
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Vision/Mission Block",
      "settings": [
        {
          "type": "select",
          "id": "style_mode",
          "label": "Card Style",
          "default": "light",
          "options": [
            { "value": "light", "label": "Light (White)" },
            { "value": "dark", "label": "Dark (Deep Green)" }
          ]
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG Code"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Our Vision"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "To become a trusted global food brand..."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text with Dividers",
      "blocks": [
        { "type": "text_block", "settings": { "title": "Global Presence", "style_mode": "light" } },
        { "type": "text_block", "settings": { "title": "Our Vision", "style_mode": "dark" } },
        { "type": "text_block", "settings": { "title": "Our Mission", "style_mode": "light" } }
      ]
    }
  ]
}
{% endschema %}
