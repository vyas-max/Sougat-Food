{%- liquid
  assign accent_color = section.settings.accent_color | default: '#38aa3d'
  assign accent_background = section.settings.accent_background | default: '#f6f7f8'
  assign card_background = section.settings.card_background | default: '#fcfcfd'
  assign card_border = section.settings.card_border | default: '#dfe3e6'
  assign contact_background = section.settings.contact_background | default: '#1b1f24'
  assign contact_text_color = section.settings.contact_text_color | default: '#f5f5f5'
  assign body_text_color = section.settings.body_text_color | default: '#111417'
-%}

<section class="returns-policy returns-policy--{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="returns-policy__wrapper page-width">
    <div class="returns-policy__intro">
      <p class="returns-policy__eyebrow">Customer Assurance</p>
      <h1 class="returns-policy__title">Returns, Refunds &amp; Exchange Policy – SOUGAT</h1>
      <div class="returns-policy__lede">
        <p>As we deal in perishable food products, we do not offer refunds or exchanges under normal circumstances.</p>
        <p>Exceptions may be made only if you:</p>
        <ul class="returns-policy__list">
          <li>Receive the wrong product, or</li>
          <li>Receive a tampered or damaged product</li>
        </ul>
      </div>
    </div>

    <div class="returns-policy__grid">
      <article class="returns-policy__card">
        <p class="returns-policy__card-label">Our Rights</p>
        <h2>We Reserve the Right to:</h2>
        <ul>
          <li>Request product identification or images for verification.</li>
          <li>Determine whether the product has been damaged, abused, or used.</li>
        </ul>
      </article>

      <article class="returns-policy__card">
        <p class="returns-policy__card-label">Reporting Timeline</p>
        <h2>24-Hour Window</h2>
        <ul>
          <li>Any issue must be reported within 24 hours of receiving the product.</li>
          <li>Requests made after 24 hours cannot be accepted due to the perishable nature of the products.</li>
        </ul>
      </article>

      <article class="returns-policy__card">
        <p class="returns-policy__card-label">Refund Process</p>
        <h2>How Refunds Are Issued</h2>
        <ul>
          <li>Approved refunds will be credited to the same payment instrument used for the transaction.</li>
          <li>Refunds will be processed within 7–10 business working days, as per standard banking procedures.</li>
        </ul>
      </article>

      <article class="returns-policy__card">
        <p class="returns-policy__card-label">No Refund / Exchange</p>
        <h2>Eligible Products Only</h2>
        <p>Products that are not expired or damaged will not be exchanged or refunded under any circumstances.</p>
      </article>

      <article class="returns-policy__card returns-policy__card--highlight">
        <p class="returns-policy__card-label">Expiry Date Clarification</p>
        <h2>Understanding MM/YY</h2>
        <p>If a product displays its expiry date in MM/YY format, it expires at the end of that month, as per international standards.</p>
        <div class="returns-policy__note">
          <p class="returns-policy__note-title">Example</p>
          <p>Expiry 01/26 means the product expires on 31st January 2025.</p>
        </div>
      </article>
    </div>

    <div class="returns-policy__contact" style="--contact-background: {{ contact_background }}; --contact-text: {{ contact_text_color }};">
      <div class="returns-policy__contact-content">
        <p class="returns-policy__eyebrow returns-policy__eyebrow--light">Need help?</p>
        <h2>Contact Us Within 24 Hours</h2>
        <div class="returns-policy__contact-grid">
          <div>
            <p class="returns-policy__contact-label">Email</p>
            <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
          </div>
          <div>
            <p class="returns-policy__contact-label">Phone</p>
            <a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}">{{ section.settings.contact_phone }}</a>
          </div>
        </div>
        <p class="returns-policy__contact-footnote">
          Please share order details, images, and a brief description so we can assist you quickly.
        </p>
      </div>
    </div>

    <p class="returns-policy__brand">{{ section.settings.brand_line }}</p>
  </div>
</section>

<style>
  .returns-policy--{{ section.id }} {
    position: relative;
    padding-block: clamp(48px, 6vw, 108px);
    background: transparent;
  }

  .returns-policy--{{ section.id }} .returns-policy__wrapper {
    display: flex;
    flex-direction: column;
    gap: clamp(32px, 5vw, 56px);
  }

  .returns-policy--{{ section.id }} .returns-policy__intro {
    max-width: 860px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .returns-policy--{{ section.id }} .returns-policy__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgb(var(--color-foreground-rgb) / 0.6);
    margin: 0;
  }

  .returns-policy--{{ section.id }} .returns-policy__eyebrow--light {
    color: var(--contact-text);
    opacity: 0.8;
  }

  .returns-policy--{{ section.id }} .returns-policy__title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.25rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: {{ accent_color }};
  }

  .returns-policy--{{ section.id }} .returns-policy__lede {
    font-size: 1.125rem;
    line-height: 1.7;
    color: {{ body_text_color }};
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .returns-policy--{{ section.id }} .returns-policy__list,
  .returns-policy--{{ section.id }} .returns-policy__sublist {
    margin: 0;
    padding-left: 20px;
    color: {{ body_text_color }};
  }

  .returns-policy--{{ section.id }} .returns-policy__sublist {
    list-style: disc;
  }

  .returns-policy--{{ section.id }} .returns-policy__list > li {
    margin-bottom: 6px;
  }

  .returns-policy--{{ section.id }} .returns-policy__exception {
    padding: 20px;
    border-radius: 0;
    border: 1px solid {{ card_border }};
    background: transparent;
    box-shadow: none;
  }

  .returns-policy--{{ section.id }} .returns-policy__exception-title {
    margin: 0 0 8px 0;
    font-weight: 600;
    color: {{ accent_color }};
  }

  .returns-policy--{{ section.id }} .returns-policy__exception ul {
    margin: 0;
    padding-left: 18px;
  }

  .returns-policy--{{ section.id }} .returns-policy__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: clamp(20px, 3vw, 32px);
  }

  .returns-policy--{{ section.id }} .returns-policy__card {
    background: transparent;
    border: 1px solid {{ card_border }};
    border-radius: 0;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: none;
  }

  .returns-policy--{{ section.id }} .returns-policy__card-label {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.7rem;
    font-weight: 600;
    color: {{ accent_color }};
  }

  .returns-policy--{{ section.id }} .returns-policy__card h2 {
    margin: 0;
    font-size: 1.35rem;
    color: {{ accent_color }};
  }

  .returns-policy--{{ section.id }} .returns-policy__card p,
  .returns-policy--{{ section.id }} .returns-policy__card ul {
    margin: 0;
    line-height: 1.6;
    color: {{ body_text_color }};
  }

  .returns-policy--{{ section.id }} .returns-policy__card ul {
    padding-left: 18px;
  }

  .returns-policy--{{ section.id }} .returns-policy__card strong {
    color: {{ accent_color }};
  }

  .returns-policy--{{ section.id }} .returns-policy__card--highlight {
    background: {{ accent_background }};
    border-color: {{ card_border }};
  }

  .returns-policy--{{ section.id }} .returns-policy__note {
    margin-top: 16px;
    padding: 16px;
    border-radius: 0;
    background: transparent;
    border: 1px dashed {{ card_border }};
  }

  .returns-policy--{{ section.id }} .returns-policy__note-title {
    margin: 0 0 4px 0;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: rgb(var(--color-foreground-rgb) / 0.65);
  }

  .returns-policy--{{ section.id }} .returns-policy__contact {
    border-radius: 0;
    background: var(--contact-background);
    color: var(--contact-text);
    padding: clamp(28px, 5vw, 48px);
    box-shadow: none;
  }

  .returns-policy--{{ section.id }} .returns-policy__contact h2 {
    margin: 0 0 16px 0;
    color: var(--contact-text);
  }

  .returns-policy--{{ section.id }} .returns-policy__contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin-bottom: 16px;
  }

  .returns-policy--{{ section.id }} .returns-policy__contact-label {
    margin: 0 0 4px 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    color: rgb(255 255 255 / 0.8);
  }

  .returns-policy--{{ section.id }} .returns-policy__contact a {
    color: var(--contact-text);
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
  }

  .returns-policy--{{ section.id }} .returns-policy__contact a:hover {
    text-decoration: underline;
  }

  .returns-policy--{{ section.id }} .returns-policy__contact-footnote {
    margin: 0;
    color: rgb(255 255 255 / 0.7);
    font-size: 0.95rem;
  }

  .returns-policy--{{ section.id }} .returns-policy__brand {
    margin: 0;
    text-align: center;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }

  @media screen and (max-width: 600px) {
    .returns-policy--{{ section.id }} .returns-policy__card {
      padding: 22px;
    }

    .returns-policy--{{ section.id }} .returns-policy__contact a {
      font-size: 1rem;
      word-break: break-word;
    }
  }
</style>

{% schema %}
{
  "name": "Returns & Refunds Policy",
  "tag": "section",
  "class": "section returns-policy",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#38aa3d"
    },
    {
      "type": "color",
      "id": "accent_background",
      "label": "Accent background",
      "default": "#f6f7f8"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#fcfcfd"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#dfe3e6"
    },
    {
      "type": "color",
      "id": "contact_background",
      "label": "Contact block background",
      "default": "#1b1f24"
    },
    {
      "type": "color",
      "id": "contact_text_color",
      "label": "Contact block text color",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "body_text_color",
      "label": "Body text color",
      "default": "#111417"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Support email",
      "default": "operations@shubhalaxmifoodproducts.com"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Support phone",
      "default": "+91 7972898280"
    },
    {
      "type": "text",
      "id": "brand_line",
      "label": "Brand line",
      "default": "SOUGAT – A Brand of Shubhalaxmi Food Industry"
    }
  ]
}
{% endschema %}
