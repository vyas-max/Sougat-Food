{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign card_bg = section.settings.card_bg
  assign section_bg = section.settings.bg_color
-%}

{%- style -%}
  .our-expertise-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    overflow: hidden;
    position: relative;
  }

  /* Decorative soft blur effect */
  .our-expertise-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: -15%;
    left: -10%;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, {{ accent_color | color_modify: 'alpha', 0.05 }} 0%, transparent 70%);
    filter: blur(100px);
    pointer-events: none;
    z-index: 0;
  }

  .our-expertise-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* ── Animations ── */
  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(-30px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes fadeUpAnim {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .our-expertise-{{ section.id }} .anim-slide {
    animation: slideInRight 0.7s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    opacity: 0;
  }
  .our-expertise-{{ section.id }} .anim-fade {
    animation: fadeUpAnim 0.8s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
    opacity: 0;
  }
  .our-expertise-{{ section.id }} .d-1 { animation-delay: 0.1s; }
  .our-expertise-{{ section.id }} .d-2 { animation-delay: 0.2s; }
  .our-expertise-{{ section.id }} .d-3 { animation-delay: 0.3s; }
  .our-expertise-{{ section.id }} .d-4 { animation-delay: 0.4s; }

  /* ── Header ── */
  .our-expertise-{{ section.id }} .header-wrap {
    text-align: left;
    margin-bottom: clamp(3.5rem, 6vw, 5rem);
    max-width: 900px;
  }

  .our-expertise-{{ section.id }} .main-title {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    color: {{ heading_color }};
    margin: 0 0 1.25rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1.05;
  }

  .our-expertise-{{ section.id }} .subheading {
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    color: {{ text_color }};
    opacity: 0.85;
    line-height: 1.6;
    margin: 0;
    font-weight: 400;
  }

  /* ── Grid/List Layout ── */
  .our-expertise-{{ section.id }} .expertise-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: clamp(4rem, 8vw, 6rem);
  }

  @media screen and (min-width: 768px) {
    .our-expertise-{{ section.id }} .expertise-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .our-expertise-{{ section.id }} .expertise-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Item Card ── */
  .our-expertise-{{ section.id }} .expert-item {
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, {{ card_bg }} 0%, rgba(255,255,255,0.7) 100%);
    padding: 1.5rem 2rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.02), inset 0 1px 0 rgba(255,255,255,1);
    transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    cursor: default;
    position: relative;
    overflow: hidden;
  }

  .our-expertise-{{ section.id }} .expert-item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at left, {{ accent_color | color_modify: 'alpha', 0.1 }}, transparent 50%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .our-expertise-{{ section.id }} .expert-item:hover {
    transform: translateX(8px) translateY(-5px);
    background: #fff;
    border-color: rgba(255, 255, 255, 1);
    box-shadow: 0 20px 40px rgba(20, 68, 45, 0.08), 0 0 0 1px {{ accent_color | color_modify: 'alpha', 0.05 }};
  }

  .our-expertise-{{ section.id }} .expert-item:hover::after {
    opacity: 1;
  }

  .our-expertise-{{ section.id }} .check-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    margin-right: 1.25rem;
    background: linear-gradient(135deg, {{ accent_color | color_modify: 'alpha', 0.15 }}, {{ accent_color | color_modify: 'alpha', 0.05 }});
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ accent_color }};
    box-shadow: 0 4px 10px {{ accent_color | color_modify: 'alpha', 0.15 }};
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    position: relative;
    z-index: 1;
  }

  .our-expertise-{{ section.id }} .expert-item:hover .check-icon {
    transform: scale(1.15) rotate(10deg);
  }

  .our-expertise-{{ section.id }} .item-label {
    font-size: 1.15rem;
    font-weight: 700;
    color: {{ heading_color }};
    margin: 0;
    letter-spacing: -0.01em;
    position: relative;
    z-index: 1;
  }

  /* ── Footer Info ── */
  .our-expertise-{{ section.id }} .footer-content {
    background: linear-gradient(135deg, {{ card_bg }} 0%, rgba(255,255,255,0.4) 100%);
    padding: clamp(2.5rem, 4.5vw, 4.5rem) clamp(2rem, 4vw, 4rem);
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.05), inset 0 1px 0 rgba(255,255,255,1);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
  }

  .our-expertise-{{ section.id }} .footer-content::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 8px;
    background: linear-gradient(180deg, {{ accent_color | color_lighten: 15 }}, {{ accent_color }});
    box-shadow: 4px 0 15px {{ accent_color | color_modify: 'alpha', 0.3 }};
  }

  .our-expertise-{{ section.id }} .footer-text {
    font-size: clamp(1.1rem, 1.5vw, 1.25rem);
    color: {{ text_color }};
    line-height: 1.7;
    margin: 0;
    opacity: 0.9;
    font-weight: 450;
  }

  @media screen and (max-width: 767px) {
    .our-expertise-{{ section.id }} .footer-content {
      padding: 2.5rem 1.5rem;
      border-radius: 30px;
    }
  }
{%- endstyle -%}

<section class="our-expertise-{{ section.id }}" id="Expertise-{{ section.id }}">
  <div class="container">
    
    <div class="header-wrap anim-fade">
      {%- if section.settings.title != blank -%}
        <h2 class="main-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="expertise-grid">
      {%- for block in section.blocks -%}
        {%- assign delay_class = forloop.index | modulo: 4 | plus: 1 -%}
        <div class="expert-item anim-slide d-{{ delay_class }}" {{ block.shopify_attributes }}>
          <div class="check-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <p class="item-label">{{ block.settings.title | escape }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_text != blank -%}
      <div class="footer-content anim-fade d-2">
        <div class="footer-text">
          {{ section.settings.footer_text }}
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Our Expertise",
  "tag": "section",
  "class": "section-our-expertise",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Expertises"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We manufacture and export a wide range of high-quality food products, including:"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Information",
      "default": "<p>Our advanced processing technology ensures superior taste retention, nutritional value preservation, and extended shelf life — especially in our freeze-drying segment, where we focus on premium quality and global export standards.</p>"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1300
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Item Background",
      "default": "#F8FBFA"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#10A560"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "expertise_item",
      "name": "Expertise Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Expertise Name",
          "default": "Expertise Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Expertise",
      "blocks": [
        { "type": "expertise_item", "settings": { "title": "Freeze-Dried Fruits & Vegetables" } },
        { "type": "expertise_item", "settings": { "title": "Pulses & Lentils" } },
        { "type": "expertise_item", "settings": { "title": "Spices & Whole Spices" } },
        { "type": "expertise_item", "settings": { "title": "Herbs & Dehydrated Products" } },
        { "type": "expertise_item", "settings": { "title": "Millets & Traditional Indian Grains" } },
        { "type": "expertise_item", "settings": { "title": "Jaggery & Natural Sweeteners" } }
      ]
    }
  ]
}
{% endschema %}
