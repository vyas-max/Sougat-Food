{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign card_bg = section.settings.card_bg
  assign section_bg = section.settings.bg_color
-%}

{%- style -%}
  .our-expertise-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    overflow: hidden;
    position: relative;
  }

  /* Decorative soft blur effect */
  .our-expertise-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: -15%;
    left: -10%;
    width: 50%;
    height: 50%;
    background: radial-gradient(circle, {{ accent_color | color_modify: 'alpha', 0.05 }} 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .our-expertise-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* ── Header ── */
  .our-expertise-{{ section.id }} .header-wrap {
    text-align: left;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    max-width: 850px;
  }

  .our-expertise-{{ section.id }} .main-title {
    font-size: clamp(2.2rem, 5vw, 3.75rem);
    color: {{ heading_color }};
    margin: 0 0 1.25rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .our-expertise-{{ section.id }} .subheading {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: {{ text_color }};
    opacity: 0.85;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Grid/List Layout ── */
  .our-expertise-{{ section.id }} .expertise-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  @media screen and (min-width: 768px) {
    .our-expertise-{{ section.id }} .expertise-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .our-expertise-{{ section.id }} .expertise-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Item Card ── */
  .our-expertise-{{ section.id }} .expert-item {
    display: flex;
    align-items: center;
    background: {{ card_bg }};
    padding: 1.5rem 2rem;
    border-radius: 20px;
    border: 1px solid rgba(0, 0, 0, 0.04);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .our-expertise-{{ section.id }} .expert-item:hover {
    transform: translateX(10px);
    background: #fff;
    border-color: {{ accent_color | color_modify: 'alpha', 0.2 }};
    box-shadow: 0 15px 35px rgba(20, 68, 45, 0.08);
  }

  .our-expertise-{{ section.id }} .check-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    margin-right: 1.25rem;
    background: {{ accent_color | color_modify: 'alpha', 0.1 }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ accent_color }};
  }

  .our-expertise-{{ section.id }} .item-label {
    font-size: 1.15rem;
    font-weight: 700;
    color: {{ heading_color }};
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* ── Footer Info ── */
  .our-expertise-{{ section.id }} .footer-content {
    background: {{ card_bg }};
    padding: clamp(2rem, 4vw, 4rem);
    border-radius: 36px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
    position: relative;
    overflow: hidden;
  }

  .our-expertise-{{ section.id }} .footer-content::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 6px;
    background: {{ accent_color }};
  }

  .our-expertise-{{ section.id }} .footer-text {
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    color: {{ text_color }};
    line-height: 1.7;
    margin: 0;
    opacity: 0.9;
    font-weight: 450;
  }

  @media screen and (max-width: 767px) {
    .our-expertise-{{ section.id }} .footer-content {
      padding: 2rem 1.5rem;
    }
  }
{%- endstyle -%}

<section class="our-expertise-{{ section.id }}" id="Expertise-{{ section.id }}">
  <div class="container">
    
    <div class="header-wrap">
      {%- if section.settings.title != blank -%}
        <h2 class="main-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="expertise-grid">
      {%- for block in section.blocks -%}
        <div class="expert-item" {{ block.shopify_attributes }}>
          <div class="check-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <p class="item-label">{{ block.settings.title | escape }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_text != blank -%}
      <div class="footer-content">
        <div class="footer-text">
          {{ section.settings.footer_text }}
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Our Expertise",
  "tag": "section",
  "class": "section-our-expertise",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Expertises"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We manufacture and export a wide range of high-quality food products, including:"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Information",
      "default": "<p>Our advanced processing technology ensures superior taste retention, nutritional value preservation, and extended shelf life — especially in our freeze-drying segment, where we focus on premium quality and global export standards.</p>"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1300
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Item Background",
      "default": "#F8FBFA"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#10A560"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "expertise_item",
      "name": "Expertise Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Expertise Name",
          "default": "Expertise Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Expertise",
      "blocks": [
        { "type": "expertise_item", "settings": { "title": "Freeze-Dried Fruits & Vegetables" } },
        { "type": "expertise_item", "settings": { "title": "Pulses & Lentils" } },
        { "type": "expertise_item", "settings": { "title": "Spices & Whole Spices" } },
        { "type": "expertise_item", "settings": { "title": "Herbs & Dehydrated Products" } },
        { "type": "expertise_item", "settings": { "title": "Millets & Traditional Indian Grains" } },
        { "type": "expertise_item", "settings": { "title": "Jaggery & Natural Sweeteners" } }
      ]
    }
  ]
}
{% endschema %}
