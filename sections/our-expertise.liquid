{%- liquid
  assign accent_color = section.settings.accent_color
  assign footer_bg = section.settings.footer_bg_color
  assign section_bg = section.settings.bg_color
-%}

{%- style -%}
  .our-expertise-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: 0;
    background-color: {{ section_bg }};
    position: relative;
  }

  .our-expertise-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  .our-expertise-{{ section.id }} .header-wrap {
    text-align: center;
    margin-bottom: 4rem;
  }

  .our-expertise-{{ section.id }} .main-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    color: {{ accent_color }};
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 1rem;
    letter-spacing: 0.05em;
    font-family: serif;
  }

  .our-expertise-{{ section.id }} .title-underline {
    width: 100px;
    height: 1px;
    background-color: {{ accent_color }};
    margin: 0.5rem auto 1.5rem;
  }

  .our-expertise-{{ section.id }} .subheading {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: #444;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.4;
  }

  /* ── Grid ── */
  .our-expertise-{{ section.id }} .expertise-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
    margin-bottom: 5rem;
  }

  @media screen and (min-width: 768px) {
    .our-expertise-{{ section.id }} .expertise-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .our-expertise-{{ section.id }} .expert-item {
    background: #fff;
    padding: 2.5rem 2rem;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    border: 1px solid #eee;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .our-expertise-{{ section.id }} .expert-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.12);
  }

  .our-expertise-{{ section.id }} .item-number {
    font-size: 1.5rem;
    font-weight: 700;
    color: {{ accent_color }};
  }

  .our-expertise-{{ section.id }} .item-label {
    font-size: 1.35rem;
    font-weight: 700;
    color: #222;
    margin: 0;
    line-height: 1.2;
  }

  /* ── Footer Bar ── */
  .our-expertise-{{ section.id }} .footer-bar {
    background-color: {{ footer_bg }};
    padding: 3rem 0;
    border-top: 3px solid {{ accent_color }};
    margin-top: 2rem;
    color: #fff;
  }

  .our-expertise-{{ section.id }} .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .our-expertise-{{ section.id }} .footer-left {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    flex: 1;
  }

  .our-expertise-{{ section.id }} .qa-icon {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    color: {{ accent_color }};
  }

  .our-expertise-{{ section.id }} .qa-icon svg {
    width: 100%;
    height: 100%;
  }

  .our-expertise-{{ section.id }} .qa-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .our-expertise-{{ section.id }} .qa-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: {{ accent_color }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .our-expertise-{{ section.id }} .qa-text {
    font-size: 0.95rem;
    line-height: 1.6;
    opacity: 0.9;
  }

  .our-expertise-{{ section.id }} .footer-badge {
    flex-shrink: 0;
    width: 130px;
    height: 130px;
    border-radius: 50%;
    background: radial-gradient(circle, {{ accent_color }} 0%, #8b6b45 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    border: 3px solid rgba(255,255,255,0.1);
  }

  .our-expertise-{{ section.id }} .badge-count {
    font-size: 2.8rem;
    font-weight: 900;
    color: #222;
    line-height: 1;
  }

  .our-expertise-{{ section.id }} .badge-label {
    font-size: 0.8rem;
    font-weight: 700;
    color: #222;
    text-transform: uppercase;
  }

  @media screen and (max-width: 767px) {
    .our-expertise-{{ section.id }} .footer-inner {
      flex-direction: column;
      text-align: center;
    }
    .our-expertise-{{ section.id }} .footer-left {
      flex-direction: column;
      align-items: center;
    }
    .our-expertise-{{ section.id }} .footer-badge {
      width: 110px;
      height: 110px;
    }
  }
{%- endstyle -%}

<section class="our-expertise-{{ section.id }}">
  <div class="container">
    <div class="header-wrap">
      <h2 class="main-title">{{ section.settings.title }}</h2>
      <div class="title-underline"></div>
      {%- if section.settings.subheading != blank -%}
        <p class="subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="expertise-grid">
      {%- for block in section.blocks -%}
        <div class="expert-item" {{ block.shopify_attributes }}>
          <div class="item-number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
          <p class="item-label">{{ block.settings.title | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="footer-bar">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-left">
          <div class="qa-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <div class="qa-content">
            <div class="qa-title">{{ section.settings.footer_label | default: "Quality Assurance" }}</div>
            <div class="qa-text">
              {{ section.settings.footer_text }}
            </div>
          </div>
        </div>
        <div class="footer-badge">
          <span class="badge-count">{{ section.blocks.size }}</span>
          <span class="badge-label">Products</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Our Expertise",
  "tag": "section",
  "class": "section-our-expertise",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "OUR EXPERTISE"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We craft and export a distinguished range of high-quality food products, meeting global premium standards."
    },
    {
      "type": "header",
      "content": "Footer Bar"
    },
    {
      "type": "text",
      "id": "footer_label",
      "label": "Footer Label",
      "default": "QUALITY ASSURANCE"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Information",
      "default": "<p>Our advanced processing technology ensures superior taste retention, nutritional value preservation, and extended shelf life—especially in our freeze-drying segment, where we focus on premium quality and global export standards.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F8F3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Gold)",
      "default": "#C5A47E"
    },
    {
      "type": "color",
      "id": "footer_bg_color",
      "label": "Footer Background (Dark Green)",
      "default": "#003D2B"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1200
    }
  ],
  "blocks": [
    {
      "type": "expert",
      "name": "Expertise Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Freeze-Dried Fruits & Vegetables"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Expertise",
      "blocks": [
        { "type": "expert", "settings": { "title": "Freeze-Dried Fruits & Vegetables" } },
        { "type": "expert", "settings": { "title": "Pulses & Lentils" } },
        { "type": "expert", "settings": { "title": "Spices & Whole Spices" } },
        { "type": "expert", "settings": { "title": "Herbs & Dehydrated Products" } },
        { "type": "expert", "settings": { "title": "Millets & Traditional Indian Grains" } },
        { "type": "expert", "settings": { "title": "Jaggery & Natural Sweeteners" } }
      ]
    }
  ]
}
{% endschema %}
