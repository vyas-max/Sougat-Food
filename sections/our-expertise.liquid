{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign card_bg = section.settings.card_bg
  assign section_bg = section.settings.bg_color
-%}

{%- style -%}
  .our-expertise-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    overflow: hidden;
    position: relative;
  }

  .our-expertise-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 70%;
    height: 100%;
    background: radial-gradient(ellipse, {{ accent_color | color_modify: 'alpha', 0.04 }} 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .our-expertise-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -15%;
    width: 80%;
    height: 80%;
    background: radial-gradient(ellipse, {{ heading_color | color_modify: 'alpha', 0.03 }} 0%, transparent 50%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .our-expertise-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeInLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  .our-expertise-{{ section.id }} .anim-header {
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
  .our-expertise-{{ section.id }} .anim-item {
    opacity: 0;
    animation: fadeInLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .our-expertise-{{ section.id }} .anim-footer {
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    animation-delay: 0.6s;
  }
  .our-expertise-{{ section.id }} .d-1 { animation-delay: 0.1s; }
  .our-expertise-{{ section.id }} .d-2 { animation-delay: 0.2s; }
  .our-expertise-{{ section.id }} .d-3 { animation-delay: 0.3s; }
  .our-expertise-{{ section.id }} .d-4 { animation-delay: 0.4s; }
  .our-expertise-{{ section.id }} .d-5 { animation-delay: 0.5s; }
  .our-expertise-{{ section.id }} .d-6 { animation-delay: 0.6s; }

  .our-expertise-{{ section.id }} .header-wrap {
    text-align: left;
    margin-bottom: clamp(3.5rem, 6vw, 5rem);
    max-width: 900px;
  }

  .our-expertise-{{ section.id }} .title-decoration {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .our-expertise-{{ section.id }} .title-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, {{ accent_color }} 0%, {{ accent_color | color_lighten: 15 }} 100%);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    box-shadow: 0 8px 24px {{ accent_color | color_modify: 'alpha', 0.3 }};
    animation: float 4s ease-in-out infinite;
  }

  .our-expertise-{{ section.id }} .title-badge {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: {{ accent_color }};
    background: {{ accent_color | color_modify: 'alpha', 0.1 }};
    padding: 0.5rem 1rem;
    border-radius: 50px;
    border: 1px solid {{ accent_color | color_modify: 'alpha', 0.2 }};
  }

  .our-expertise-{{ section.id }} .main-title {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    color: {{ heading_color }};
    margin: 0 0 1.5rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1.05;
    position: relative;
  }

  .our-expertise-{{ section.id }} .main-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, {{ accent_color }}, {{ accent_color | color_lighten: 20 }});
    border-radius: 2px;
  }

  .our-expertise-{{ section.id }} .subheading {
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    color: {{ text_color }};
    opacity: 0.8;
    line-height: 1.7;
    margin: 1.75rem 0 0;
    font-weight: 400;
    max-width: 700px;
  }

  .our-expertise-{{ section.id }} .expertise-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: clamp(4rem, 8vw, 6rem);
  }

  @media screen and (min-width: 768px) {
    .our-expertise-{{ section.id }} .expertise-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .our-expertise-{{ section.id }} .expertise-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .our-expertise-{{ section.id }} .expert-item {
    display: flex;
    align-items: center;
    background: linear-gradient(145deg, {{ card_bg }} 0%, rgba(255,255,255,0.9) 100%);
    padding: 1.75rem 2rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow: 
      0 4px 20px rgba(0, 0, 0, 0.03),
      0 1px 3px rgba(0, 0, 0, 0.02),
      inset 0 1px 0 rgba(255,255,255,1);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: default;
    position: relative;
    overflow: hidden;
  }

  .our-expertise-{{ section.id }} .expert-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, {{ accent_color | color_modify: 'alpha', 0.08 }} 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .our-expertise-{{ section.id }} .expert-item::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, {{ accent_color }}, transparent);
    opacity: 0;
    transition: opacity 0.5s ease;
    transform: scaleX(0);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease;
  }

  .our-expertise-{{ section.id }} .expert-item:hover {
    transform: translateY(-8px) scale(1.02);
    background: #fff;
    border-color: rgba(255, 255, 255, 1);
    box-shadow: 
      0 25px 50px rgba(20, 68, 45, 0.1),
      0 0 0 1px {{ accent_color | color_modify: 'alpha', 0.08 }};
  }

  .our-expertise-{{ section.id }} .expert-item:hover::before {
    opacity: 1;
  }

  .our-expertise-{{ section.id }} .expert-item:hover::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .our-expertise-{{ section.id }} .check-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    margin-right: 1.5rem;
    background: linear-gradient(135deg, {{ accent_color | color_modify: 'alpha', 0.15 }} 0%, {{ accent_color | color_modify: 'alpha', 0.05 }} 100%);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ accent_color }};
    box-shadow: 0 4px 15px {{ accent_color | color_modify: 'alpha', 0.2 }};
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    z-index: 1;
  }

  .our-expertise-{{ section.id }} .check-icon svg {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .our-expertise-{{ section.id }} .item-content {
    display: flex;
    align-items: center;
    width: 100%;
  }

  .our-expertise-{{ section.id }} .item-label {
    flex: 1;
    font-size: 1.1rem;
    font-weight: 700;
    color: {{ heading_color }};
    margin: 0;
    letter-spacing: -0.01em;
    position: relative;
    z-index: 1;
    transition: color 0.4s ease;
    text-align: left;
    padding-left: 0;
  }

  .our-expertise-{{ section.id }} .expert-item:hover .check-icon {
    transform: scale(1.1) rotate(5deg);
    background: linear-gradient(135deg, {{ accent_color }} 0%, {{ accent_color | color_lighten: 10 }} 100%);
    color: #fff;
    box-shadow: 0 8px 25px {{ accent_color | color_modify: 'alpha', 0.35 }};
  }

  .our-expertise-{{ section.id }} .expert-item:hover .check-icon svg {
    transform: scale(1.1);
  }

  .our-expertise-{{ section.id }} .expert-item:hover .item-label {
    color: {{ accent_color }};
  }

  .our-expertise-{{ section.id }} .footer-content {
    background: linear-gradient(145deg, {{ card_bg }} 0%, rgba(255,255,255,0.6) 100%);
    padding: clamp(2.5rem, 4.5vw, 4.5rem) clamp(2rem, 4vw, 4rem);
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 
      0 20px 60px rgba(0, 0, 0, 0.04),
      0 1px 3px rgba(0, 0, 0, 0.02),
      inset 0 1px 0 rgba(255,255,255,1);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .our-expertise-{{ section.id }} .footer-content::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 6px;
    background: linear-gradient(180deg, {{ accent_color | color_lighten: 15 }}, {{ accent_color }});
    box-shadow: 4px 0 20px {{ accent_color | color_modify: 'alpha', 0.4 }};
  }

  .our-expertise-{{ section.id }} .footer-content::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, {{ accent_color | color_modify: 'alpha', 0.05 }} 0%, transparent 70%);
    pointer-events: none;
  }

  .our-expertise-{{ section.id }} .footer-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    gap: 2rem;
  }

  .our-expertise-{{ section.id }} .footer-icon {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, {{ accent_color | color_modify: 'alpha', 0.15 }} 0%, {{ accent_color | color_modify: 'alpha', 0.05 }} 100%);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ accent_color }};
    box-shadow: 0 8px 25px {{ accent_color | color_modify: 'alpha', 0.15 }};
  }

  .our-expertise-{{ section.id }} .footer-text {
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    color: {{ text_color }};
    line-height: 1.8;
    margin: 0;
    opacity: 0.9;
    font-weight: 450;
  }

  .our-expertise-{{ section.id }} .footer-text p {
    margin: 0;
  }

  @media screen and (max-width: 767px) {
    .our-expertise-{{ section.id }} .footer-content {
      padding: 2.5rem 1.5rem;
      border-radius: 24px;
    }
    .our-expertise-{{ section.id }} .footer-inner {
      flex-direction: column;
      gap: 1.5rem;
    }
    .our-expertise-{{ section.id }} .footer-icon {
      width: 52px;
      height: 52px;
    }
    .our-expertise-{{ section.id }} .main-title::after {
      width: 60px;
      height: 3px;
    }
  }
{%- endstyle -%}

<section class="our-expertise-{{ section.id }}" id="Expertise-{{ section.id }}">
  <div class="container">
    
    <div class="header-wrap anim-header">
      <div class="title-decoration">
        <div class="title-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
        </div>
        <span class="title-badge">Expertise</span>
      </div>
      {%- if section.settings.title != blank -%}
        <h2 class="main-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="expertise-grid">
      {%- for block in section.blocks -%}
        {%- assign delay_class = forloop.index | modulo: 6 | plus: 1 -%}
        <div class="expert-item anim-item d-{{ delay_class }}" {{ block.shopify_attributes }}>
          <div class="item-content">
            <div class="check-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <p class="item-label">{{ block.settings.title | escape }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_text != blank -%}
      <div class="footer-content anim-footer">
        <div class="footer-inner">
          <div class="footer-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
          </div>
          <div class="footer-text">
            {{ section.settings.footer_text }}
          </div>
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Our Expertise",
  "tag": "section",
  "class": "section-our-expertise",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Expertises"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We manufacture and export a wide range of high-quality food products, including:"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Information",
      "default": "<p>Our advanced processing technology ensures superior taste retention, nutritional value preservation, and extended shelf life — especially in our freeze-drying segment, where we focus on premium quality and global export standards.</p>"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1300
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Item Background",
      "default": "#F8FBFA"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#10A560"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "expertise_item",
      "name": "Expertise Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Expertise Name",
          "default": "Expertise Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Expertise",
      "blocks": [
        { "type": "expertise_item", "settings": { "title": "Freeze-Dried Fruits & Vegetables" } },
        { "type": "expertise_item", "settings": { "title": "Pulses & Lentils" } },
        { "type": "expertise_item", "settings": { "title": "Spices & Whole Spices" } },
        { "type": "expertise_item", "settings": { "title": "Herbs & Dehydrated Products" } },
        { "type": "expertise_item", "settings": { "title": "Millets & Traditional Indian Grains" } },
        { "type": "expertise_item", "settings": { "title": "Jaggery & Natural Sweeteners" } }
      ]
    }
  ]
}
{% endschema %}
