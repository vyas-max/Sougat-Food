{% schema %}
{
  "name": "Partnership Opportunities",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f9fafb"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background Gradient",
      "default": "linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%)"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Partnership Opportunities",
      "info": "Leave blank to hide the main heading."
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Join hands with Sougat Foods for sustainable mutual growth."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "opportunity",
      "name": "Opportunity Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Partnership Category"
        },
        {
          "type": "textarea",
          "id": "top_description",
          "label": "Top Description"
        },
        {
          "type": "text",
          "id": "list_heading",
          "label": "List Heading",
          "info": "E.g., 'We offer:' or 'We cater to:'"
        },
        {
          "type": "select",
          "id": "list_style",
          "label": "List Style",
          "options": [
            { "value": "checkmark", "label": "Checkmarks (✓)" },
            { "value": "bullet", "label": "Bullets (•)" },
            { "value": "none", "label": "None" }
          ],
          "default": "checkmark"
        },
        {
          "type": "textarea",
          "id": "list_items",
          "label": "List Items",
          "info": "Enter one item per line."
        },
        {
          "type": "textarea",
          "id": "bottom_description",
          "label": "Bottom Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partnership Opportunities",
      "blocks": [
        {
          "type": "opportunity",
          "settings": {
            "title": "Private Label Manufacturing",
            "top_description": "Launch or expand your own brand with our premium freeze-dried solutions.",
            "list_heading": "We offer:",
            "list_style": "checkmark",
            "list_items": "Customized product formulations\\nRetail & bulk packaging options\\nBranding & labeling support\\nExport-ready documentation\\nStrict quality and compliance standards",
            "bottom_description": "From concept to finished product, we ensure seamless execution under global food safety certifications."
          }
        },
        {
          "type": "opportunity",
          "settings": {
            "title": "Distributorship Opportunities",
            "top_description": "Become an authorized Sougat distributor and grow in your region with a premium, high-demand product range.",
            "list_heading": "We provide:",
            "list_style": "checkmark",
            "list_items": "Attractive margins\\nMarketing & promotional support\\nConsistent product supply\\nDedicated business assistance",
            "bottom_description": "Ideal for FMCG distributors, modern trade suppliers, and health-focused retail networks."
          }
        },
        {
          "type": "opportunity",
          "settings": {
            "title": "Bulk & Institutional Supply",
            "top_description": "",
            "list_heading": "We cater to:",
            "list_style": "bullet",
            "list_items": "HoReCa (Hotels, Restaurants, Cafes)\\nFood manufacturers\\nExporters & Importers\\nCorporate gifting companies\\nHealth & nutrition brands",
            "bottom_description": "With scalable production capacity and reliable logistics, we ensure timely and consistent bulk deliveries."
          }
        },
        {
          "type": "opportunity",
          "settings": {
            "title": "Export Partnerships",
            "top_description": "We are actively expanding in international markets and welcome global importers and distributors. Our facility operates under internationally recognized standards, ensuring smooth cross-border trade and compliance.",
            "list_heading": "",
            "list_style": "none",
            "list_items": "",
            "bottom_description": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }} {
    background: {{ section.settings.background_gradient }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body-family, sans-serif);
    overflow: hidden;
  }

  {% if request.design_mode %}
  .section-{{ section.id }} .po-fade-up {
    opacity: 1 !important;
    transform: none !important;
  }
  {% endif %}

  .po-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Section Header */
  .po-section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .po-section-title {
    font-size: 2.75rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 1rem;
    position: relative;
    display: inline-block;
  }

  /* Fancy Underline matching the other sections */
  .po-section-title::after {
    content: '';
    position: absolute;
    width: 60%;
    height: 4px;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(90deg, #3b82f6, #0ea5e9, #10b981);
    border-radius: 2px;
  }

  .po-section-subtitle {
    font-size: 1.25rem;
    color: #475569;
    max-width: 600px;
    margin: 1.5rem auto 0;
    line-height: 1.6;
  }

  /* Responsive Grid Layout */
  .po-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
    gap: 2.5rem;
  }

  .po-card {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    border-radius: 24px;
    padding: 3rem;
    box-shadow: 0 20px 40px -15px rgba(0,0,0,0.05); /* Soft, elevated shadow */
    border: 1px solid rgba(255, 255, 255, 0.7); /* Frosted glass border effect */
    position: relative;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  /* Glowing hover effect behind the card content */
  .po-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at top right, rgba(14,165,233,0.08) 0%, rgba(255,255,255,0) 60%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: 0;
  }

  .po-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px -20px rgba(14, 165, 233, 0.15); /* Tinted shadow drop */
    border-color: rgba(14, 165, 233, 0.3);
  }
  
  .po-card:hover::before {
    opacity: 1;
  }

  .po-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding-bottom: 1.5rem;
  }

  /* Decorative Diamond Container */
  .po-icon-wrapper {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 2px 4px rgba(255,255,255,0.5), 0 4px 10px rgba(14, 165, 233, 0.2);
    transform: rotate(45deg); /* Spin the square to a diamond */
    transition: transform 0.4s ease;
  }

  .po-card:hover .po-icon-wrapper {
    transform: rotate(0deg) scale(1.05); /* Unspin on hover */
  }

  .po-icon {
    transform: rotate(-45deg); /* Counter rotate the icon itself */
    transition: transform 0.4s ease;
  }

  .po-card:hover .po-icon {
    transform: rotate(0deg);
  }

  .po-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: #1e293b;
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .po-content-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  .po-desc-top {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #64748b;
    margin-bottom: 2rem;
  }

  .po-list-container {
    background: rgba(248, 250, 252, 0.6);
    border-radius: 16px;
    padding: 1.5rem;
    border: 1px dashed #cbd5e1;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .po-list-heading {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .po-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .po-list li {
    font-size: 1.05rem;
    color: #475569;
    margin-bottom: 1rem;
    display: flex;
    align-items: flex-start;
    line-height: 1.6;
    font-weight: 500;
  }
  
  .po-list li:last-child {
    margin-bottom: 0;
  }

  /* List Styles */
  .po-list.style-checkmark li::before {
    content: '✓';
    color: #10b981; /* Green checkmark */
    font-weight: 800;
    margin-right: 12px;
    font-size: 1.2rem;
    margin-top: -2px;
  }

  .po-list.style-bullet li::before {
    content: '•';
    color: #0ea5e9; /* Blue bullet */
    font-weight: 800;
    margin-right: 12px;
    font-size: 1.5rem;
    margin-top: -4px;
  }

  .po-desc-bottom {
    font-size: 1.05rem;
    line-height: 1.6;
    color: #475569;
    background: #f1f5f9;
    padding: 1.25rem;
    border-radius: 12px;
    margin-top: 1.5rem;
    border-left: 4px solid #10b981;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1024px) {
    .po-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .po-section-title { font-size: 2rem; }
    .po-section-subtitle { font-size: 1.1rem; }
    
    .po-card {
      padding: 2rem;
      border-radius: 20px;
    }
    
    .po-title {
      font-size: 1.35rem;
    }
    
    .po-desc-top, .po-list li, .po-list-heading {
      font-size: 1rem;
    }
  }

  /* Reveal Animations */
  .po-fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.165, 0.84, 0.44, 1), transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  
  .po-fade-up.po-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<div class="section-{{ section.id }}">
  <div class="po-container">
    
    {% if section.settings.section_title != blank or section.settings.section_subtitle != blank %}
      <div class="po-section-header po-fade-up">
        {% if section.settings.section_title != blank %}
          <h2 class="po-section-title">{{ section.settings.section_title }}</h2>
        {% endif %}
        {% if section.settings.section_subtitle != blank %}
          <p class="po-section-subtitle">{{ section.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="po-grid">
      {% for block in section.blocks %}
        <div class="po-card po-fade-up" style="transition-delay: {{ forloop.index | times: 150 }}ms;" {{ block.shopify_attributes }}>
          
          <div class="po-header">
            <div class="po-icon-wrapper">
              <svg class="po-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12h14M12 5l7 7-7 7" stroke="#0284c7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="po-title">{{ block.settings.title }}</h3>
          </div>

          <div class="po-content-wrap">
            {% if block.settings.top_description != blank %}
              <p class="po-desc-top">{{ block.settings.top_description }}</p>
            {% endif %}

            {% if block.settings.list_heading != blank or block.settings.list_items != blank %}
              <div class="po-list-container">
                {% if block.settings.list_heading != blank %}
                  <div class="po-list-heading">{{ block.settings.list_heading }}</div>
                {% endif %}

                {% if block.settings.list_items != blank and block.settings.list_style != 'none' %}
                  {% assign items = block.settings.list_items | split: '\n' %}
                  <ul class="po-list style-{{ block.settings.list_style }}">
                    {% for item in items %}
                      {% assign clean_item = item | strip %}
                      {% if clean_item != blank %}
                        <li>{{ clean_item }}</li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
            {% endif %}

            {% if block.settings.bottom_description != blank %}
              <div class="po-desc-bottom">{{ block.settings.bottom_description }}</div>
            {% endif %}
          </div>

        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    function initPO() {
      const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
      };

      const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
              if (entry.isIntersecting) {
                  entry.target.classList.add('po-visible');
                  observer.unobserve(entry.target);
              }
          });
      }, observerOptions);

      const fadeElements = document.querySelectorAll('.section-{{ section.id }} .po-fade-up');
      fadeElements.forEach(el => observer.observe(el));
    }

    initPO();

    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initPO();
      }
    });
  })();
</script>
