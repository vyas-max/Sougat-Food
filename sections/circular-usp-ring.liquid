{%- liquid
  assign bg_color = section.settings.bg_color | default: '#FFFFFF'
  assign circle_size = section.settings.center_image_size | default: 320
  assign padding_top = section.settings.padding_top | default: 80
  assign padding_bottom = section.settings.padding_bottom | default: 80
  assign slide_duration = section.settings.slide_duration | default: 2000
  
  assign center_images = section.blocks | where: 'type', 'center_image'
  assign usp_blocks = section.blocks | where: 'type', 'usp_point'
-%}

<section
  class="circular-usp-ring circular-usp-ring--{{ section.id }}{% if section.settings.show_connector_lines %} circular-usp-ring--with-lines{% endif %}"
  style="background-color: {{ bg_color }}; padding-top: {{ padding_top }}px; padding-bottom: {{ padding_bottom }}px; --circle-size: {{ circle_size }}px;"
>
  <div class="circular-usp-ring__inner">
    <div class="circular-usp-ring__heading-group">
      {%- if section.settings.eyebrow_text != blank -%}
        <p class="circular-usp-ring__eyebrow">{{ section.settings.eyebrow_text }}</p>
      {%- endif -%}

      {%- if section.settings.heading_text != blank -%}
        <h2 class="circular-usp-ring__heading">{{ section.settings.heading_text }}</h2>
      {%- endif -%}
    </div>

    <div class="circular-usp-ring__layout">
      {%- comment %} Left column: USP 1 top, USP 3 bottom {% endcomment -%}
      <div class="circular-usp-ring__col circular-usp-ring__col--left">
        {%- for block in usp_blocks -%}
          {%- if forloop.index == 1 or forloop.index == 3 -%}
            <div class="circular-usp-ring__usp circular-usp-ring__usp--left" {{ block.shopify_attributes }}>
              <span class="circular-usp-ring__number">{{ forloop.index }}</span>
              {%- if block.settings.title != blank -%}
                <p class="circular-usp-ring__usp-title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="circular-usp-ring__usp-description">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment %} Center column: circle image carousel {% endcomment -%}
      <div class="circular-usp-ring__col circular-usp-ring__col--center">
        <div class="circular-usp-ring__orbit-container">
          <div class="circular-usp-ring__orbit circular-usp-ring__orbit--1">
            <span class="circular-usp-ring__orbit-dot"></span>
          </div>
          <div class="circular-usp-ring__orbit circular-usp-ring__orbit--2">
            <span class="circular-usp-ring__orbit-dot"></span>
            <span class="circular-usp-ring__orbit-dot"></span>
          </div>
          <div class="circular-usp-ring__glow"></div>
        </div>
        <div class="circular-usp-ring__image-shell">
          {%- if center_images.size > 0 -%}
            <div class="circular-usp-ring__carousel" data-slide-duration="{{ slide_duration }}">
              {%- for block in center_images -%}
                <div class="circular-usp-ring__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 1200 | image_tag:
                      class: 'circular-usp-ring__image',
                      loading: 'lazy',
                      widths: '360, 540, 720, 900, 1100, 1200',
                      sizes: '(max-width: 749px) 80vw, 400px',
                      alt: block.settings.image.alt | default: section.settings.heading_text | default: 'Ring visual'
                    }}
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- elsif section.settings.center_image != blank -%}
            {{ section.settings.center_image | image_url: width: 1200 | image_tag:
              class: 'circular-usp-ring__image',
              loading: 'lazy',
              widths: '360, 540, 720, 900, 1100, 1200',
              sizes: '(max-width: 749px) 80vw, 400px',
              alt: section.settings.heading_text | default: section.settings.eyebrow_text | default: 'Ring visual'
            }}
          {%- else -%}
            <div class="circular-usp-ring__placeholder" aria-hidden="true">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment %} Right column: USP 2 top, USP 4 bottom {% endcomment -%}
      <div class="circular-usp-ring__col circular-usp-ring__col--right">
        {%- for block in usp_blocks -%}
          {%- if forloop.index == 2 or forloop.index == 4 -%}
            <div class="circular-usp-ring__usp circular-usp-ring__usp--right" {{ block.shopify_attributes }}>
              <span class="circular-usp-ring__number">{{ forloop.index }}</span>
              {%- if block.settings.title != blank -%}
                <p class="circular-usp-ring__usp-title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="circular-usp-ring__usp-description">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="circular-usp-ring__mobile-list" aria-label="Unique selling points">
        {%- for block in usp_blocks -%}
          <div class="circular-usp-ring__usp circular-usp-ring__usp--mobile" {{ block.shopify_attributes }}>
            <span class="circular-usp-ring__number">{{ forloop.index }}</span>
            {%- if block.settings.title != blank -%}
              <p class="circular-usp-ring__usp-title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="circular-usp-ring__usp-description">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  .circular-usp-ring--{{ section.id }} {
    color: inherit;
    position: relative;
  }

  .circular-usp-ring__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: clamp(16px, 4vw, 48px);
    text-align: center;
    position: relative;
  }

  .circular-usp-ring__heading-group {
    max-width: 720px;
    margin: 0 auto clamp(48px, 7vw, 90px);
  }

  .circular-usp-ring__eyebrow {
    margin: 0 0 14px;
    font-size: clamp(0.8rem, 1.2vw, 0.95rem);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0f8a4b;
    opacity: 0.85;
  }

  .circular-usp-ring__heading {
    margin: 0;
    font-size: clamp(32px, 5.5vw, 54px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    font-weight: 700;
    background: linear-gradient(135deg, #0b6c3c 0%, #10a560 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .circular-usp-ring__layout {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: clamp(24px, 4vw, 60px);
  }

  .circular-usp-ring__col {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: clamp(40px, 8vw, 100px);
    min-height: var(--circle-size);
  }

  .circular-usp-ring__col--left {
    align-items: flex-end;
    text-align: right;
  }

  .circular-usp-ring__col--right {
    align-items: flex-start;
    text-align: left;
  }

  .circular-usp-ring__col--center {
    min-height: auto;
    justify-content: center;
    position: relative;
  }

  /* Orbit container */
  .circular-usp-ring__orbit-container {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .circular-usp-ring__orbit {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(15, 138, 75, 0.1);
  }

  .circular-usp-ring__orbit--1 {
    width: calc(var(--circle-size) + 80px);
    height: calc(var(--circle-size) + 80px);
    animation: orbit-rotate 20s linear infinite;
  }

  .circular-usp-ring__orbit--2 {
    width: calc(var(--circle-size) + 140px);
    height: calc(var(--circle-size) + 140px);
    border-style: dashed;
    animation: orbit-rotate 35s linear infinite reverse;
  }

  .circular-usp-ring__orbit-dot {
    position: absolute;
    width: 10px;
    height: 10px;
    background: linear-gradient(135deg, #10a560, #0b6c3c);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(16, 165, 96, 0.5);
  }

  .circular-usp-ring__orbit--1 .circular-usp-ring__orbit-dot {
    top: 0;
    left: 50%;
    transform: translateX(-50%) translateY(-50%);
  }

  .circular-usp-ring__orbit--2 .circular-usp-ring__orbit-dot:nth-child(1) {
    top: 50%;
    left: 0;
    transform: translateX(-50%) translateY(-50%);
  }

  .circular-usp-ring__orbit--2 .circular-usp-ring__orbit-dot:nth-child(2) {
    top: 50%;
    right: 0;
    transform: translateX(50%) translateY(-50%);
  }

  .circular-usp-ring__glow {
    position: absolute;
    width: calc(var(--circle-size) + 60px);
    height: calc(var(--circle-size) + 60px);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(16, 165, 96, 0.12) 0%, transparent 70%);
    animation: glow-pulse 3s ease-in-out infinite;
  }

  @keyframes orbit-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes glow-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.05); }
  }

  .circular-usp-ring__image-shell {
    width: var(--circle-size);
    height: var(--circle-size);
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(145deg, #ffffff 0%, #f0f7f2 100%);
    box-shadow: 
      0 30px 80px rgba(15, 138, 75, 0.18),
      0 12px 32px rgba(0, 0, 0, 0.1),
      inset 0 0 30px rgba(16, 165, 96, 0.05);
    flex-shrink: 0;
    border: 3px solid rgba(15, 138, 75, 0.15);
    position: relative;
    z-index: 2;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .circular-usp-ring__col--center:hover .circular-usp-ring__image-shell {
    transform: scale(1.02);
    box-shadow: 
      0 35px 90px rgba(15, 138, 75, 0.22),
      0 15px 40px rgba(0, 0, 0, 0.12),
      inset 0 0 40px rgba(16, 165, 96, 0.08);
  }

  .circular-usp-ring__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .circular-usp-ring__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
  }

  .circular-usp-ring__placeholder svg {
    width: 60%;
    height: 60%;
    opacity: 0.4;
  }

  .circular-usp-ring__usp {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 200px;
    position: relative;
    transition: transform 0.3s ease;
  }

  .circular-usp-ring__usp:hover {
    transform: translateY(-4px);
  }

  .circular-usp-ring__mobile-list {
    display: none;
  }

  .circular-usp-ring__number {
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 700;
    background: linear-gradient(135deg, #10a560 0%, #0b6c3c 100%);
    color: #fff;
    margin-bottom: 6px;
    position: relative;
    box-shadow: 0 6px 20px rgba(15, 138, 75, 0.3);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .circular-usp-ring__number::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid rgba(16, 165, 96, 0.2);
    animation: number-pulse 2s ease-in-out infinite;
  }

  @keyframes number-pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.1); opacity: 0; }
  }

  .circular-usp-ring__usp:hover .circular-usp-ring__number {
    transform: scale(1.1);
    box-shadow: 0 8px 25px rgba(15, 138, 75, 0.4);
  }

  .circular-usp-ring__usp--left .circular-usp-ring__number {
    margin-left: auto;
  }

  .circular-usp-ring__usp-title {
    margin: 0;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #173826;
    transition: color 0.3s ease;
  }

  .circular-usp-ring__usp:hover .circular-usp-ring__usp-title {
    color: #0f8a4b;
  }

  .circular-usp-ring__usp-description {
    margin: 0;
    font-size: clamp(0.85rem, 1vw, 0.95rem);
    line-height: 1.6;
    color: rgba(23, 56, 38, 0.7);
  }

  /* Connector lines (desktop only) */
  @media screen and (min-width: 900px) {
    .circular-usp-ring--with-lines .circular-usp-ring__usp--left::after {
      content: '';
      position: absolute;
      right: -32px;
      top: 50%;
      width: 28px;
      height: 2px;
      background: linear-gradient(90deg, rgba(16, 165, 96, 0.4), rgba(16, 165, 96, 0.1));
      border-radius: 2px;
      transform: translateY(-50%);
      transition: width 0.3s ease, background 0.3s ease;
    }

    .circular-usp-ring__usp--left:hover::after {
      width: 40px;
      background: linear-gradient(90deg, rgba(16, 165, 96, 0.6), rgba(16, 165, 96, 0.2));
    }

    .circular-usp-ring--with-lines .circular-usp-ring__usp--right::before {
      content: '';
      position: absolute;
      left: -32px;
      top: 50%;
      width: 28px;
      height: 2px;
      background: linear-gradient(90deg, rgba(16, 165, 96, 0.1), rgba(16, 165, 96, 0.4));
      border-radius: 2px;
      transform: translateY(-50%);
      transition: width 0.3s ease, background 0.3s ease;
    }

    .circular-usp-ring__usp--right:hover::before {
      width: 40px;
      background: linear-gradient(90deg, rgba(16, 165, 96, 0.2), rgba(16, 165, 96, 0.6));
    }
  }

  /* Tablet */
  @media screen and (max-width: 899px) {
    .circular-usp-ring__layout {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 32px 20px;
    }

    .circular-usp-ring__col--center {
      grid-column: 1 / -1;
      grid-row: 1;
    }

    .circular-usp-ring__col--left,
    .circular-usp-ring__col--right {
      min-height: auto;
      gap: 20px;
    }

    .circular-usp-ring__col--left {
      align-items: flex-end;
      text-align: right;
    }

    .circular-usp-ring__col--right {
      align-items: flex-start;
      text-align: left;
    }

    .circular-usp-ring__image-shell {
      width: min(var(--circle-size), 280px);
      height: min(var(--circle-size), 280px);
      margin: 0 auto;
    }

    .circular-usp-ring__orbit--2 {
      display: none;
    }

    .circular-usp-ring__orbit--1 {
      width: calc(min(var(--circle-size), 280px) + 60px);
      height: calc(min(var(--circle-size), 280px) + 60px);
    }

    .circular-usp-ring__glow {
      width: calc(min(var(--circle-size), 280px) + 40px);
      height: calc(min(var(--circle-size), 280px) + 40px);
    }

  }

  /* Mobile */
  @media screen and (max-width: 599px) {
    .circular-usp-ring__layout {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .circular-usp-ring__col--center {
      grid-row: 1;
    }

    .circular-usp-ring__col--left,
    .circular-usp-ring__col--right {
      display: none;
    }

    .circular-usp-ring__image-shell {
      width: min(var(--circle-size), 220px);
      height: min(var(--circle-size), 220px);
    }

    .circular-usp-ring__orbit-container {
      display: none;
    }

    .circular-usp-ring__mobile-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      text-align: center;
    }

    .circular-usp-ring__mobile-list .circular-usp-ring__usp {
      align-items: center;
      max-width: none;
    }

    .circular-usp-ring__mobile-list .circular-usp-ring__number {
      margin-left: 0;
      width: 38px;
      height: 38px;
      font-size: 1rem;
    }

    .circular-usp-ring__mobile-list .circular-usp-ring__usp-title {
      font-size: 0.9rem;
    }

    .circular-usp-ring__mobile-list .circular-usp-ring__usp-description {
      display: none;
    }
  }

  /* Carousel styles */
  .circular-usp-ring__carousel {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .circular-usp-ring__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease-in-out;
  }

  .circular-usp-ring__slide.is-active {
    opacity: 1;
    z-index: 1;
  }

  .circular-usp-ring__slide .circular-usp-ring__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const carousels = document.querySelectorAll('.circular-usp-ring__carousel');
    
    carousels.forEach(function(carousel) {
      const slides = carousel.querySelectorAll('.circular-usp-ring__slide');
      if (slides.length <= 1) return;
      
      const duration = parseInt(carousel.dataset.slideDuration) || 2000;
      let currentIndex = 0;
      
      setInterval(function() {
        slides[currentIndex].classList.remove('is-active');
        currentIndex = (currentIndex + 1) % slides.length;
        slides[currentIndex].classList.add('is-active');
      }, duration);
    });
  });
</script>

{% schema %}
{
  "name": "Circular USP ring",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "100% Natural"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading",
      "default": "Why Sougat"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center image (fallback)",
      "info": "Used only if no Center Image blocks are added"
    },
    {
      "type": "range",
      "id": "center_image_size",
      "label": "Center image size",
      "min": 260,
      "max": 520,
      "step": 10,
      "default": 400,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "slide_duration",
      "label": "Slide duration",
      "info": "Time between slides in milliseconds",
      "min": 1000,
      "max": 5000,
      "step": 500,
      "default": 2000,
      "unit": "ms"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "checkbox",
      "id": "show_connector_lines",
      "label": "Show connector lines",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 10,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 10,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "center_image",
      "name": "Center image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "usp_point",
      "name": "USP point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "USP Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Circular USP ring",
      "blocks": [
        {
          "type": "usp_point",
          "settings": {
            "title": "Green Tea Extract",
            "description": "Provides antioxidant protection and helps soothe and refresh the skin."
          }
        },
        {
          "type": "usp_point",
          "settings": {
            "title": "Brown Algae Extract",
            "description": "Supports skin firmness and helps improve elasticity."
          }
        },
        {
          "type": "usp_point",
          "settings": {
            "title": "Red Algae Extract",
            "description": "Helps hydrate the skin and smooth the appearance of fine lines."
          }
        },
        {
          "type": "usp_point",
          "settings": {
            "title": "Caffeine",
            "description": "Energizes the skin, helping reduce the appearance of puffiness and fatigue."
          }
        }
      ]
    }
  ]
}
{% endschema %}
