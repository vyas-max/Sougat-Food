{%- liquid
  assign text_color = section.settings.text_color | default: '#1a1a1a'
-%}

<section class="info-cards info-cards--{{ section.id }}">
  <div class="info-cards__grid">
    {%- for block in section.blocks -%}
      {%- assign block_bg = block.settings.background_color | default: '#e7f8e3' -%}
      <div class="info-cards__item" style="--card-bg: {{ block_bg }};" {{ block.shopify_attributes }}>
        <div class="info-cards__content">
          <div class="info-cards__image-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 400 | image_tag:
                loading: 'lazy',
                class: 'info-cards__image',
                widths: '200, 300, 400',
                sizes: '(max-width: 749px) 140px, 180px',
                alt: block.settings.title | default: block.settings.subtitle
              }}
            {%- else -%}
              <div class="info-cards__placeholder">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>
          <div class="info-cards__text">
            {%- if block.settings.subtitle != blank -%}
              <p class="info-cards__subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="info-cards__title">{{ block.settings.title }}</h3>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="info-cards__item" style="--card-bg: {% cycle '#e7f8e3', '#d4f0d0', '#eef5eb', '#f4f7f2' %};">
          <div class="info-cards__content">
            <div class="info-cards__image-wrap">
              <div class="info-cards__placeholder">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
            <div class="info-cards__text">
              <p class="info-cards__subtitle">{% cycle 'No Preservatives.', 'Eco-Friendly', 'High Protein', 'Simply Wholesome' %}</p>
              <h3 class="info-cards__title">{% cycle 'Organic. All-Natural. Non-Allergenic.', 'Plant-Based. Clean Ingredients. No Additives.', 'Vegan. Soy Free. Low Sugar.', 'Naturally Delicious. Pure Ingredients.' %}</h3>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .info-cards--{{ section.id }} {
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }

  .info-cards__grid {
    display: grid;
    grid-template-columns: 1fr;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .info-cards__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .info-cards__item {
    background: var(--card-bg);
    padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 3vw, 2.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 280px;
  }

  @media screen and (min-width: 750px) {
    .info-cards__item {
      min-height: 320px;
    }
  }

  .info-cards__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 280px;
  }

  .info-cards__image-wrap {
    width: clamp(120px, 28vw, 160px);
    height: clamp(120px, 28vw, 160px);
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.5);
    border: 3px solid rgba(255, 255, 255, 0.8);
  }

  .info-cards__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .info-cards__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(200, 200, 200, 0.2);
  }

  .info-cards__placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.4;
  }

  .info-cards__text {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .info-cards__subtitle {
    margin: 0;
    font-size: 0.85rem;
    color: {{ text_color | default: '#1a1a1a' }};
    opacity: 0.7;
  }

  .info-cards__title {
    margin: 0;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    font-weight: 600;
    line-height: 1.4;
    color: {{ text_color | default: '#1a1a1a' }};
  }
</style>

{% schema %}
{
  "name": "Info cards",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Info card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Circle image"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "No Preservatives."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Organic. All-Natural. Non-Allergenic."
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Card background",
          "default": "#e7f8e3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Info cards",
      "category": "Image",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "subtitle": "No Preservatives.",
            "title": "Organic. All-Natural. Non-Allergenic.",
            "background_color": "#e7f8e3"
          }
        },
        {
          "type": "card",
          "settings": {
            "subtitle": "Eco-Friendly",
            "title": "Plant-Based. Clean Ingredients. No Additives.",
            "background_color": "#d4f0d0"
          }
        },
        {
          "type": "card",
          "settings": {
            "subtitle": "High Protein",
            "title": "Vegan. Soy Free. Low Sugar.",
            "background_color": "#eef5eb"
          }
        },
        {
          "type": "card",
          "settings": {
            "subtitle": "Simply Wholesome",
            "title": "Naturally Delicious. Pure Ingredients.",
            "background_color": "#f4f7f2"
          }
        }
      ]
    }
  ]
}
{% endschema %}
