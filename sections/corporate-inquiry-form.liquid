<style>
  .corporate-inquiry-section {
    padding: 60px 20px;
    background-color: #ffffff;
    display: flex;
    justify-content: center;
  }

  .corporate-inquiry-container {
    width: 100%;
    max-width: 650px;
    background: #ffffff;
  }

  .corporate-inquiry-title {
    text-align: center;
    font-size: 32px;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 8px;
    line-height: 1.2;
    font-family: inherit;
  }

  .corporate-inquiry-subtitle {
    text-align: center;
    font-size: 16px;
    color: #4a4a4a;
    margin-bottom: 32px;
    line-height: 1.5;
    font-family: inherit;
  }

  .corporate-inquiry-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-field-group {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .form-input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    font-size: 15px;
    color: #333;
    font-family: inherit;
    transition: border-color 0.3s ease;
    background-color: #ffffff;
  }

  .form-input::placeholder {
    color: #a0a0a0;
  }

  .form-input:focus {
    outline: none;
    border-color: #1a1a1a;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .checkbox-group {
    flex-direction: row;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
    margin-bottom: 4px;
  }

  .form-checkbox {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: #007bc4;
  }

  .checkbox-label {
    font-size: 15px;
    color: #333;
    cursor: pointer;
    font-family: inherit;
  }

  .submit-button {
    background-color: #1a1a1a;
    color: #ffffff;
    font-size: 16px;
    font-weight: 600;
    padding: 16px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    width: 100%;
    margin-top: 8px;
    transition: background-color 0.3s ease;
    font-family: inherit;
  }

  .submit-button:hover {
    background-color: #000000;
  }

  .form-disclaimer {
    text-align: center;
    font-size: 13px;
    color: #4a4a4a;
    margin-top: 16px;
    font-family: inherit;
  }

  .form-disclaimer a {
    color: #1a1a1a;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .form-disclaimer a:hover {
    text-decoration: underline;
  }

  .form-status {
    padding: 12px;
    border-radius: 6px;
    margin-bottom: 16px;
    text-align: center;
    font-size: 14px;
    font-family: inherit;
  }

  .form-success {
    background-color: #e8f5e9;
    color: #2e7d32;
    border: 1px solid #c8e6c9;
  }

  .form-error {
    background-color: #ffebee;
    color: #c62828;
    border: 1px solid #ffcdd2;
  }

  @media (max-width: 768px) {
    .corporate-inquiry-title {
      font-size: 26px;
    }
    .corporate-inquiry-section {
      padding: 40px 15px;
    }
  }
</style>

<section class="corporate-inquiry-section">
  <div class="corporate-inquiry-container">
    <h2 class="corporate-inquiry-title">{{ section.settings.heading }}</h2>
    <p class="corporate-inquiry-subtitle">{{ section.settings.subheading }}</p>
    
    {% form 'contact', class: 'corporate-inquiry-form' %}
      {%- if form.posted_successfully? -%}
        <div class="form-status form-success" tabindex="-1" autofocus>
          {{ section.settings.success_message }}
        </div>
      {%- elsif form.errors -%}
        <div class="form-status form-error">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="form-field-group">
        <input type="text" id="ContactFormFirstName-{{ section.id }}" name="contact[First Name]" placeholder="First name" class="form-input">
      </div>
      
      <div class="form-field-group">
        <input type="text" id="ContactFormLastName-{{ section.id }}" name="contact[Last Name]" placeholder="Last name" class="form-input">
      </div>
      
      <div class="form-field-group">
        <input type="text" id="ContactFormCompany-{{ section.id }}" name="contact[Company]" placeholder="Company" class="form-input">
      </div>
      
      <div class="form-field-group">
        <input type="email" id="ContactFormEmail-{{ section.id }}" name="contact[email]" placeholder="Email" required class="form-input">
      </div>
      
      <div class="form-field-group checkbox-group">
        <input type="checkbox" id="ContactFormMarketing-{{ section.id }}" name="contact[accepts_marketing]" value="yes" checked class="form-checkbox">
        <label for="ContactFormMarketing-{{ section.id }}" class="checkbox-label">Email me news and offers</label>
      </div>

      <div class="form-field-group">
        <input type="number" id="ContactFormExpectedQty-{{ section.id }}" name="contact[Expected Order Qty]" placeholder="Expected Order Qty" class="form-input">
      </div>
      
      <div class="form-field-group">
        <textarea id="ContactFormRequirement-{{ section.id }}" name="contact[Requirement]" placeholder="Please mention your requirement (in brief)" rows="4" class="form-input form-textarea"></textarea>
      </div>
      
      <button type="submit" class="submit-button">{{ section.settings.button_text }}</button>

      <p class="form-disclaimer">
        View our <a href="{{ section.settings.privacy_url | default: '/policies/privacy-policy' }}">privacy policy</a> and <a href="{{ section.settings.tos_url | default: '/policies/terms-of-service' }}">terms of service</a>.
      </p>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Corporate Inquiry Form",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "For Corporate Gifting Inquiries"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Please fill out the form below, and one of our sales representatives will reach out to you shortly."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Submit"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "Thanks for contacting us. We'll get back to you as soon as possible."
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy Policy URL"
    },
    {
      "type": "url",
      "id": "tos_url",
      "label": "Terms of Service URL"
    }
  ],
  "presets": [
    {
      "name": "Corporate Inquiry Form",
      "category": "Forms"
    }
  ]
}
{% endschema %}
