{% schema %}
{
  "name": "Category Selection",
  "tag": "section",
  "class": "section-category-selection",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DISCOVER YOUR FAVORITE"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Select from our premium collection"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "interaction_mode",
      "label": "Interaction Mode",
      "options": [
        { "value": "hover", "label": "Hover" },
        { "value": "click", "label": "Click" }
      ],
      "default": "hover",
      "info": "Choose how users preview the item details."
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "page-width",
          "label": "Page Width"
        }
      ],
      "default": "page-width"
    }
  ],
  "blocks": [
    {
      "type": "flavor",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Item Image",
          "info": "Upload a transparent PNG for the badge."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Item Name",
          "default": "Item Name"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Linked Product",
          "info": "Select a product to display its details in the preview card."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Custom Description",
          "info": "Overrides the product description if set."
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 300,
          "step": 5,
          "unit": "px",
          "label": "Image Width",
          "default": 180
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Selection",
      "blocks": [
        { "type": "flavor", "settings": { "title": "Category 1" } },
        { "type": "flavor", "settings": { "title": "Category 2" } },
        { "type": "flavor", "settings": { "title": "Category 3" } },
        { "type": "flavor", "settings": { "title": "Category 4" } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .flavor-selection {
    padding: 60px 0; /* Updated padding to remove horizontal padding as container handles it */
    overflow: hidden;
    position: relative;
    background: linear-gradient(160deg, #fff8f0 0%, #f1f3ed 100%);
    color: #2b2b2b;
  }

  /* Container handles width now via class */
  .flavor-selection__container {
    /* Styles handled by page-width-content usually, but we ensure basic center just in case */
    margin: 0 auto;
    width: 100%;
  }

  /* Explicitly enforce page width variable if the class doesn't fully cover it in this context */
  .flavor-selection__container.page-width-content {
    max-width:1440px;
    padding: 0 1.5rem; 
  }
  
  .flavor-selection__container.full-width {
      max-width: 100%;
      padding: 0 20px;
  }

  .flavor-selection__header {
    text-align: center;
    margin-bottom: 50px;
  }

  .flavor-selection__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    line-height: 1.1;
    margin-bottom: 10px;
    color: #2b2b2b;
    /* Default theme typography settings applied */
  }
  
  /* Size modifiers based on schema setting */
  .flavor-selection__heading.h0 { font-size: clamp(2.5rem, 5vw, 4rem); }
  .flavor-selection__heading.h1 { font-size: clamp(2rem, 4vw, 3rem); }
  .flavor-selection__heading.h2 { font-size: clamp(1.5rem, 3vw, 2.5rem); }

  .flavor-selection__subheading {
    font-family: var(--font-body-family);
    font-style: italic;
    font-size: 16px;
    color: rgba(43, 43, 43, 0.7);
  }

  /* Split Layout */
  .flavor-selection__layout {
    display: flex;
    gap: 40px;
    align-items: flex-start;
  }

  /* Left Side: Grid */
  .flavor-selection__grid {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: initial;
  }

  .flavor-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    transition: transform 0.3s ease, opacity 0.3s ease;
    position: relative;
    padding: 12px;
    border-radius: 18px;
    background-color: rgba(255, 255, 255, 0.35);
    border: 1px solid rgba(226, 140, 42, 0.15);
  }

  .flavor-item:hover, .flavor-item.is-active {
    transform: translateY(-4px);
    background-color: rgba(120, 192, 67, 0.12);
    box-shadow: 0 12px 30px rgba(84, 122, 74, 0.15);
  }

  .flavor-item__image {
    display: block;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.1));
    pointer-events: none; /* Let clicks pass to container */
  }

  .flavor-item--placeholder {
    background-color: rgb(var(--color-background-rgb) / 0.6);
   
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: rgb(var(--color-foreground-rgb) / 0.7);
    text-align: center;
    padding: 10px;
    border: 2px dashed var(--color-border);
  }

  /* Right Side: Preview Card */
  .flavor-selection__preview {
    flex: 1;
    position: sticky;
    top: 40px;
    background: #ffffff;
    padding: 40px;
    border-radius: 24px;
    box-shadow: 0 25px 60px rgba(18, 27, 24, 0.08); /* Soft shadow */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center; /* Center content vertically if brief */
    text-align: center;
    min-height: 400px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    border: 1px solid #f0e5d7;
    
  }

  .flavor-selection__preview.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  /* Initial state/Empty State for preview */
  .flavor-selection__preview-empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  .flavor-preview__image-wrapper {
      width: 100%;
      max-width: 300px;
      margin-bottom: 20px;
      aspect-ratio: 1/1;
      display: flex;
      align-items: center;
      justify-content: center;
  }
  
  .flavor-preview__image {
      width: 100%;
      height: 100%;
      object-fit: contain;
  }

  .flavor-preview__title {
      font-family: var(--font-heading-family);
      font-size: 28px;
      margin-bottom: 10px;
      color: #2b2b2b;
  }

  .flavor-preview__price {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 20px;
      color: #5b724d;
  }

  .flavor-preview__description {
      margin-bottom: 30px;
      line-height: 1.6;
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
  }

  .flavor-preview__button {
      display: inline-block;
      padding: 12px 30px;
      background-color: #78c043;
      color: #0d2609;
      border: 1px solid transparent;
      text-decoration: none;
      text-transform: uppercase;
      font-weight: 600;
      letter-spacing: 1px;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      border-radius: 999px;
  }
  
  .flavor-preview__button:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 24px rgba(120, 192, 67, 0.35);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .flavor-selection__layout {
       flex-direction: column;
       align-items: center;
       gap: 20px;
    }
    
    /* Mobile Scrolling Grid */
    .flavor-selection__grid {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        justify-content: flex-start;
        width: 100%;
        padding-bottom: 20px; /* Space for scrollbar */
        -webkit-overflow-scrolling: touch;
        scroll-snap-type: x mandatory;
        gap: 15px; /* Re-introduce gap for mobile spacing */
        padding-inline: 20px; /* Start padding */
        scroll-padding-left: 20px;
    }
    
    .flavor-item {
        flex: 0 0 auto; /* Don't shrink */
        width: 100px; /* Fixed width for scrolling items */
        scroll-snap-align: start;
        border-radius: 18px;
    }
    
    /* Make images smaller on mobile list */
    .flavor-item__image {
        width: 80px !important; /* Override inline styles for consistency in scroll strip */
        height: 80px !important;
        object-fit: contain;
    }
    
    .flavor-selection__preview {
        width: 100%;
        position: static;
        min-height: auto;
        order: 2; 
        padding: 20px;
        margin-top: 10px;
        border-radius: 24px;
    }
    
    .flavor-preview__image-wrapper {
        max-width: 200px;
    }
  }
</style>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="flavor-selection section color-{{ section.settings.color_scheme }} {% if section.settings.section_width == 'page-width' %}section--page-width{% endif %}" data-interaction-mode="{{ section.settings.interaction_mode }}">
  <div class="flavor-selection__container {% if section.settings.section_width == 'page-width' %}page-width-content{% else %}full-width{% endif %}">
    <div class="flavor-selection__header">
      <h2 class="flavor-selection__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      <p class="flavor-selection__subheading">{{ section.settings.subheading }}</p>
    </div>

    <div class="flavor-selection__layout">
      
      <!-- Grid Area -->
      <div class="flavor-selection__grid">
        {% for block in section.blocks %}
          {% assign product = block.settings.product %}
          <div class="flavor-item" 
               {{ block.shopify_attributes }}
               data-block-id="{{ block.id }}"
               data-title="{{ block.settings.title | escape }}"
               data-image-src="{% if product.featured_image %}{{ product.featured_image | image_url: width: 600 }}{% elsif block.settings.image %}{{ block.settings.image | image_url: width: 600 }}{% endif %}"
               data-price="{{ product.price | money }}"
               data-url="{{ product.url }}"
               data-description="{% if block.settings.description != blank %}{{ block.settings.description | escape }}{% else %}{{ product.description | strip_html | truncate: 150 }}{% endif %}"
          >
            {% if block.settings.image %}
              {% capture img_style %}width: {{ block.settings.image_width }}px;{% endcapture %}
              {{ block.settings.image | image_url: width: 600 | image_tag: 
                loading: 'lazy', 
                class: 'flavor-item__image',
                style: img_style,
                widths: '200, 300, 400, 600',
                alt: block.settings.title
              }}
            {% else %}
               <div class="flavor-item--placeholder" style="width: {{ block.settings.image_width }}px; height: {{ block.settings.image_width }}px;">
                  {{ block.settings.title }}
                </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <!-- Preview Area -->
      <div class="flavor-selection__preview" id="flavor-preview-{{ section.id }}">
          <div class="flavor-selection__preview-empty">
              <p>Hover over an item to see details</p>
          </div>
          <!-- Dynamic Content will be injected here -->
          <div class="flavor-preview__content" style="display:none; width: 100%; display: flex; flex-direction: column; align-items: center;">
              <div class="flavor-preview__image-wrapper">
                  <img src="" alt="" class="flavor-preview__image">
              </div>
              <h3 class="flavor-preview__title"></h3>
              <p class="flavor-preview__price"></p>
              <p class="flavor-preview__description"></p>
              <a href="#" class="flavor-preview__button">Shop Now</a>
          </div>
      </div>

    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const section = document.querySelector('.flavor-selection[data-interaction-mode]');
    if(!section) return;

    const interactionMode = section.dataset.interactionMode; // 'hover' or 'click'
    const items = section.querySelectorAll('.flavor-item');
    const previewContainer = section.querySelector('.flavor-selection__preview');
    const emptyState = previewContainer.querySelector('.flavor-selection__preview-empty');
    const contentState = previewContainer.querySelector('.flavor-preview__content');
    
    // Elements to update
    const prevImage = previewContainer.querySelector('.flavor-preview__image');
    const prevTitle = previewContainer.querySelector('.flavor-preview__title');
    const prevPrice = previewContainer.querySelector('.flavor-preview__price');
    const prevDesc = previewContainer.querySelector('.flavor-preview__description');
    const prevBtn = previewContainer.querySelector('.flavor-preview__button');

    function updatePreview(item) {
        const title = item.dataset.title;
        const imgSrc = item.dataset.imageSrc;
        const price = item.dataset.price;
        const description = item.dataset.description;
        const url = item.dataset.url;

        // Update DOM
        if(imgSrc) {
            prevImage.src = imgSrc;
            prevImage.alt = title;
        }
        prevTitle.textContent = title;
        prevPrice.textContent = price;
        prevDesc.textContent = description;
        
        if(url && url !== 'undefined') {
          prevBtn.href = url;
          prevBtn.style.display = 'inline-block';
          prevBtn.textContent = 'View Product';
        } else {
          prevBtn.style.display = 'none';
        }

        // Toggle Visibility
        emptyState.style.display = 'none';
        contentState.style.display = 'flex';
        previewContainer.classList.add('is-visible');

        // Highlight active item
        items.forEach(i => i.classList.remove('is-active'));
        item.classList.add('is-active');
    }
    
    // Select first item by default if visible
    if(items.length > 0) {
        updatePreview(items[0]);
    }

    items.forEach(item => {
        if(interactionMode === 'click') {
            item.addEventListener('click', () => updatePreview(item));
        } else {
            // Hover mode
            item.addEventListener('mouseenter', () => updatePreview(item));
            // Optional: Click also updates in hover mode for mobile touch support
            item.addEventListener('click', () => updatePreview(item));
        }
    });
});
</script>
