{%- style -%}
  .blog-cards-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }
  
  .blog-cards-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  @media screen and (min-width: 768px) {
    .blog-cards-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .blog-cards-grid-{{ section.id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .blog-card-{{ section.id }} {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease;
  }

  .blog-card-{{ section.id }}:hover {
    transform: translateY(-5px);
  }

  .blog-card-image-wrapper-{{ section.id }} {
    width: 100%;
    height: 250px;
    background-color: #f3f3f3;
  }

  .blog-card-image-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-card-svg-placeholder-{{ section.id }} {
    width: 100%;
    height: 100%;
    fill: #ccc;
    background-color: #f3f3f3;
  }

  .blog-card-content-{{ section.id }} {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .blog-card-title-{{ section.id }} {
    font-size: 1.25rem;
    font-weight: 600;
    margin-block-start: 0;
    margin-block-end: 10px;
    color: #333;
  }

  .blog-card-text-{{ section.id }} {
    font-size: 1rem;
    color: #666;
    line-height: 1.5;
  }

  .blog-card-text-{{ section.id }} p {
    margin-top: 0;
  }

  .blog-cards-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .blog-cards-heading-{{ section.id }} {
    font-size: 2.5rem;
    color: #333;
    margin-bottom: 10px;
  }
{%- endstyle -%}

<div class="blog-cards-section-{{ section.id }}">
  {%- if section.settings.title != blank -%}
    <div class="blog-cards-header-{{ section.id }}">
      <h2 class="blog-cards-heading-{{ section.id }}">{{ section.settings.title }}</h2>
    </div>
  {%- endif -%}

  <div class="blog-cards-grid-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="blog-card-{{ section.id }}" {{ block.shopify_attributes }}>
        
        <div class="blog-card-image-wrapper-{{ section.id }}">
          {%- if block.settings.photo != blank -%}
            <img 
              src="{{ block.settings.photo | image_url: width: 600 }}" 
              alt="{{ block.settings.photo.alt | escape }}" 
              class="blog-card-image-{{ section.id }}"
              loading="lazy"
              width="600"
              height="400"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'blog-card-svg-placeholder-' | append: section.id }}
          {%- endif -%}
        </div>
        
        <div class="blog-card-content-{{ section.id }}">
          {%- if block.settings.title != blank -%}
            <h3 class="blog-card-title-{{ section.id }}">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="blog-card-text-{{ section.id }}">
              {{ block.settings.text }}
            </div>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Blog Cards Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Latest from the Blog"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Max Width (px)",
      "default": 1200
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Blog Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Blog Post Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add a short description or excerpt for this blog card here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog Cards Section",
      "category": "Blog",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
