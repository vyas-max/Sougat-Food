{%- style -%}
  .recipe-grid-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }
  
  .recipe-grid-container-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .recipe-grid-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 50px;
  }

  .recipe-grid-heading-{{ section.id }} {
    font-size: clamp(2rem, 4vw, 3rem);
    color: #111;
    margin-bottom: 15px;
    font-weight: 800;
  }

  .recipe-grid-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }
  
  @media screen and (min-width: 768px) {
    .recipe-grid-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .recipe-grid-grid-{{ section.id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .recipe-card-{{ section.id }} {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    border: 1px solid #f0f0f0;
  }

  .recipe-card-{{ section.id }}:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  }

  .recipe-card-image-wrapper-{{ section.id }} {
    position: relative;
    width: 100%;
    padding-bottom: 75%; /* 4:3 Aspect Ratio */
    background: #f8f8f8;
    overflow: hidden;
  }

  .recipe-card-image-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .recipe-card-{{ section.id }}:hover .recipe-card-image-{{ section.id }} {
    transform: scale(1.1);
  }

  .recipe-card-badge-{{ section.id }} {
    position: absolute;
    top: 15px;
    left: 15px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(5px);
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    color: #111;
    z-index: 2;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .recipe-card-content-{{ section.id }} {
    padding: 25px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .recipe-card-meta-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 12px;
    font-size: 0.8rem;
    color: #777;
    font-weight: 600;
  }

  .recipe-meta-item-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .recipe-meta-icon-{{ section.id }} {
    width: 14px;
    height: 14px;
    opacity: 0.6;
  }

  .recipe-card-title-{{ section.id }} {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 12px 0;
    color: #111;
    line-height: 1.25;
  }

  .recipe-card-desc-{{ section.id }} {
    font-size: 1rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 25px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .recipe-card-footer-{{ section.id }} {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 20px;
    border-top: 1px solid #f4f4f4;
  }

  .recipe-card-author-{{ section.id }} {
    font-size: 0.85rem;
    color: #999;
    font-weight: 500;
  }

  .recipe-card-link-{{ section.id }} {
    font-size: 0.9rem;
    color: #111;
    font-weight: 700;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: transform 0.3s ease;
  }

  .recipe-card-link-{{ section.id }}:hover {
    transform: translateX(3px);
  }
{%- endstyle -%}

<div class="recipe-grid-section-{{ section.id }}">
  <div class="recipe-grid-container-{{ section.id }}">
    
    <div class="recipe-grid-header-{{ section.id }}">
      {%- if section.settings.title != blank -%}
        <h2 class="recipe-grid-heading-{{ section.id }}">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <div class="recipe-grid-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="recipe-card-{{ section.id }}" {{ block.shopify_attributes }}>
          
          <div class="recipe-card-image-wrapper-{{ section.id }}">
            {%- if block.settings.category != blank -%}
              <span class="recipe-card-badge-{{ section.id }}">{{ block.settings.category }}</span>
            {%- endif -%}

            {%- if block.settings.photo != blank -%}
              <img 
                src="{{ block.settings.photo | image_url: width: 800 }}" 
                alt="{{ block.settings.photo.alt | escape }}" 
                class="recipe-card-image-{{ section.id }}"
                loading="lazy"
                width="800"
                height="600"
              >
            {%- else -%}
              {{ 'food-1' | placeholder_svg_tag: 'recipe-card-placeholder' }}
            {%- endif -%}
          </div>

          <div class="recipe-card-content-{{ section.id }}">
            <div class="recipe-card-meta-{{ section.id }}">
              {%- if block.settings.prep_time != blank -%}
                <div class="recipe-meta-item-{{ section.id }}">
                  <svg class="recipe-meta-icon-{{ section.id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  {{ block.settings.prep_time }}
                </div>
              {%- endif -%}
              {%- if block.settings.difficulty != blank -%}
                <div class="recipe-meta-item-{{ section.id }}">
                  <svg class="recipe-meta-icon-{{ section.id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                  {{ block.settings.difficulty }}
                </div>
              {%- endif -%}
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="recipe-card-title-{{ section.id }}">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="recipe-card-desc-{{ section.id }}">
                {{ block.settings.text }}
              </div>
            {%- endif -%}

            <div class="recipe-card-footer-{{ section.id }}">
              {%- if block.settings.author != blank -%}
                <span class="recipe-card-author-{{ section.id }}">By {{ block.settings.author }}</span>
              {%- endif -%}
              
              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.button_link | default: '#' }}" class="recipe-card-link-{{ section.id }}">
                  {{ block.settings.button_label }}
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
              {%- endif -%}
            </div>
          </div>

        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Recipe Grid Cards",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Latest Recipes"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Max Width (px)",
      "default": 1300
    }
  ],
  "blocks": [
    {
      "type": "recipe_card",
      "name": "Recipe Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category Badge",
          "default": "Breakfast"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Recipe Title",
          "default": "Blueberry Smoothie Bowl"
        },
        {
          "type": "text",
          "id": "prep_time",
          "label": "Prep Time",
          "default": "10 Mins"
        },
        {
          "type": "text",
          "id": "difficulty",
          "label": "Difficulty",
          "default": "Easy"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>A healthy and refreshing start to your morning with fresh blueberries and granola.</p>"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Sarah Doe"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Link Text",
          "default": "View Recipe"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Recipe Grid Cards"
    }
  ]
}
{% endschema %}
