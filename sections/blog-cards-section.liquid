{%- style -%}
  .blog-cards-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_color }};
    position: relative;
    overflow: hidden;
  }

  .blog-cards-section-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: -30%;
    right: -15%;
    width: 60%;
    height: 70%;
    background: radial-gradient(ellipse, {{ section.settings.accent_color | color_modify: 'alpha', 0.04 }} 0%, transparent 60%);
    pointer-events: none;
  }

  .blog-cards-section-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: -20%;
    left: -10%;
    width: 50%;
    height: 50%;
    background: radial-gradient(ellipse, {{ section.settings.heading_color | color_modify: 'alpha', 0.02 }} 0%, transparent 50%);
    pointer-events: none;
  }

  .blog-cards-container-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  .blog-cards-header-{{ section.id }} {
    text-align: center;
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .blog-cards-badge-wrap-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .blog-cards-badge-icon-{{ section.id }} {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, {{ section.settings.accent_color }} 0%, {{ section.settings.accent_hover }} 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    box-shadow: 0 6px 20px {{ section.settings.accent_color | color_modify: 'alpha', 0.3 }};
  }

  .blog-cards-badge-icon-{{ section.id }} svg {
    width: 20px;
    height: 20px;
  }

  .blog-cards-badge-text-{{ section.id }} {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ section.settings.accent_color }};
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
    padding: 0.5rem 1.25rem;
    border-radius: 50px;
    border: 1px solid {{ section.settings.accent_color | color_modify: 'alpha', 0.2 }};
  }

  .blog-cards-heading-{{ section.id }} {
    font-size: clamp(2rem, 5vw, 3.25rem);
    color: {{ section.settings.heading_color }};
    margin: 0 0 1rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .blog-cards-subheading-{{ section.id }} {
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    color: {{ section.settings.subheading_color }};
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
    font-weight: 400;
    opacity: 0.9;
  }

  .blog-cards-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.card_gap }}px;
  }

  @media screen and (min-width: 640px) {
    .blog-cards-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .blog-cards-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    }
  }

  .blog-card-{{ section.id }} {
    background: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    box-shadow: 
      0 4px 20px rgba(0, 0, 0, 0.04),
      0 1px 3px rgba(0, 0, 0, 0.02);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    border: 1px solid rgba(0, 0, 0, 0.04);
    position: relative;
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  .blog-card-{{ section.id }}:nth-child(1) { animation-delay: 0.1s; }
  .blog-card-{{ section.id }}:nth-child(2) { animation-delay: 0.2s; }
  .blog-card-{{ section.id }}:nth-child(3) { animation-delay: 0.3s; }
  .blog-card-{{ section.id }}:nth-child(4) { animation-delay: 0.4s; }
  .blog-card-{{ section.id }}:nth-child(5) { animation-delay: 0.5s; }
  .blog-card-{{ section.id }}:nth-child(6) { animation-delay: 0.6s; }

  .blog-card-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, {{ section.settings.accent_color | color_modify: 'alpha', 0.02 }} 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 0;
  }

  .blog-card-{{ section.id }}:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow: 
      0 25px 50px rgba(0, 0, 0, 0.1),
      0 0 0 1px {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
  }

  .blog-card-{{ section.id }}:hover::before {
    opacity: 1;
  }

  .blog-card-img-wrap-{{ section.id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ section.settings.image_ratio }}%;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    overflow: hidden;
  }

  .blog-card-img-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1), filter 0.5s ease;
  }

  .blog-card-{{ section.id }}:hover .blog-card-img-{{ section.id }} {
    transform: scale(1.1);
    filter: brightness(0.7);
  }

  .blog-card-placeholder-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
  }

  .blog-card-placeholder-{{ section.id }} svg {
    width: 40%;
    height: 40%;
    opacity: 0.2;
    color: #fff;
  }

  .blog-card-overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, 
      transparent 0%, 
      rgba(0, 0, 0, 0.2) 40%,
      rgba(0, 0, 0, 0.6) 70%,
      rgba(0, 0, 0, 0.85) 100%);
    z-index: 1;
    transition: background 0.4s ease;
  }

  .blog-card-{{ section.id }}:hover .blog-card-overlay-{{ section.id }} {
    background: linear-gradient(180deg, 
      rgba(0, 0, 0, 0.1) 0%, 
      rgba(0, 0, 0, 0.3) 40%,
      rgba(0, 0, 0, 0.7) 70%,
      rgba(0, 0, 0, 0.95) 100%);
  }

  .blog-card-content-{{ section.id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 1.5rem 1.5rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 50%;
  }

  .blog-card-badge-{{ section.id }} {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(255, 255, 255, 0.95);
    color: {{ section.settings.accent_color }};
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    z-index: 3;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blog-card-{{ section.id }}:hover .blog-card-badge-{{ section.id }} {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  .blog-card-actions-{{ section.id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 3;
    display: flex;
    gap: 8px;
  }

  .blog-card-action-btn-{{ section.id }} {
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transform: translateY(-10px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    border: none;
  }

  .blog-card-{{ section.id }}:hover .blog-card-action-btn-{{ section.id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .blog-card-action-btn-{{ section.id }}:nth-child(1) { transition-delay: 0s; }
  .blog-card-action-btn-{{ section.id }}:nth-child(2) { transition-delay: 0.05s; }

  .blog-card-action-btn-{{ section.id }}:hover {
    background: #fff;
    transform: scale(1.1);
  }

  .blog-card-action-btn-{{ section.id }} svg {
    width: 18px;
    height: 18px;
    color: {{ section.settings.accent_color }};
  }

  .blog-card-title-wrap-{{ section.id }} {
    margin-bottom: 0.75rem;
  }

  .blog-card-title-{{ section.id }} {
    font-size: 1.35rem;
    font-weight: 800;
    color: #ffffff;
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
    transition: all 0.3s ease;
  }

  .blog-card-{{ section.id }}:hover .blog-card-title-{{ section.id }} {
    color: #fff;
  }

  .blog-card-meta-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 0.75rem;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blog-card-{{ section.id }}:hover .blog-card-meta-{{ section.id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .blog-card-meta-item-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 500;
  }

  .blog-card-meta-item-{{ section.id }} svg {
    width: 14px;
    height: 14px;
    opacity: 0.9;
  }

  .blog-card-desc-{{ section.id }} {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.1s;
  }

  .blog-card-{{ section.id }}:hover .blog-card-desc-{{ section.id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .blog-card-popup-trigger-{{ section.id }} {
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.15s;
  }

  .blog-card-{{ section.id }}:hover .blog-card-popup-trigger-{{ section.id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .blog-card-popup-trigger-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.15);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 10px 20px;
    border-radius: 50px;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    font-family: inherit;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .blog-card-popup-trigger-btn-{{ section.id }}:hover {
    background: {{ section.settings.accent_color }};
    border-color: {{ section.settings.accent_color }};
    transform: translateX(5px);
  }

  .blog-card-popup-icon-{{ section.id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .blog-card-popup-trigger-btn-{{ section.id }}:hover .blog-card-popup-icon-{{ section.id }} {
    transform: translateX(3px);
  }

  @media screen and (max-width: 749px) {
    .blog-card-content-{{ section.id }} {
      padding: 1.5rem 1rem 1rem;
    }
    .blog-card-title-{{ section.id }} {
      font-size: 1.1rem;
    }
    .blog-cards-header-{{ section.id }} {
      margin-bottom: 2rem;
    }
    .blog-card-meta-{{ section.id }},
    .blog-card-desc-{{ section.id }},
    .blog-card-popup-trigger-{{ section.id }} {
      opacity: 1;
      transform: translateY(0);
    }
    .blog-card-action-btn-{{ section.id }} {
      opacity: 1;
      transform: translateY(0);
    }
  }
{%- endstyle -%}

<style>
  .blog-card-popup-overlay-{{ section.id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 1000;
    display: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .blog-card-popup-overlay-{{ section.id }}.active {
    opacity: 1;
  }

  .blog-card-popup-{{ section.id }} {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.92);
    background: #ffffff;
    max-width: 800px;
    width: 92%;
    max-height: 90vh;
    overflow: hidden;
    border-radius: 28px;
    box-shadow: 0 30px 100px rgba(0, 0, 0, 0.3);
    z-index: 1001;
    display: none;
    opacity: 0;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blog-card-popup-{{ section.id }}.active {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .blog-card-popup-image-wrap-{{ section.id }} {
    position: relative;
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .blog-card-popup-image-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-card-popup-image-overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%);
  }

  .blog-card-popup-header-{{ section.id }} {
    padding: 1.75rem 2rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .blog-card-popup-title-{{ section.id }} {
    font-size: 1.5rem;
    font-weight: 900;
    color: #0f172a;
    margin: 0;
    line-height: 1.25;
    letter-spacing: -0.02em;
    flex: 1;
  }

  .blog-card-popup-close-{{ section.id }} {
    background: #f1f5f9;
    border: none;
    cursor: pointer;
    padding: 12px;
    border-radius: 50%;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-card-popup-close-{{ section.id }}:hover {
    background: #e2e8f0;
    transform: rotate(90deg) scale(1.05);
  }

  .blog-card-popup-close-icon-{{ section.id }} {
    width: 20px;
    height: 20px;
    stroke: #475569;
  }

  .blog-card-popup-content-{{ section.id }} {
    padding: 1.5rem 2rem 2rem;
    font-size: 1rem;
    color: #475569;
    line-height: 1.8;
    max-height: 45vh;
    overflow-y: auto;
  }

  .blog-card-popup-content-{{ section.id }}::-webkit-scrollbar {
    width: 6px;
  }

  .blog-card-popup-content-{{ section.id }}::-webkit-scrollbar-track {
    background: #f1f5f9;
    border-radius: 3px;
  }

  .blog-card-popup-content-{{ section.id }}::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 3px;
  }

  .blog-card-popup-content-{{ section.id }}::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }

  .blog-card-popup-content-{{ section.id }} p {
    margin: 0 0 1rem;
  }

  .blog-card-popup-content-{{ section.id }} p:last-child {
    margin-bottom: 0;
  }

  .blog-card-popup-footer-{{ section.id }} {
    padding: 1.25rem 2rem;
    background: #f8fafc;
    border-top: 1px solid #e2e8f0;
    display: flex;
    justify-content: flex-end;
    gap: 12px;
  }

  .blog-card-popup-btn-{{ section.id }} {
    padding: 12px 28px;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    font-family: inherit;
  }

  .blog-card-popup-btn-close-{{ section.id }} {
    background: linear-gradient(135deg, {{ section.settings.accent_color }}, {{ section.settings.accent_hover }});
    color: #ffffff;
    border: none;
    box-shadow: 0 4px 15px {{ section.settings.accent_color | color_modify: 'alpha', 0.3 }};
  }

  .blog-card-popup-btn-close-{{ section.id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px {{ section.settings.accent_color | color_modify: 'alpha', 0.4 }};
  }

  @media screen and (max-width: 749px) {
    .blog-card-popup-{{ section.id }} {
      width: 96%;
      max-height: 92vh;
      border-radius: 20px;
    }

    .blog-card-popup-image-wrap-{{ section.id }} {
      height: 180px;
    }

    .blog-card-popup-header-{{ section.id }} {
      padding: 1.25rem 1.25rem 1rem;
    }

    .blog-card-popup-title-{{ section.id }} {
      font-size: 1.2rem;
    }

    .blog-card-popup-content-{{ section.id }} {
      padding: 1rem 1.25rem 1.5rem;
      max-height: 50vh;
    }

    .blog-card-popup-footer-{{ section.id }} {
      padding: 1rem 1.25rem;
    }

    .blog-card-popup-btn-{{ section.id }} {
      padding: 10px 20px;
    }
  }
</style>

<div class="blog-cards-section-{{ section.id }}">
  <div class="blog-cards-container-{{ section.id }}">

    {%- if section.settings.title != blank or section.settings.subheading != blank -%}
      <div class="blog-cards-header-{{ section.id }}">
        <div class="blog-cards-badge-wrap-{{ section.id }}">
          <div class="blog-cards-badge-icon-{{ section.id }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
          </div>
          <span class="blog-cards-badge-text-{{ section.id }}">{{ section.settings.badge_text | default: 'Blog' }}</span>
        </div>
        {%- if section.settings.title != blank -%}
          <h2 class="blog-cards-heading-{{ section.id }}">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="blog-cards-subheading-{{ section.id }}">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="blog-cards-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="blog-card-{{ section.id }}" {{ block.shopify_attributes }}>

          <div class="blog-card-img-wrap-{{ section.id }}">
            {%- if block.settings.badge != blank -%}
              <span class="blog-card-badge-{{ section.id }}">{{ block.settings.badge }}</span>
            {%- endif -%}

            <div class="blog-card-actions-{{ section.id }}">
              <button type="button" class="blog-card-action-btn-{{ section.id }}" onclick="(function(btn){
                var popup = document.getElementById('blog-popup-{{ section.id }}-{{ block.id }}');
                var overlay = document.getElementById('blog-popup-overlay-{{ section.id }}-{{ block.id }}');
                popup.style.display = 'block';
                overlay.style.display = 'block';
                document.body.style.overflow = 'hidden';
                setTimeout(function() {
                  popup.classList.add('active');
                  overlay.classList.add('active');
                }, 10);
              })(this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
              </button>
              <button type="button" class="blog-card-action-btn-{{ section.id }}" onclick="(function(btn){
                var popup = document.getElementById('blog-popup-{{ section.id }}-{{ block.id }}');
                var overlay = document.getElementById('blog-popup-overlay-{{ section.id }}-{{ block.id }}');
                popup.style.display = 'block';
                overlay.style.display = 'block';
                document.body.style.overflow = 'hidden';
                setTimeout(function() {
                  popup.classList.add('active');
                  overlay.classList.add('active');
                }, 10);
              })(this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"></path>
                  <path d="M12 5v14"></path>
                </svg>
              </button>
            </div>

            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                        {{ block.settings.image | image_url: width: 600 }} 600w,
                        {{ block.settings.image | image_url: width: 800 }} 800w"
                sizes="(max-width: 749px) 100vw, (max-width: 1023px) 50vw, 33vw"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                class="blog-card-img-{{ section.id }}"
                loading="lazy"
                width="800"
                height="600"
              >
            {%- else -%}
              <div class="blog-card-placeholder-{{ section.id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {%- endif -%}

            <div class="blog-card-overlay-{{ section.id }}"></div>

            <div class="blog-card-content-{{ section.id }}">
              {%- if block.settings.title != blank -%}
                <div class="blog-card-title-wrap-{{ section.id }}">
                  <h3 class="blog-card-title-{{ section.id }}">{{ block.settings.title }}</h3>
                </div>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <div class="blog-card-meta-{{ section.id }}">
                  <span class="blog-card-meta-item-{{ section.id }}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                      <line x1="16" y1="2" x2="16" y2="6"></line>
                      <line x1="8" y1="2" x2="8" y2="6"></line>
                      <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    Latest
                  </span>
                  <span class="blog-card-meta-item-{{ section.id }}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    5 min read
                  </span>
                </div>
                <div class="blog-card-desc-{{ section.id }}">
                  {{ block.settings.description | strip_html | truncatewords: 15 }}
                </div>
              {%- endif -%}

              {%- if block.settings.dropdown_label != blank and block.settings.dropdown_content != blank -%}
                <div class="blog-card-popup-trigger-{{ section.id }}">
                  <button
                    type="button"
                    class="blog-card-popup-trigger-btn-{{ section.id }}"
                    aria-expanded="false"
                    aria-controls="blog-popup-{{ section.id }}-{{ block.id }}"
                    onclick="(function(btn){
                      var popup = document.getElementById('blog-popup-{{ section.id }}-{{ block.id }}');
                      var overlay = document.getElementById('blog-popup-overlay-{{ section.id }}-{{ block.id }}');
                      popup.style.display = 'block';
                      overlay.style.display = 'block';
                      document.body.style.overflow = 'hidden';
                      setTimeout(function() {
                        popup.classList.add('active');
                        overlay.classList.add('active');
                      }, 10);
                    })(this)"
                  >
                    <span>{{ block.settings.dropdown_label }}</span>
                    <svg class="blog-card-popup-icon-{{ section.id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                    </svg>
                  </button>
                </div>
              {%- endif -%}
            </div>
          </div>

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{%- for block in section.blocks -%}
  {%- if block.settings.dropdown_label != blank and block.settings.dropdown_content != blank -%}
    <div class="blog-card-popup-overlay-{{ section.id }}" id="blog-popup-overlay-{{ section.id }}-{{ block.id }}" onclick="(function(overlay){
      var popup = document.getElementById('blog-popup-{{ section.id }}-{{ block.id }}');
      popup.classList.remove('active');
      overlay.classList.remove('active');
      setTimeout(function() {
        popup.style.display = 'none';
        overlay.style.display = 'none';
      }, 400);
      document.body.style.overflow = 'auto';
    })(this)">
    </div>

    <div class="blog-card-popup-{{ section.id }}" id="blog-popup-{{ section.id }}-{{ block.id }}">
      {%- if block.settings.image != blank -%}
        <div class="blog-card-popup-image-wrap-{{ section.id }}">
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.title | escape }}"
            class="blog-card-popup-image-{{ section.id }}"
          >
          <div class="blog-card-popup-image-overlay-{{ section.id }}"></div>
        </div>
      {%- endif -%}
      <div class="blog-card-popup-header-{{ section.id }}">
        <h3 class="blog-card-popup-title-{{ section.id }}">{{ block.settings.title }}</h3>
        <button
          type="button"
          class="blog-card-popup-close-{{ section.id }}"
          onclick="(function(btn){
            var popup = document.getElementById('blog-popup-{{ section.id }}-{{ block.id }}');
            var overlay = document.getElementById('blog-popup-overlay-{{ section.id }}-{{ block.id }}');
            popup.classList.remove('active');
            overlay.classList.remove('active');
            setTimeout(function() {
              popup.style.display = 'none';
              overlay.style.display = 'none';
            }, 400);
            document.body.style.overflow = 'auto';
          })(this)"
        >
          <svg class="blog-card-popup-close-icon-{{ section.id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="blog-card-popup-content-{{ section.id }}">
        {{ block.settings.dropdown_content }}
      </div>
      <div class="blog-card-popup-footer-{{ section.id }}">
        <button
          type="button"
          class="blog-card-popup-btn-{{ section.id }} blog-card-popup-btn-close-{{ section.id }}"
          onclick="(function(btn){
            var popup = document.getElementById('blog-popup-{{ section.id }}-{{ block.id }}');
            var overlay = document.getElementById('blog-popup-overlay-{{ section.id }}-{{ block.id }}');
            popup.classList.remove('active');
            overlay.classList.remove('active');
            setTimeout(function() {
              popup.style.display = 'none';
              overlay.style.display = 'none';
            }, 400);
            document.body.style.overflow = 'auto';
          })(this)"
        >
          Close
        </button>
      </div>
    </div>
  {%- endif -%}
{%- endfor -%}

<script>
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var overlays = document.querySelectorAll('[id^="blog-popup-overlay-{{ section.id }}"]');
      var popups = document.querySelectorAll('[id^="blog-popup-{{ section.id }}-"]');
      overlays.forEach(function(overlay) {
        overlay.classList.remove('active');
        setTimeout(function() { overlay.style.display = 'none'; }, 400);
      });
      popups.forEach(function(popup) {
        popup.classList.remove('active');
        setTimeout(function() { popup.style.display = 'none'; }, 400);
      });
      document.body.style.overflow = 'auto';
    }
  });
</script>

