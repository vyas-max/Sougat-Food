{%- style -%}
  .premium-recipe-list-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    overflow: hidden;
    font-family: inherit;
  }
  
  .premium-recipe-container-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  .premium-recipe-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .premium-recipe-heading-{{ section.id }} {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #111;
    margin-bottom: 16px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  
  .premium-recipe-subheading-{{ section.id }} {
    font-size: 1.125rem;
    color: #555;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .premium-recipe-item-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 40px;
    margin-bottom: 80px;
    align-items: center;
  }

  .premium-recipe-item-{{ section.id }}:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 990px) {
    .premium-recipe-item-{{ section.id }} {
      flex-direction: row;
      gap: 80px;
      margin-bottom: 120px;
    }
    
    .premium-recipe-item-{{ section.id }}:nth-child(even) {
      flex-direction: row-reverse;
    }
  }

  .premium-recipe-image-col-{{ section.id }} {
    width: 100%;
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  }

  @media screen and (min-width: 990px) {
    .premium-recipe-image-col-{{ section.id }} {
      width: 50%;
    }
  }

  .premium-recipe-image-wrapper-{{ section.id }} {
    position: relative;
    width: 100%;
    padding-bottom: 110%; /* Makes image slightly taller than square */
    background: #f4f4f4;
  }

  .premium-recipe-image-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .premium-recipe-item-{{ section.id }}:hover .premium-recipe-image-{{ section.id }} {
    transform: scale(1.05);
  }

  .premium-recipe-placeholder-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    fill: #ccc;
    background-color: #f8f8f8;
  }

  .premium-recipe-content-col-{{ section.id }} {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media screen and (min-width: 990px) {
    .premium-recipe-content-col-{{ section.id }} {
      width: 50%;
    }
  }

  .premium-recipe-category-{{ section.id }} {
    display: inline-block;
    padding: 8px 20px;
    background: #111;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    border-radius: 100px;
    margin-bottom: 24px;
    width: fit-content;
  }

  .premium-recipe-title-{{ section.id }} {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 800;
    color: #111;
    margin: 0 0 25px 0;
    line-height: 1.1;
    letter-spacing: -1px;
  }

  .premium-recipe-meta-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 20px 30px;
    margin-bottom: 30px;
    padding-bottom: 30px;
    border-bottom: 1px solid #eaeaea;
  }

  .premium-meta-block-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .premium-meta-icon-{{ section.id }} {
    width: 24px;
    height: 24px;
    color: #111;
    opacity: 0.8;
  }

  .premium-meta-text-{{ section.id }} {
    display: flex;
    flex-direction: column;
  }
  
  .premium-meta-label-{{ section.id }} {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #888;
    font-weight: 700;
  }

  .premium-meta-value-{{ section.id }} {
    font-size: 1.05rem;
    color: #111;
    font-weight: 700;
  }

  .premium-recipe-desc-{{ section.id }} {
    font-size: 1.15rem;
    color: #555;
    line-height: 1.7;
    margin-bottom: 40px;
  }
  
  .premium-recipe-desc-{{ section.id }} p {
    margin: 0 0 16px 0;
  }
  .premium-recipe-desc-{{ section.id }} p:last-child {
    margin-bottom: 0;
  }

  .premium-recipe-action-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 40px;
    background-color: {{ section.settings.button_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: 100px;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    width: fit-content;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }

  .premium-recipe-action-{{ section.id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 25px rgba(0,0,0,0.15);
    background-color: #333;
    color: #fff;
  }

  .premium-recipe-action-icon-{{ section.id }} {
    margin-left: 10px;
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .premium-recipe-action-{{ section.id }}:hover .premium-recipe-action-icon-{{ section.id }} {
    transform: translateX(5px);
  }
{%- endstyle -%}

<div class="premium-recipe-list-{{ section.id }}">
  <div class="premium-recipe-container-{{ section.id }}">
    
    <div class="premium-recipe-header-{{ section.id }}">
      {%- if section.settings.title != blank -%}
        <h2 class="premium-recipe-heading-{{ section.id }}">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <div class="premium-recipe-subheading-{{ section.id }}">{{ section.settings.subtitle }}</div>
      {%- endif -%}
    </div>

    <div class="premium-recipe-items-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="premium-recipe-item-{{ section.id }}" {{ block.shopify_attributes }}>
          
          <div class="premium-recipe-image-col-{{ section.id }}">
            <div class="premium-recipe-image-wrapper-{{ section.id }}">
              {%- if block.settings.photo != blank -%}
                <img 
                  src="{{ block.settings.photo | image_url: width: 1200 }}" 
                  alt="{{ block.settings.photo.alt | escape }}" 
                  class="premium-recipe-image-{{ section.id }}"
                  loading="lazy"
                  width="1200"
                  height="1200"
                >
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'premium-recipe-placeholder-' | append: section.id }}
              {%- endif -%}
            </div>
          </div>

          <div class="premium-recipe-content-col-{{ section.id }}">
            {%- if block.settings.category != blank -%}
              <div class="premium-recipe-category-{{ section.id }}">{{ block.settings.category }}</div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="premium-recipe-title-{{ section.id }}">{{ block.settings.title }}</h3>
            {%- endif -%}

            <div class="premium-recipe-meta-{{ section.id }}">
              {%- if block.settings.prep_time != blank -%}
                <div class="premium-meta-block-{{ section.id }}">
                  <svg class="premium-meta-icon-{{ section.id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <div class="premium-meta-text-{{ section.id }}">
                    <span class="premium-meta-label-{{ section.id }}">Prep</span>
                    <span class="premium-meta-value-{{ section.id }}">{{ block.settings.prep_time }}</span>
                  </div>
                </div>
              {%- endif -%}

              {%- if block.settings.cook_time != blank -%}
                <div class="premium-meta-block-{{ section.id }}">
                  <svg class="premium-meta-icon-{{ section.id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"></path></svg>
                  <div class="premium-meta-text-{{ section.id }}">
                    <span class="premium-meta-label-{{ section.id }}">Cook</span>
                    <span class="premium-meta-value-{{ section.id }}">{{ block.settings.cook_time }}</span>
                  </div>
                </div>
              {%- endif -%}

              {%- if block.settings.servings != blank -%}
                <div class="premium-meta-block-{{ section.id }}">
                  <svg class="premium-meta-icon-{{ section.id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                  <div class="premium-meta-text-{{ section.id }}">
                    <span class="premium-meta-label-{{ section.id }}">Yield</span>
                    <span class="premium-meta-value-{{ section.id }}">{{ block.settings.servings }}</span>
                  </div>
                </div>
              {%- endif -%}

              {%- if block.settings.difficulty != blank -%}
                <div class="premium-meta-block-{{ section.id }}">
                  <svg class="premium-meta-icon-{{ section.id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                  <div class="premium-meta-text-{{ section.id }}">
                    <span class="premium-meta-label-{{ section.id }}">Level</span>
                    <span class="premium-meta-value-{{ section.id }}">{{ block.settings.difficulty }}</span>
                  </div>
                </div>
              {%- endif -%}
            </div>

            {%- if block.settings.text != blank -%}
              <div class="premium-recipe-desc-{{ section.id }}">
                {{ block.settings.text }}
              </div>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link | default: '#' }}" class="premium-recipe-action-{{ section.id }}">
                {{ block.settings.button_label }}
                <svg class="premium-recipe-action-icon-{{ section.id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Premium Recipe List",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Featured Recipes"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Discover our handpicked selection of gourmet recipes."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Background Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Max Width (px)",
      "default": 1300
    }
  ],
  "blocks": [
    {
      "type": "recipe_block",
      "name": "Premium Recipe",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Recipe Photo (High Res)"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category Label",
          "default": "Main Course"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Recipe Title",
          "default": "Truffle Mushroom Risotto"
        },
        {
          "type": "text",
          "id": "prep_time",
          "label": "Prep Time",
          "default": "15 mins"
        },
        {
          "type": "text",
          "id": "cook_time",
          "label": "Cook Time",
          "default": "30 mins"
        },
        {
          "type": "text",
          "id": "servings",
          "label": "Yield/Servings",
          "default": "4 portions"
        },
        {
          "type": "text",
          "id": "difficulty",
          "label": "Difficulty",
          "default": "Intermediate"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Recipe Story / Description",
          "default": "<p>Experience the ultimate comfort food with this rich, creamy truffle mushroom risotto. It is slowly simmered to perfection, releasing mouth-watering aromas.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Get the Recipe"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Recipe List",
      "category": "Blog",
      "blocks": [
        {
          "type": "recipe_block"
        },
        {
          "type": "recipe_block"
        }
      ]
    }
  ]
}
{% endschema %}
