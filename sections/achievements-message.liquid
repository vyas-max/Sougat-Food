{%- liquid
  assign bg_color = section.settings.background_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
-%}

{%- style -%}
  .achievements-msg-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ bg_color }};
  }

  .achievements-msg-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .achievements-msg-{{ section.id }} .achievements-wrap {
    text-align: center;
    margin-bottom: 3rem;
  }

  .achievements-msg-{{ section.id }} .main-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: {{ heading_color }};
    margin: 0 0 2rem;
    font-weight: 700;
  }

  .achievements-msg-{{ section.id }} .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media screen and (min-width: 768px) {
    .achievements-msg-{{ section.id }} .stats-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }

  .achievements-msg-{{ section.id }} .stat-card {
    background: #fff;
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid {{ accent_color | color_modify: 'alpha', 0.3 }};
    text-align: center;
  }

  .achievements-msg-{{ section.id }} .stat-number {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: {{ accent_color }};
    margin: 0 0 0.5rem;
    line-height: 1;
  }

  .achievements-msg-{{ section.id }} .stat-label {
    font-size: 0.9rem;
    font-weight: 500;
    color: {{ heading_color }};
    margin: 0;
  }

  .achievements-msg-{{ section.id }} .messages-wrap {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .achievements-msg-{{ section.id }} .message-box {
    background: #fff;
    border: 1px solid {{ accent_color | color_modify: 'alpha', 0.3 }};
    border-radius: 8px;
    padding: 2rem;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .achievements-msg-{{ section.id }} .message-title {
    font-size: 1.25rem;
    color: {{ heading_color }};
    margin: 0 0 1rem;
    font-weight: 700;
  }

  .achievements-msg-{{ section.id }} .message-text {
    font-size: 1rem;
    line-height: 1.7;
    color: #444;
    margin: 0 0 1.5rem;
  }

  .achievements-msg-{{ section.id }} .message-text p {
    margin: 0 0 1rem;
  }

  .achievements-msg-{{ section.id }} .message-text p:last-child {
    margin-bottom: 0;
  }

  .achievements-msg-{{ section.id }} .signature-wrap {
    border-top: 1px solid {{ accent_color | color_modify: 'alpha', 0.2 }};
    padding-top: 1rem;
  }

  .achievements-msg-{{ section.id }} .signature-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: {{ accent_color }};
    margin: 0 0 0.25rem;
  }

  .achievements-msg-{{ section.id }} .signature-title {
    font-size: 0.9rem;
    color: {{ heading_color }};
    margin: 0;
  }

  @media screen and (max-width: 767px) {
    .achievements-msg-{{ section.id }} .message-box {
      padding: 1.5rem;
    }
  }
{%- endstyle -%}

<section class="achievements-msg-{{ section.id }}">
  <div class="container">
    <div class="achievements-wrap">
      <h2 class="main-title">{{ section.settings.achievements_title }}</h2>
      <div class="stats-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="stat-card" {{ block.shopify_attributes }}>
              <h3 class="stat-number">{{ block.settings.number }}{{ block.settings.suffix }}</h3>
              <p class="stat-label">{{ block.settings.label }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="messages-wrap">
      {%- if section.settings.chairman_message != blank -%}
        <div class="message-box">
          <h2 class="message-title">{{ section.settings.chairman_title }}</h2>
          <div class="message-text">{{ section.settings.chairman_message }}</div>
          <div class="signature-wrap">
            <p class="signature-name">{{ section.settings.chairman_name }}</p>
            <p class="signature-title">{{ section.settings.chairman_designation }}</p>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.director_message != blank -%}
        <div class="message-box">
          <h2 class="message-title">{{ section.settings.director_title }}</h2>
          <div class="message-text">{{ section.settings.director_message }}</div>
          <div class="signature-wrap">
            <p class="signature-name">{{ section.settings.director_name }}</p>
            <p class="signature-title">{{ section.settings.director_designation }}</p>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Achievements & Message",
  "tag": "section",
  "class": "section-achievements-msg",
  "settings": [
    {
      "type": "text",
      "id": "achievements_title",
      "label": "Achievements Title",
      "default": "Our Achievements"
    },
    {
      "type": "header",
      "content": "Chairman's Message"
    },
    {
      "type": "text",
      "id": "chairman_title",
      "label": "Chairman Title",
      "default": "Chairman's Message"
    },
    {
      "type": "richtext",
      "id": "chairman_message",
      "label": "Chairman Message",
      "default": "<p>Our journey since 1962 has been guided by integrity, quality, and a deep commitment to our customers. We believe in building lasting relationships through trust and excellence.</p>"
    },
    {
      "type": "text",
      "id": "chairman_name",
      "label": "Chairman Name",
      "default": "John Doe"
    },
    {
      "type": "text",
      "id": "chairman_designation",
      "label": "Chairman Designation",
      "default": "Chairman, Sougat Foods"
    },
    {
      "type": "header",
      "content": "Director's Message"
    },
    {
      "type": "text",
      "id": "director_title",
      "label": "Director Title",
      "default": "Director's Message"
    },
    {
      "type": "richtext",
      "id": "director_message",
      "label": "Director Message",
      "default": "<p>At Sougat Foods, our commitment goes beyond business. We are dedicated to providing the highest quality products while maintaining sustainable practices.</p>"
    },
    {
      "type": "text",
      "id": "director_name",
      "label": "Director Name",
      "default": "Jane Doe"
    },
    {
      "type": "text",
      "id": "director_designation",
      "label": "Director Designation",
      "default": "Director, Sougat Foods"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F9F8F3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#10A560"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Achievement",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "25"
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "Suffix (e.g. K, +)",
          "default": "K"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Happy Clients"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Achievements & Message",
      "blocks": [
        { "type": "stat", "settings": { "number": "25", "suffix": "K", "label": "Happy Clients" } },
        { "type": "stat", "settings": { "number": "15", "suffix": "+", "label": "Export Countries" } },
        { "type": "stat", "settings": { "number": "5", "suffix": " Ton", "label": "Manufacturing" } },
        { "type": "stat", "settings": { "number": "50", "suffix": "+", "label": "Products" } }
      ]
    }
  ]
}
{% endschema %}
