{%- style -%}
  .main-page-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: '#F9F7F2' }};
    padding-top: {{ section.settings.padding-block-start }}px;
    padding-bottom: {{ section.settings.padding-block-end }}px;
  }

  .ethos-header {
    text-align: center;
    max-width: 1200px;
    margin: 0 auto 40px;
    padding: 0 15px;
  }

  @media screen and (max-width: 767px) {
    .ethos-header {
      margin-bottom: 30px;
      padding-top: 20px;
    }
  }

  .ethos-label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #888;
    margin-bottom: 25px;
    font-weight: 600;
  }

  .ethos-title {
    font-family: serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.1;
    margin-bottom: 30px;
    letter-spacing: -0.01em;
  }

  .ethos-description {
    font-size: 1.15rem;
    line-height: 1.7;
    color: #555;
    max-width: 720px;
    margin: 0 auto;
    font-weight: 400;
  }

  .main-page-blocks {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  @media screen and (max-width: 749px) {
    .ethos-title {
      font-size: 2rem;
    }
    .ethos-description {
      font-size: 1rem;
    }
  }
{%- endstyle -%}

<div class="main-page-section-{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="ethos-header">
    {%- if section.settings.top_label != blank -%}
      <span class="ethos-label">{{ section.settings.top_label }}</span>
    {%- endif -%}
    
    {%- if section.settings.title != blank -%}
      <h1 class="ethos-title">{{ section.settings.title }}</h1>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="ethos-description">
        {{ section.settings.description }}
      </div>
    {%- endif -%}
  </div>

  <div class="main-page-blocks">
    {% content_for 'blocks' %}
  </div>
</div>

{% schema %}
{
  "name": "Main Page (Ethos Style)",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Ethos Header Content"
    },
    {
      "type": "text",
      "id": "top_label",
      "label": "Top Small Label",
      "default": "THE SOUGAT ETHOS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "Preserving Nature's Purity"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "In a world of synthetic additives and over-processing, we choose the path of quiet integrity. We believe the most powerful ingredients are those left untouched by modern shortcuts, captured at their peak through the art of artisanal freeze-drying."
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F7F2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ]
}
{% endschema %}