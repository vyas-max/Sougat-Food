{% stylesheet %}
  .main-page-section {
    position: relative;
  }

  .main-page-wrapper {
    max-width: var(--page-width);
    margin: 0 auto;
    padding-left: var(--page-margin);
    padding-right: var(--page-margin);
  }

  .main-page-header {
    text-align: {{ section.settings.text_alignment }};
    padding: var(--padding-block-start) 0 {{ section.settings.header_bottom_spacing }}px;
  }

  .main-page-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: rgb(var(--color-foreground-rgb));
    margin: 0 0 0.5rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .main-page-subtitle {
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: rgb(var(--color-foreground-rgb));
    opacity: 0.75;
    margin: 0;
    max-width: {{ section.settings.subtitle_max_width }}px;
    line-height: 1.6;
    {% if section.settings.text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif section.settings.text_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  .main-page-content {
    position: relative;
  }

  .main-page-content > * + * {
    margin-top: {{ section.settings.content_gap }}px;
  }

  @media screen and (max-width: 749px) {
    .main-page-header {
      padding: calc(var(--padding-block-start) / 2) 0 {{ section.settings.header_bottom_spacing | divided_by: 2 }}px;
    }

    .main-page-title {
      font-size: 1.75rem;
    }

    .main-page-subtitle {
      font-size: 1rem;
    }
  }
{% endstylesheet %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section main-page-section color-{{ section.settings.color_scheme }}">
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--column
      main-page-wrapper
      section-content-wrapper
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {% render 'spacing-style', settings: section.settings %}
    "
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% schema %}
{
  "name": "t:names.page",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "subtitle_max_width",
      "label": "Subtitle Max Width",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        }
      ],
      "default": "column",
      "visible_if": "{{ section.settings.gap < 0 }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Content Block Gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "header_bottom_spacing",
      "label": "Bottom Spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ]
}
{% endschema %}