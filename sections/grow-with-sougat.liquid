{% schema %}
{
  "name": "Grow With Sougat",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Grow With Sougat"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "First Paragraph",
      "default": "At Sougat Foods, we believe strong partnerships create sustainable success. With advanced freeze-drying technology, internationally certified manufacturing, and a growing product portfolio, we invite businesses to collaborate and scale with us across domestic and global markets."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Second Paragraph",
      "default": "Whether you are a distributor, retailer, private label brand, or institutional buyer — we offer flexible and reliable partnership models tailored to your growth."
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show Bottom Divider Line",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Grow With Sougat"
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body-family, sans-serif);
  }

  {% if request.design_mode %}
  /* Force items to be visible in Shopify Editor */
  .section-{{ section.id }} .gws-fade-up {
    opacity: 1 !important;
    transform: none !important;
  }
  {% endif %}

  .gws-container {
    max-width: 900px; /* Kept slightly constrained for readability */
    margin: 0 auto;
    padding: 0 20px;
  }

  .gws-title {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: #111827;
    position: relative;
    display: inline-block;
  }
  
  /* Attractive gradient underline for title */
  .gws-title::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 3px;
    bottom: -6px;
    left: 0;
    background: linear-gradient(90deg, #f59e0b, #10b981);
    border-radius: 2px;
  }

  .gws-paragraph {
    font-size: 1.125rem;
    line-height: 1.8;
    color: #4b5563;
    margin-bottom: 2rem;
  }

  .gws-paragraph:last-of-type {
    margin-bottom: 3rem; /* Extra space before divider */
  }

  .gws-divider {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 0;
    width: 100%;
  }

  @media (max-width: 768px) {
    .gws-title {
      font-size: 1.875rem;
    }
    
    .gws-paragraph {
      font-size: 1.05rem;
    }
  }

  /* Reveal Animations */
  .gws-fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
  
  .gws-fade-up.gws-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<div class="section-{{ section.id }}">
  <div class="gws-container">
    {% if section.settings.title != blank %}
      <h2 class="gws-title gws-fade-up">{{ section.settings.title }}</h2>
    {% endif %}

    {% if section.settings.paragraph_1 != blank %}
      <p class="gws-paragraph gws-fade-up" style="transition-delay: 150ms;">
        {{ section.settings.paragraph_1 }}
      </p>
    {% endif %}

    {% if section.settings.paragraph_2 != blank %}
      <p class="gws-paragraph gws-fade-up" style="transition-delay: 300ms;">
        {{ section.settings.paragraph_2 }}
      </p>
    {% endif %}

    {% if section.settings.show_divider %}
      <hr class="gws-divider gws-fade-up" style="transition-delay: 450ms;">
    {% endif %}
  </div>
</div>

<script>
  (function() {
    function initGWS() {
      const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
      };

      const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
              if (entry.isIntersecting) {
                  entry.target.classList.add('gws-visible');
                  observer.unobserve(entry.target);
              }
          });
      }, observerOptions);

      const fadeElements = document.querySelectorAll('.section-{{ section.id }} .gws-fade-up');
      fadeElements.forEach(el => observer.observe(el));
    }

    initGWS();

    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initGWS();
      }
    });
  })();
</script>
