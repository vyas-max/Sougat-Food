{%- liquid
  assign section_background = section.settings.background_primary | default: '#CEDFE7'
  assign section_accent = section.settings.background_secondary | default: '#EAF0F4'
  assign content_background = section.settings.content_background | default: '#E1EFF5'
  assign heading_color = section.settings.heading_color | default: '#111111'
  assign body_color = section.settings.body_color | default: '#333333'
  assign button_background = section.settings.button_background | default: '#1D2C34'
  assign button_text = section.settings.button_text | default: '#FFFFFF'
  assign button_background_hover = section.settings.button_background_hover | default: '#111111'
  assign button_text_hover = section.settings.button_text_hover | default: '#FFFFFF'
-%}

<style>
  /* Benefits highlight section */
  .benefits-section--{{ section.id }} {
    position: relative;
    background: linear-gradient(to bottom, {{ section_background }} 35%, {{ section_accent }} 35%); /* Kept vertical split based on preference */
    color: {{ body_color }};
    overflow: hidden;
    
    --benefits-heading-color: {{ heading_color }};
    --benefits-body-color: {{ body_color }};
    --benefits-button-bg: {{ button_background }};
    --benefits-button-text: {{ button_text }};
    --benefits-button-bg-hover: {{ button_background_hover }};
    --benefits-button-text-hover: {{ button_text_hover }};
  }

  .benefits-section__inner {
    position: relative;
    z-index: 1;
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  @media screen and (min-width: 1024px) {
    .benefits-section__inner {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0px;
      align-items: stretch;
      min-height: 600px;
    }
  }

  .benefits-section__media {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 400px; /* Ensure visibility on mobile */
  }

  .benefits-section__media-frame {
    position: relative;
    width: 100%;
    max-width: 560px;
    padding: 54px 0 54px 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .benefits-section__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    border-radius: 24px;
  }

  .benefits-section__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
    min-height: 300px;
    border-radius: 16px;
  }

  .benefits-section__content {
    padding: 54px 20px;
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 3vw, 36px);
  }

  .benefits-section__heading {
    margin: 0;
    color: var(--benefits-heading-color);
    font-size: clamp(24px, 4vw, 46px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    font-weight: 400 !important;
    text-align: center;
    hyphens: auto;
    margin-bottom: 2rem; /* Spacer for background split alignment */
  }

  @media screen and (min-width: 1024px) {
      .benefits-section__heading {
           margin-bottom: 4rem; 
      }
  }

  .benefits-section__list {
    display: flex;
    flex-direction: column;
  }

  .benefits-section__item {
    padding-block: clamp(20px, 2.5vw, 28px);
    border-bottom: 1px solid rgba(17, 28, 38, 0.12);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  
  @media screen and (min-width: 768px) {
    .benefits-section__item {
      flex-direction: row;
      align-items: center;
      gap: 40px; /* Reduced from 80px to fit safer in split screens */
    }
  }
  
  @media screen and (min-width: 1200px) {
    .benefits-section__item {
      gap: 80px; /* Original requested gap for large screens */
    }
  }

  .benefits-section__item:first-child {
    padding-top: 0;
  }

  .benefits-section__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .benefits-section__item-header {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0; /* Prevent header from shrinking */
    min-width: 200px; /* Ensure consistency */
  }

  .benefits-section__icon {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .benefits-section__item-title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--benefits-heading-color);
    white-space: normal;
    text-transform: uppercase;
  }

  .benefits-section__item-text {
    margin: 0;
    color: var(--benefits-body-color);
    line-height: 1.6;
    font-size: 18px;
    text-align: left;
    hyphens: auto;
  }

  @media screen and (min-width: 768px) and (max-width: 1199px) {
    .benefits-section--{{ section.id }} {
      padding-block: clamp(48px, 8vw, 140px);
      padding-inline: clamp(16px, 6vw, 72px);
      background: linear-gradient(135deg, {{ section_background }} 45%, {{ section_accent }} 45%);
    }

    .benefits-section__inner {
      padding-inline: clamp(12px, 3vw, 36px);
      gap: clamp(32px, 6vw, 72px);
      display: grid;
      grid-template-columns: minmax(0, 1fr);
    }

    .benefits-section__content {
      padding: clamp(36px, 5vw, 54px) clamp(24px, 5vw, 48px);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      border: none;
    }

    .benefits-section__media {
      min-height: 360px;
    }

    .benefits-section__media-frame {
      max-width: 720px;
      padding: clamp(16px, 4vw, 32px) 0;
    }

    .benefits-section__item {
      border: none;
      border-bottom: 1px solid rgba(17, 28, 38, 0.18);
      border-radius: 0;
      padding: clamp(20px, 3vw, 28px) 0;
      align-items: flex-start;
      gap: clamp(16px, 4vw, 32px);
    }

    .benefits-section__item-header {
      min-width: auto;
    }
  }

  .benefits-section__cta {
    margin-top: clamp(24px, 4vw, 40px);
  }

  .benefits-section__button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 30px;
    border-radius: 999px;
    background-color: var(--benefits-button-bg);
    color: var(--benefits-button-text);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.3s ease, background-color 0.3s ease, color 0.3s ease;
  }

  .benefits-section__button:hover {
    background-color: var(--benefits-button-bg-hover);
    color: var(--benefits-button-text-hover);
    transform: translateY(-2px);
  }

  .benefits-section__button-arrow svg {
    display: block;
    transition: transform 0.3s ease;
  }
</style>

<section
  class="benefits-section benefits-section--{{ section.id }}"
  style="
    --benefits-bg-primary: {{ section_background }};
    --benefits-bg-secondary: {{ section_accent }};
    --benefits-content-bg: {{ content_background }};
    --benefits-heading-color: {{ heading_color }};
    --benefits-body-color: {{ body_color }};
    --benefits-button-bg: {{ button_background }};
    --benefits-button-text: {{ button_text }};
    --benefits-button-bg-hover: {{ button_background_hover }};
    --benefits-button-text-hover: {{ button_text_hover }};
  "
>
  <div class="benefits-section__inner">
    <div class="benefits-section__media">
      <div class="benefits-section__media-frame">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag:
            loading: 'lazy',
            class: 'benefits-section__image',
            widths: '375, 550, 750, 900, 1200',
            sizes: '(max-width: 768px) 100vw, 50vw',
            alt: section.settings.image.alt | default: section.settings.heading
          }}
        {%- else -%}
          <div class="benefits-section__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="benefits-section__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="benefits-section__heading">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="benefits-section__list">
          {%- for block in section.blocks -%}
            <div class="benefits-section__item" {{ block.shopify_attributes }}>
              <div class="benefits-section__item-header">
                {%- if block.settings.icon != blank -%}
                  {{ block.settings.icon | image_url: width: 80 | image_tag:
                    loading: 'lazy',
                    class: 'benefits-section__icon',
                    widths: '40, 60, 80',
                    alt: block.settings.title | default: 'Benefit icon'
                  }}
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h5 class="benefits-section__item-title">
                    {{ block.settings.title }}
                  </h5>
                {%- endif -%}
              </div>

              {%- if block.settings.text != blank -%}
                <p class="benefits-section__item-text">
                  {{ block.settings.text }}
                </p>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <div class="benefits-section__cta">
          <a
            href="{{ section.settings.button_link }}"
            class="benefits-section__button"
          >
            <span class="benefits-section__button-text">
              {{ section.settings.button_label }}
            </span>
            <span class="benefits-section__button-arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12H19M12 5L19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits highlight",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our products are crafted to suit all skin types & textures."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "color",
      "id": "background_primary",
      "label": "Primary background",
      "default": "#CEDFE7"
    },
    {
      "type": "color",
      "id": "background_secondary",
      "label": "Secondary background",
      "default": "#F5FAFD"
    },
    {
      "type": "color",
      "id": "content_background",
      "label": "Content panel background",
      "default": "#E1EFF5"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#1D2C34"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_background_hover",
      "label": "Button background (hover)",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_text_hover",
      "label": "Button text (hover)",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Describe the value your product delivers."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Benefits highlight",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Unmatched Quality",
            "text": "Our products are crafted with the finest ingredients to deliver long-lasting perfection."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Beauty Solutions",
            "text": "We bring the latest beauty trends and innovations to your fingertips."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "For Every Skin Type",
            "text": "A diverse range of shades and formulas suitable for every skin tone and type."
          }
        }
      ]
    }
  ]
}
{% endschema %}
