{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign section_bg = section.settings.bg_color
-%}

{%- style -%}
  .infra-tech-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    color: #fff;
  }

  @media screen and (max-width: 767px) {
    .infra-tech-{{ section.id }} {
      padding-top: 30px;
      padding-bottom: 30px;
    }
  }

  .infra-tech-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .infra-tech-{{ section.id }} .header-wrap {
    text-align: center;
    margin-bottom: 3rem;
  }

  @media screen and (max-width: 767px) {
    .infra-tech-{{ section.id }} .header-wrap {
      margin-bottom: 1.5rem;
    }
  }

  .infra-tech-{{ section.id }} .main-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: {{ accent_color }};
    margin: 0 0 1rem;
    font-weight: 700;
  }

  .infra-tech-{{ section.id }} .description {
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.7;
    margin: 0;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .infra-tech-{{ section.id }} .description p {
    margin: 0;
  }

  .infra-tech-{{ section.id }} .offer-box {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    padding: 2rem;
  }

  .infra-tech-{{ section.id }} .offer-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: {{ accent_color }};
    margin: 0 0 1.5rem;
  }

  .infra-tech-{{ section.id }} .offer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media screen and (min-width: 640px) {
    .infra-tech-{{ section.id }} .offer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .infra-tech-{{ section.id }} .offer-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .infra-tech-{{ section.id }} .offer-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
  }

  .infra-tech-{{ section.id }} .check-icon {
    width: 20px;
    height: 20px;
    background: {{ accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .infra-tech-{{ section.id }} .check-icon svg {
    width: 12px;
    height: 12px;
    color: {{ section_bg }};
  }

  .infra-tech-{{ section.id }} .item-text {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 767px) {
    .infra-tech-{{ section.id }} .offer-box {
      padding: 1.5rem;
    }
  }
{%- endstyle -%}

<section class="infra-tech-{{ section.id }}">
  <div class="container">
    <div class="header-wrap">
      <h2 class="main-title">{{ section.settings.title }}</h2>
      {%- if section.settings.description != blank -%}
        <div class="description">
          {{ section.settings.description }}
        </div>
      {%- endif -%}
    </div>

    <div class="offer-box">
      <h3 class="offer-title">{{ section.settings.offer_title }}</h3>
      <div class="offer-grid">
        {%- for block in section.blocks -%}
          <div class="offer-item" {{ block.shopify_attributes }}>
            <div class="check-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <p class="item-text">{{ block.settings.title | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Infrastructure & Tech",
  "tag": "section",
  "class": "section-infra-tech",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Infrastructure & Technology"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our modern processing facility is equipped with advanced machinery and strict quality control systems to ensure consistency and excellence.</p>"
    },
    {
      "type": "text",
      "id": "offer_title",
      "label": "Offer Heading",
      "default": "We Offer"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#10A560"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "offering",
      "name": "Offering Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Offering Name",
          "default": "Private Label Manufacturing"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Infrastructure & Tech",
      "blocks": [
        { "type": "offering", "settings": { "title": "Private Label Manufacturing" } },
        { "type": "offering", "settings": { "title": "Contract Manufacturing" } },
        { "type": "offering", "settings": { "title": "Customized Packaging Solutions" } },
        { "type": "offering", "settings": { "title": "Bulk & Retail Packing Options" } },
        { "type": "offering", "settings": { "title": "Export Documentation Support" } }
      ]
    }
  ]
}
{% endschema %}
