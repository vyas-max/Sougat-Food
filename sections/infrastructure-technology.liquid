{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign card_bg = section.settings.card_bg
  assign section_bg = section.settings.bg_color
-%}

{%- style -%}
  .infra-tech-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    overflow: hidden;
    position: relative;
    font-display: swap;
  }

  /* Decorative high-tech soft glow */
  .infra-tech-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: -15%;
    left: -10%;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, {{ accent_color | color_modify: 'alpha', 0.06 }} 0%, transparent 70%);
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }

  .infra-tech-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 2;
  }

  /* ── Animations ── */
  @keyframes fadeUpAnim {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(-20px); }
    to { opacity: 1; transform: translateX(0); }
  }
  .infra-tech-{{ section.id }} .anim-fade {
    animation: fadeUpAnim 0.8s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
    opacity: 0;
  }
  .infra-tech-{{ section.id }} .anim-slide {
    animation: slideInRight 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    opacity: 0;
  }
  .infra-tech-{{ section.id }} .d-1 { animation-delay: 0.1s; }
  .infra-tech-{{ section.id }} .d-2 { animation-delay: 0.2s; }
  .infra-tech-{{ section.id }} .d-3 { animation-delay: 0.3s; }
  .infra-tech-{{ section.id }} .d-4 { animation-delay: 0.4s; }

  /* ── Header Styling ── */
  .infra-tech-{{ section.id }} .header-content {
    max-width: 900px;
    margin: 0 auto clamp(3.5rem, 8vw, 5.5rem) auto;
    position: relative;
    text-align: center;
  }

  .infra-tech-{{ section.id }} .main-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    color: {{ heading_color }};
    margin: 0 0 1.5rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1.05;
  }

  .infra-tech-{{ section.id }} .description {
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    color: {{ text_color }};
    line-height: 1.6;
    margin: 0;
    opacity: 0.85;
    font-weight: 450;
  }

  /* ── Offerings Section ── */
  .infra-tech-{{ section.id }} .offer-wrap {
    background: linear-gradient(145deg, {{ card_bg }}, rgba(255,255,255,0.7));
    padding: clamp(3rem, 5vw, 5rem);
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow: 0 35px 80px rgba(0, 0, 0, 0.05), inset 0 2px 5px rgba(255,255,255,1);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
  }

  .infra-tech-{{ section.id }} .offer-wrap::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 6px;
    background: linear-gradient(180deg, {{ accent_color | color_lighten: 20 }}, {{ accent_color }});
    border-radius: 40px 0 0 40px;
    box-shadow: 2px 0 15px {{ accent_color | color_modify: 'alpha', 0.4 }};
  }

  .infra-tech-{{ section.id }} .offer-title {
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    color: {{ heading_color }};
    margin-bottom: 3rem;
    font-weight: 850;
    display: flex;
    align-items: center;
    gap: 20px;
    letter-spacing: -0.02em;
  }

  .infra-tech-{{ section.id }} .offer-title::after {
    content: '';
    flex-grow: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(20,68,45,0.1), transparent);
  }

  /* ── Offer Grid ── */
  .infra-tech-{{ section.id }} .offer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media screen and (min-width: 768px) {
    .infra-tech-{{ section.id }} .offer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem 2rem;
    }
  }

  .infra-tech-{{ section.id }} .offer-item {
    display: flex;
    align-items: flex-start;
    padding: 1.25rem 1.5rem;
    background: rgba(255,255,255,0.4);
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.6);
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .infra-tech-{{ section.id }} .offer-item:hover {
    transform: translateX(10px) translateY(-2px);
    background: rgba(255,255,255,0.9);
    box-shadow: 0 10px 25px rgba(20, 68, 45, 0.05);
    border-color: rgba(255,255,255,1);
  }

  .infra-tech-{{ section.id }} .icon-box {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    margin-top: 2px;
    margin-right: 1.25rem;
    color: {{ accent_color }};
    background: linear-gradient(135deg, {{ accent_color | color_modify: 'alpha', 0.15 }}, {{ accent_color | color_modify: 'alpha', 0.05 }});
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 8px {{ accent_color | color_modify: 'alpha', 0.1 }};
  }

  .infra-tech-{{ section.id }} .item-text {
    font-size: 1.2rem;
    font-weight: 700;
    color: {{ heading_color }};
    margin: 0;
    line-height: 1.4;
  }

  @media screen and (max-width: 767px) {
    .infra-tech-{{ section.id }} .container { padding: 0 1.25rem; }
    .infra-tech-{{ section.id }} .offer-wrap { padding: 3rem 1.5rem; border-radius: 32px; }
    .infra-tech-{{ section.id }} .offer-item { padding: 1rem; }
  }
{%- endstyle -%}

<section class="infra-tech-{{ section.id }}" id="Infrastructure-{{ section.id }}">
  <div class="container">
    
    <div class="header-content anim-fade">
      {%- if section.settings.title != blank -%}
        <h2 class="main-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="description">
          {{ section.settings.description }}
        </div>
      {%- endif -%}
    </div>

    <div class="offer-wrap anim-fade d-1">
      {%- if section.settings.offer_title != blank -%}
        <h3 class="offer-title">{{ section.settings.offer_title }}</h3>
      {%- endif -%}

      <div class="offer-grid">
        {%- for block in section.blocks -%}
          {%- assign delay_class = forloop.index | modulo: 4 | plus: 1 -%}
          <div class="offer-item anim-slide d-{{ delay_class }}" {{ block.shopify_attributes }}>
            <div class="icon-box">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <p class="item-text">{{ block.settings.title | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Infrastructure & Tech",
  "tag": "section",
  "class": "section-infra-tech",
  "settings": [
    {
      "type": "header",
      "content": "Description Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Infrastructure & Technology"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Our modern processing facility is equipped with advanced machinery, hygienic production lines, and strict quality control systems. From raw material procurement to final packaging, every step is carefully monitored to ensure consistency and excellence."
    },
    {
      "type": "header",
      "content": "Offerings Content"
    },
    {
      "type": "text",
      "id": "offer_title",
      "label": "Offer Heading",
      "default": "We offer:"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1300
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#F8FBFA"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#10A560"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "offering",
      "name": "Offering Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Offering Name",
          "default": "Offering Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Infrastructure & Tech",
      "blocks": [
        { "type": "offering", "settings": { "title": "Private Label Manufacturing" } },
        { "type": "offering", "settings": { "title": "Contract Manufacturing" } },
        { "type": "offering", "settings": { "title": "Customized Packaging Solutions" } },
        { "type": "offering", "settings": { "title": "Bulk & Retail Packing Options" } },
        { "type": "offering", "settings": { "title": "Complete Export Documentation & Compliance Support" } }
      ]
    }
  ]
}
{% endschema %}
