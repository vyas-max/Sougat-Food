{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign section_bg = section.settings.bg_color
-%}

{%- style -%}
  .infra-tech-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    position: relative;
    overflow: hidden;
    color: #fff;
  }

  /* Golden Dust/Sparkle Effect */
  .infra-tech-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 20% 30%, {{ accent_color | color_modify: 'alpha', 0.1 }} 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, {{ accent_color | color_modify: 'alpha', 0.1 }} 0%, transparent 50%);
    pointer-events: none;
    z-index: 1;
  }

  .infra-tech-{{ section.id }}::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.05;
    pointer-events: none;
    z-index: 1;
  }

  .infra-tech-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 2;
  }

  /* ── Header ── */
  .infra-tech-{{ section.id }} .header-wrap {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .infra-tech-{{ section.id }} .main-title {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    color: {{ accent_color }};
    text-transform: uppercase;
    font-weight: 500;
    margin: 0 0 1.5rem;
    font-family: serif;
    letter-spacing: 0.08em;
  }

  .infra-tech-{{ section.id }} .description {
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Glass Console ── */
  .infra-tech-{{ section.id }} .glass-console {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-top: 1px solid rgba(255, 255, 255, 0.4); /* Highlight top edge */
    border-radius: 24px;
    padding: clamp(2rem, 4vw, 4rem);
    box-shadow: 
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      inset 0 0 20px rgba(255, 255, 255, 0.05);
    position: relative;
  }

  /* Gold Border Glow Animation */
  .infra-tech-{{ section.id }} .glass-console::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 24px;
    padding: 1px;
    background: linear-gradient(135deg, {{ accent_color | color_modify: 'alpha', 0.5 }}, transparent 50%, {{ accent_color | color_modify: 'alpha', 0.3 }});
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .infra-tech-{{ section.id }} .offer-header {
    margin-bottom: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .infra-tech-{{ section.id }} .offer-title {
    font-size: 2.25rem;
    font-family: serif;
    font-weight: 500;
    color: #fff;
    margin: 0;
  }

  .infra-tech-{{ section.id }} .offer-line {
    flex-grow: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(255,255,255,0.2), transparent);
  }

  /* ── Offer Grid ── */
  .infra-tech-{{ section.id }} .offer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media screen and (min-width: 768px) {
    .infra-tech-{{ section.id }} .offer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  .infra-tech-{{ section.id }} .offer-pill {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1rem 1.5rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: all 0.3s ease;
  }

  .infra-tech-{{ section.id }} .offer-pill:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: {{ accent_color | color_modify: 'alpha', 0.4 }};
    transform: translateX(5px);
  }

  .infra-tech-{{ section.id }} .check-circle {
    width: 28px;
    height: 28px;
    background: {{ accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section_bg }};
    flex-shrink: 0;
    box-shadow: 0 0 10px {{ accent_color | color_modify: 'alpha', 0.3 }};
  }

  .infra-tech-{{ section.id }} .check-circle svg {
    width: 16px;
    height: 16px;
  }

  .infra-tech-{{ section.id }} .pill-text {
    font-size: 1.1rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.95);
    margin: 0;
    line-height: 1.3;
  }

  @media screen and (max-width: 767px) {
    .infra-tech-{{ section.id }} .offer-title { font-size: 1.75rem; }
    .infra-tech-{{ section.id }} .glass-console { padding: 1.5rem; }
    .infra-tech-{{ section.id }} .pill-text { font-size: 1rem; }
  }
{%- endstyle -%}

<section class="infra-tech-{{ section.id }}">
  <div class="container">
    <div class="header-wrap">
      <h2 class="main-title">{{ section.settings.title }}</h2>
      {%- if section.settings.description != blank -%}
        <div class="description">
          {{ section.settings.description }}
        </div>
      {%- endif -%}
    </div>

    <div class="glass-console">
      <div class="offer-header">
        <h3 class="offer-title">{{ section.settings.offer_title }}</h3>
        <div class="offer-line"></div>
      </div>

      <div class="offer-grid">
        {%- for block in section.blocks -%}
          <div class="offer-pill" {{ block.shopify_attributes }}>
            <div class="check-circle">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <p class="pill-text">{{ block.settings.title | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Infrastructure & Tech",
  "tag": "section",
  "class": "section-infra-tech",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "INFRASTRUCTURE & TECHNOLOGY"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Our modern processing facility is equipped with advanced machinery, hygienic production lines, and strict quality control systems. From raw material procurement to final packaging, every step is carefully monitored to ensure consistency and excellence."
    },
    {
      "type": "text",
      "id": "offer_title",
      "label": "Offer Heading",
      "default": "We offer:"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (Dark Green)",
      "default": "#003D2B"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Gold)",
      "default": "#C5A47E"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1200
    }
  ],
  "blocks": [
    {
      "type": "offering",
      "name": "Offering Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Offering Name",
          "default": "Private Label Manufacturing"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Infrastructure & Tech",
      "blocks": [
        { "type": "offering", "settings": { "title": "Private Label Manufacturing" } },
        { "type": "offering", "settings": { "title": "Contract Manufacturing" } },
        { "type": "offering", "settings": { "title": "Customized Packaging Solutions" } },
        { "type": "offering", "settings": { "title": "Bulk & Retail Packing Options" } },
        { "type": "offering", "settings": { "title": "Complete Export Documentation & Compliance Support" } }
      ]
    }
  ]
}
{% endschema %}
