{% comment %}
  Video Product Showcase Section
  Full width video with products overlaying at the bottom
  Products appear based on video timestamp
{% endcomment %}

{% liquid
  assign section_id = section.id
  assign heading = section.settings.heading
%}

<div class="vps-section" data-section-id="{{ section_id }}" {{ section.shopify_attributes }}>

  {% comment %} Video Container with Overlay Products {% endcomment %}
  <div class="vps-video-wrapper" id="vps-wrapper-{{ section_id }}">

    {% comment %} Main Video {% endcomment %}
    <div class="vps-video-container">
      {% if section.settings.video_source == 'uploaded' and section.settings.video != blank %}
        {% assign vps_video_dom_id = 'vps-video-' | append: section_id %}
        {{
          section.settings.video
          | video_tag:
            image_size: '2500x',
            autoplay: true,
            loop: section.settings.loop,
            muted: true,
            controls: false,
            id: vps_video_dom_id,
            class: 'vps-video'
        }}
      {% elsif section.settings.video_source == 'url' and section.settings.video_url != blank %}
        {% liquid
          assign vps_video_dom_id = 'vps-video-' | append: section_id
          assign video_id = section.settings.video_url.id
          assign video_type = section.settings.video_url.type

          if video_type == 'youtube'
            assign video_src = 'https://www.youtube.com/embed/' | append: video_id
            assign video_src = video_src | append: '?enablejsapi=1&rel=0&controls=1'
            if section.settings.autoplay
              assign video_src = video_src | append: '&autoplay=1&mute=1'
            endif
            if section.settings.loop
              assign video_src = video_src | append: '&loop=1&playlist=' | append: video_id
            endif
          elsif video_type == 'vimeo'
            assign video_src = 'https://player.vimeo.com/video/' | append: video_id
            assign video_src = video_src | append: '?api=1&controls=1'
            if section.settings.autoplay
              assign video_src = video_src | append: '&autoplay=1&muted=1'
            endif
            if section.settings.loop
              assign video_src = video_src | append: '&loop=1'
            endif
          endif
        %}
        <iframe
          id="{{ vps_video_dom_id }}"
          src="{{ video_src }}"
          class="vps-iframe"
          allow="autoplay; encrypted-media; fullscreen"
          allowfullscreen
          data-video-type="{{ video_type }}"
        ></iframe>
      {% else %}
        <div class="vps-placeholder">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polygon points="5,3 19,12 5,21"></polygon>
          </svg>
          <p>Add a video to get started</p>
        </div>
      {% endif %}
    </div>

    {% comment %} Content Overlay (Title + Nav + Products) {% endcomment %}
    <div class="vps-content-overlay" id="vps-products-{{ section_id }}">
      
      {% comment %} Title & Navigation Row {% endcomment %}
      {% if section.settings.show_heading %}
        <div class="vps-header-row">
          <div class="vps-header-text">
            <span class="vps-subtitle">FEATURED</span>
            <h2 class="vps-heading">{{ heading }}</h2>
          </div>
          <div class="vps-nav-arrows">
            <button type="button" class="vps-nav-btn vps-nav-prev" aria-label="Previous products">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button type="button" class="vps-nav-btn vps-nav-next" aria-label="Next products">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        </div>
      {% endif %}

      {% comment %} Products Strip {% endcomment %}
      <div class="vps-products-inner">
        {% for block in section.blocks %}
          {% if block.type == 'product_tag' %}
            {% assign product = block.settings.product %}

            <div
              class="vps-product-card"
              data-block-id="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              {% if product != blank %}
                <div class="vps-product-content">
                  <a href="{{ product.url }}" class="vps-product-link">
                    <div class="vps-product-image">
                      {% if product.featured_image %}
                        {{
                          product.featured_image
                          | image_url: width: 200
                          | image_tag:
                            loading: 'lazy',
                            alt: product.featured_image.alt,
                            class: 'vps-product-img'
                        }}
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag: 'vps-placeholder-svg' }}
                      {% endif %}
                    </div>
                    <div class="vps-product-info">
                      <p class="vps-product-title">{{ product.title }}</p>
                      {% liquid
                        assign vps_product_desc = product.description | strip_html | strip
                        if vps_product_desc == blank and product.metafields.custom.short_description != blank
                          assign vps_product_desc = product.metafields.custom.short_description.value | strip_html | strip
                        endif
                        if vps_product_desc == blank
                          assign vps_product_desc = product.title
                        endif
                      %}
                      <p class="vps-product-desc">{{ vps_product_desc | truncatewords: 18 }}</p>
                    </div>
                  </a>
                  <div class="vps-product-purchase">
                    <div class="vps-product-pricing">
                      {% if product.compare_at_price > product.price %}
                        <span class="vps-product-compare">{{ product.compare_at_price | money }}</span>
                      {% endif %}
                      <span class="vps-product-price">{{ product.price | money }}</span>
                    </div>
                    <form method="post" action="{{ routes.cart_add_url }}" class="vps-product-cart">
                      <input type="hidden" name="form_type" value="product">
                      <input type="hidden" name="utf8" value="✓">
                      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button
                        class="vps-product-add"
                        type="submit"
                        aria-label="Add {{ product.title | escape }} to cart"
                      >
                        +
                      </button>
                    </form>
                  </div>
                </div>
              {% else %}
                <div class="vps-product-empty">
                  <p>Select a product</p>
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

  </div>
</div>

{% stylesheet %}
  /* Base Section */
  .vps-section {
    width: 100%;
    background: #000;
    position: relative;
    padding: 0;
    margin: 0;
  }

  /* Video Wrapper */
  .vps-video-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .vps-video-container {
    width: 100%;
    position: relative;
    max-height: min(85vh, 720px);
    overflow: hidden;
  }

  .vps-video,
  .vps-iframe {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: {{ section.settings.video_aspect_ratio }};
    object-fit: cover;
    max-height: min(85vh, 720px);
  }

  .vps-video-container::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.75) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .vps-placeholder {
    aspect-ratio: {{ section.settings.video_aspect_ratio }};
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
    color: rgba(255, 255, 255, 0.4);
    gap: 16px;
  }

  /* Content Overlay - absolute over video */
  .vps-content-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(24px, 4vw, 60px);
  }

  /* Header Row - Title + Nav at TOP */
  .vps-header-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .vps-header-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .vps-subtitle {
    color: rgba(255, 255, 255, 0.7);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .vps-heading {
    color: #fff;
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
    line-height: 1.1;
  }

  .vps-nav-arrows {
    display: flex;
    gap: 8px;
  }

  .vps-nav-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: #ff6b35;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.2s ease;
    position: relative;
    z-index: 10;
    pointer-events: auto;
  }

  .vps-nav-btn:hover {
    background: #e55a2b;
    transform: scale(1.05);
  }

  .vps-nav-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* Products Strip */
  .vps-products-inner {
    display: flex;
    gap: clamp(16px, 2vw, 24px);
    overflow-x: scroll;
    overflow-y: hidden;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 4px;
  }

  .vps-products-inner::-webkit-scrollbar {
    display: none;
  }

  /* Product Card */
  .vps-product-card {
    background: #fff;
    border-radius: 16px;
    padding: 16px;
    flex: 0 0 calc(33.333% - 16px);
    min-width: 300px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    scroll-snap-align: start;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .vps-product-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
  }

  .vps-product-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .vps-product-link {
    display: flex;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
  }

  .vps-product-image {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    border-radius: 12px;
    padding: 8px;
  }

  .vps-product-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .vps-placeholder-svg {
    width: 40px;
    height: 40px;
    color: #ccc;
  }

  .vps-product-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    min-width: 0;
  }

  .vps-product-title {
    font-weight: 600;
    font-size: 14px;
    color: #1a1a1a;
    margin: 0 0 6px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .vps-product-pricing {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .vps-product-compare {
    font-size: 11px;
    color: #999;
    text-decoration: line-through;
  }

  .vps-product-price {
    font-weight: 700;
    font-size: 15px;
    color: #ff6b35;
  }

  .vps-product-desc {
    font-size: 12px;
    color: #666;
    margin: 0 0 10px 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .vps-product-purchase {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: auto;
  }

  .vps-product-cart {
    flex-shrink: 0;
  }

  .vps-product-add {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: none;
    background: #ff6b35;
    color: #fff;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .vps-product-add:hover {
    background: #e55a2b;
    transform: scale(1.1);
  }

  .vps-product-add:focus {
    outline: 2px solid rgba(255, 107, 53, 0.5);
    outline-offset: 2px;
  }

  .vps-product-empty {
    padding: 20px;
    text-align: center;
    color: #999;
  }

  /* Desktop (1200px+) */
  @media (min-width: 1200px) {
    .vps-product-card {
      flex: 0 0 calc(30% - 16px);
      min-width: 300px;
    }
  }

  /* Tablet (768px - 1199px) */
  @media (min-width: 768px) and (max-width: 1199px) {
    .vps-content-overlay {
      padding: clamp(20px, 3vw, 40px);
    }

    .vps-product-card {
      flex: 0 0 calc(45% - 12px);
      min-width: 260px;
    }

    .vps-header-row {
      margin-bottom: 20px;
    }

    .vps-heading {
      font-size: clamp(1.2rem, 3vw, 1.8rem);
    }
  }

  /* Mobile (< 768px) */
  @media (max-width: 767px) {
    .vps-video-wrapper {
      min-height: 520px;
    }

    .vps-video-container,
    .vps-video,
    .vps-iframe {
      min-height: 520px;
      max-height: none;
      object-fit: cover;
    }

    .vps-content-overlay {
      padding: 24px 16px 20px;
      justify-content: flex-start;
      gap: 20px;
    }

    .vps-header-row {
      margin-bottom: 0;
      flex-wrap: wrap;
      gap: 10px;
    }

    .vps-subtitle {
      font-size: 11px;
    }

    .vps-heading {
      font-size: 1.4rem;
    }

    .vps-nav-arrows {
      gap: 8px;
    }

    .vps-nav-btn {
      width: 34px;
      height: 34px;
    }

    .vps-nav-btn svg {
      width: 16px;
      height: 16px;
    }

    .vps-products-inner {
      gap: 12px;
      margin-top: auto;
      padding-bottom: 10px;
    }

    .vps-product-card {
      flex: 0 0 auto;
      min-width: 80vw;
      max-width: 80vw;
      padding: 12px;
      border-radius: 12px;
    }

    .vps-product-link {
      gap: 10px;
    }

    .vps-product-image {
      width: 55px;
      height: 55px;
      padding: 5px;
      border-radius: 10px;
    }

    .vps-product-info {
      gap: 2px;
    }

    .vps-product-title {
      font-size: 14px;
      font-weight: 600;
    }

    .vps-product-desc {
      font-size: 12px;
      -webkit-line-clamp: 1;
      margin-bottom: 4px;
    }

    .vps-product-price {
      font-size: 14px;
    }

    .vps-product-add {
      width: 30px;
      height: 30px;
      font-size: 16px;
      border-radius: 8px;
    }

    .vps-product-content {
      flex-direction: row;
      align-items: center;
    }

    .vps-product-purchase {
      flex-shrink: 0;
    }
  }
{% endstylesheet %}

<script>
(function(){
  window.VPSinit = function() {
    document.querySelectorAll('.vps-section').forEach(function(section) {
      var inner = section.querySelector('.vps-products-inner');
      if (!inner || inner.getAttribute('data-init') === '1') return;
      inner.setAttribute('data-init', '1');
      
      var cards = Array.from(inner.querySelectorAll('.vps-product-card'));
      if (cards.length < 2) return;
      
      var currentIndex = 0;
      var isPaused = false;
      var autoInterval = null;
      
      // Get card width + gap
      function getCardWidth() {
        return cards[0] ? cards[0].offsetWidth + 20 : 320;
      }
      
      // Scroll to specific index
      function scrollToIndex(idx) {
        if (idx < 0) idx = 0;
        if (idx >= cards.length) idx = cards.length - 1;
        currentIndex = idx;
        inner.scrollTo({ left: idx * getCardWidth(), behavior: 'smooth' });
      }
      
      // Next slide
      function nextSlide() {
        var maxIdx = Math.max(0, cards.length - Math.floor(inner.clientWidth / getCardWidth()));
        if (currentIndex >= maxIdx) {
          currentIndex = 0;
        } else {
          currentIndex++;
        }
        scrollToIndex(currentIndex);
      }
      
      // Prev slide
      function prevSlide() {
        if (currentIndex <= 0) {
          var maxIdx = Math.max(0, cards.length - Math.floor(inner.clientWidth / getCardWidth()));
          currentIndex = maxIdx;
        } else {
          currentIndex--;
        }
        scrollToIndex(currentIndex);
      }
      
      // Navigation buttons
      var prevBtn = section.querySelector('.vps-nav-prev');
      var nextBtn = section.querySelector('.vps-nav-next');
      
      if (prevBtn) {
        prevBtn.onclick = function(e) {
          e.preventDefault();
          prevSlide();
        };
      }
      
      if (nextBtn) {
        nextBtn.onclick = function(e) {
          e.preventDefault();
          nextSlide();
        };
      }
      
      // Auto-scroll every 3 seconds (slide by slide)
      function startAutoScroll() {
        if (autoInterval) clearInterval(autoInterval);
        autoInterval = setInterval(function() {
          if (!isPaused) nextSlide();
        }, 3000);
      }
      
      // Pause on hover/touch
      inner.onmouseenter = function() { isPaused = true; };
      inner.onmouseleave = function() { isPaused = false; };
      inner.ontouchstart = function() { isPaused = true; };
      inner.ontouchend = function() { setTimeout(function() { isPaused = false; }, 3000); };
      
      // Start auto-scroll
      if (inner.scrollWidth > inner.clientWidth) {
        startAutoScroll();
      }
    });
  };
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', window.VPSinit);
  } else {
    window.VPSinit();
  }
  document.addEventListener('shopify:section:load', window.VPSinit);
})();
</script>

{% schema %}
{
  "name": "Video Product Showcase",
  "tag": "section",
  "class": "vps-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show Heading",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP THE VIDEO"
    },
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "select",
      "id": "video_source",
      "label": "Video Source",
      "options": [
        { "value": "uploaded", "label": "Uploaded Video" },
        { "value": "url", "label": "External URL (YouTube/Vimeo)" }
      ],
      "default": "uploaded"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "visible_if": "{{ section.settings.video_source == 'uploaded' }}"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"],
      "visible_if": "{{ section.settings.video_source == 'url' }}"
    },
    {
      "type": "select",
      "id": "video_aspect_ratio",
      "label": "Aspect Ratio",
      "options": [
        { "value": "16/9", "label": "Landscape (16:9)" },
        { "value": "21/9", "label": "Ultrawide (21:9)" },
        { "value": "9/16", "label": "Portrait (9:16)" }
      ],
      "default": "16/9"
    },
    {
      "type": "range",
      "id": "video_duration",
      "min": 15,
      "max": 300,
      "step": 5,
      "unit": "s",
      "label": "Video Duration",
      "default": 60,
      "info": "Used for timeline positioning"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Muted (required for autoplay)",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "product_tag",
      "name": "Product Tag",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "timestamp",
          "min": 0,
          "max": 300,
          "step": 5,
          "unit": "s",
          "label": "Show at Timestamp",
          "default": 10,
          "info": "Product appears when video reaches this time"
        },
        {
          "type": "checkbox",
          "id": "show_description",
          "label": "Show Product Description",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Product Showcase",
      "blocks": [
        { "type": "product_tag", "settings": { "timestamp": 5 } },
        { "type": "product_tag", "settings": { "timestamp": 15 } },
        { "type": "product_tag", "settings": { "timestamp": 30 } }
      ]
    }
  ]
}
{% endschema %}
