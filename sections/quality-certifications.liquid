{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign section_bg = section.settings.bg_color
  assign footer_bg = section.settings.footer_bg_color
-%}

{%- style -%}
  .quality-certs-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section_bg }};
  }

  .quality-certs-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .quality-certs-{{ section.id }} .header-wrap {
    text-align: center;
    margin-bottom: 3rem;
  }

  .quality-certs-{{ section.id }} .main-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: {{ heading_color }};
    margin: 0 0 1rem;
    font-weight: 700;
  }

  .quality-certs-{{ section.id }} .subheading {
    font-size: 1rem;
    color: {{ text_color }};
    line-height: 1.6;
    margin: 0;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .quality-certs-{{ section.id }} .certs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }

  @media screen and (min-width: 640px) {
    .quality-certs-{{ section.id }} .certs-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .quality-certs-{{ section.id }} .certs-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }

  .quality-certs-{{ section.id }} .cert-card {
    background: #fff;
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid {{ accent_color | color_modify: 'alpha', 0.3 }};
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .quality-certs-{{ section.id }} .cert-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
  }

  .quality-certs-{{ section.id }} .cert-stamp {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: {{ accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    margin: 0 auto 1rem;
  }

  .quality-certs-{{ section.id }} .cert-stamp svg {
    width: 24px;
    height: 24px;
  }

  .quality-certs-{{ section.id }} .cert-name {
    font-size: 1rem;
    font-weight: 700;
    color: {{ heading_color }};
    margin: 0;
    line-height: 1.3;
  }

  .quality-certs-{{ section.id }} .footer-banner {
    background-color: {{ footer_bg }};
    border: 1px solid {{ accent_color | color_modify: 'alpha', 0.3 }};
    padding: 2rem;
    border-radius: 8px;
    text-align: center;
  }

  .quality-certs-{{ section.id }} .banner-text {
    font-size: 1rem;
    color: {{ text_color }};
    line-height: 1.7;
    margin: 0;
  }

  .quality-certs-{{ section.id }} .banner-text p {
    margin: 0;
  }
{%- endstyle -%}

<section class="quality-certs-{{ section.id }}">
  <div class="container">
    <div class="header-wrap">
      <h2 class="main-title">{{ section.settings.title }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="certs-grid">
      {%- for block in section.blocks -%}
        <div class="cert-card" {{ block.shopify_attributes }}>
          <div class="cert-stamp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12l2 2 4-4"></path>
            </svg>
          </div>
          <h4 class="cert-name">{{ block.settings.title | escape }}</h4>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_text != blank -%}
      <div class="footer-banner">
        <div class="banner-text">
          {{ section.settings.footer_text }}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Quality & Certifications",
  "tag": "section",
  "class": "section-quality-certs",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Certified Quality"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Quality is at the heart of everything we do. Our manufacturing processes strictly follow international food safety standards."
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "<p>These certifications reflect our commitment to food safety, ethical sourcing, transparency, and global compliance.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F8F3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#003D2B"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#10A560"
    },
    {
      "type": "color",
      "id": "footer_bg_color",
      "label": "Footer Background Color",
      "default": "#E8F5F1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "certification",
      "name": "Certification",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Certification Name",
          "default": "BRC"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quality & Certifications",
      "blocks": [
        { "type": "certification", "settings": { "title": "BRC" } },
        { "type": "certification", "settings": { "title": "FSSC 22000" } },
        { "type": "certification", "settings": { "title": "HACCP" } },
        { "type": "certification", "settings": { "title": "SEDEX" } }
      ]
    }
  ]
}
{% endschema %}
