{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign section_bg = section.settings.bg_color
  assign footer_bg = section.settings.footer_bg_color
-%}

{%- style -%}
  .quality-certs-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section_bg }};
    position: relative;
  }

  .quality-certs-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  .quality-certs-{{ section.id }} .header-wrap {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .quality-certs-{{ section.id }} .main-title-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .quality-certs-{{ section.id }} .title-icon {
    width: 48px;
    height: 48px;
    color: {{ accent_color }};
    flex-shrink: 0;
  }

  .quality-certs-{{ section.id }} .main-title {
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    color: {{ heading_color }};
    text-transform: uppercase;
    font-weight: 600;
    margin: 0;
    font-family: serif;
    letter-spacing: 0.05em;
  }

  .quality-certs-{{ section.id }} .subheading {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: #444;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Grid ── */
  .quality-certs-{{ section.id }} .certs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  @media screen and (min-width: 1024px) {
    .quality-certs-{{ section.id }} .certs-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
    }
  }

  .quality-certs-{{ section.id }} .cert-card {
    background: #fff;
    padding: 2.5rem 1.5rem;
    border-radius: 8px;
    border: 1.5px solid {{ accent_color | color_modify: 'alpha', 0.3 }};
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    transition: transform 0.3s ease;
  }

  .quality-certs-{{ section.id }} .cert-card:hover {
    transform: translateY(-5px);
  }

  .quality-certs-{{ section.id }} .cert-stamp {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: {{ heading_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ accent_color }};
    margin-bottom: 0.5rem;
    border: 2px solid {{ accent_color | color_modify: 'alpha', 0.2 }};
  }

  .quality-certs-{{ section.id }} .cert-stamp svg {
    width: 32px;
    height: 32px;
  }

  .quality-certs-{{ section.id }} .cert-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: {{ heading_color }};
    margin: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .quality-certs-{{ section.id }} .cert-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ── Footer Box ── */
  .quality-certs-{{ section.id }} .footer-banner {
    background-color: {{ footer_bg }};
    border: 1.5px solid {{ accent_color | color_modify: 'alpha', 0.5 }};
    padding: 3rem 2rem;
    border-radius: 12px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .quality-certs-{{ section.id }} .banner-icon {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background-color: {{ heading_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ accent_color }};
  }

  .quality-certs-{{ section.id }} .banner-text {
    font-size: 1.2rem;
    color: #333;
    max-width: 800px;
    line-height: 1.5;
    font-weight: 500;
  }

  @media screen and (max-width: 767px) {
    .quality-certs-{{ section.id }} .main-title-wrap {
      flex-direction: column;
      gap: 0.5rem;
    }
    .quality-certs-{{ section.id }} .footer-banner {
      padding: 2rem 1rem;
    }
    .quality-certs-{{ section.id }} .banner-text {
      font-size: 1.05rem;
    }
  }
{%- endstyle -%}

<section class="quality-certs-{{ section.id }}">
  <div class="container">
    <div class="header-wrap">
      <div class="main-title-wrap">
        <div class="title-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <path d="M9 12l2 2 4-4"></path>
          </svg>
        </div>
        <h2 class="main-title">{{ section.settings.title }}</h2>
      </div>
      {%- if section.settings.subheading != blank -%}
        <p class="subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="certs-grid">
      {%- for block in section.blocks -%}
        <div class="cert-card" {{ block.shopify_attributes }}>
          <div class="cert-stamp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9 12l2 2 4-4"></path>
            </svg>
          </div>
          <h4 class="cert-name">{{ block.settings.title | escape }}</h4>
          <span class="cert-label">Certified</span>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_text != blank -%}
      <div class="footer-banner">
        <div class="banner-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M9 12l2 2 4-4"></path>
          </svg>
        </div>
        <div class="banner-text">
          {{ section.settings.footer_text }}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Quality & Certifications",
  "tag": "section",
  "class": "section-quality-certs",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "CERTIFIED QUALITY"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Quality is at the heart of everything we do. Our manufacturing processes strictly follow international food safety standards. We are proud to be certified with:"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Banner Text",
      "default": "<p>These certifications reflect our commitment to food safety, ethical sourcing, transparency, and global compliance.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F8F3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading & Stamp Color (Dark Green)",
      "default": "#003D2B"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Gold)",
      "default": "#C5A47E"
    },
    {
      "type": "color",
      "id": "footer_bg_color",
      "label": "Footer Banner Background (Mint)",
      "default": "#E8F5F1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1200
    }
  ],
  "blocks": [
    {
      "type": "certification",
      "name": "Certification",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Certification Name",
          "default": "BRC"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quality & Certifications",
      "blocks": [
        { "type": "certification", "settings": { "title": "BRC" } },
        { "type": "certification", "settings": { "title": "FSSC 22000" } },
        { "type": "certification", "settings": { "title": "HACCP" } },
        { "type": "certification", "settings": { "title": "SEDEX" } }
      ]
    }
  ]
}
{% endschema %}
