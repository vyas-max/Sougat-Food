{%- style -%}
{%- liquid
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign accent_color = section.settings.accent_color
  assign card_bg = section.settings.card_bg
  assign section_bg = section.settings.bg_color
-%}

{%- style -%}
  .about-freeze-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section_bg }};
    overflow: hidden;
    position: relative;
    font-display: swap;
  }

  /* ── Premium Mesh Background ── */
  .about-freeze-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: -20%;
    left: -10%;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, {{ accent_color | color_modify: 'alpha', 0.08 }} 0%, rgba(255,255,255,0) 60%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .about-freeze-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: -20%;
    right: -10%;
    width: 50%;
    height: 50%;
    background: radial-gradient(circle, {{ heading_color | color_modify: 'alpha', 0.03 }} 0%, rgba(255,255,255,0) 60%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .about-freeze-{{ section.id }} .container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* ── Animations ── */
  @keyframes fadeUpAnim {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .about-freeze-{{ section.id }} .animate-on-load {
    animation: fadeUpAnim 0.8s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
    opacity: 0;
  }
  .about-freeze-{{ section.id }} .delay-1 { animation-delay: 0.1s; }
  .about-freeze-{{ section.id }} .delay-2 { animation-delay: 0.2s; }
  .about-freeze-{{ section.id }} .delay-3 { animation-delay: 0.3s; }

  /* ── Header Styling ── */
  .about-freeze-{{ section.id }} .header-group {
    text-align: center;
    margin-bottom: clamp(3.5rem, 8vw, 5.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .about-freeze-{{ section.id }} .badge {
    display: inline-block;
    padding: 6px 18px;
    background: linear-gradient(135deg, {{ accent_color | color_modify: 'alpha', 0.15 }}, {{ accent_color | color_modify: 'alpha', 0.05 }});
    color: {{ accent_color }};
    border: 1px solid {{ accent_color | color_modify: 'alpha', 0.2 }};
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px {{ accent_color | color_modify: 'alpha', 0.1 }};
  }

  .about-freeze-{{ section.id }} .main-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    color: {{ heading_color }};
    margin: 0 0 1.5rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1.05;
    max-width: 900px;
  }

  .about-freeze-{{ section.id }} .subheading {
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    color: {{ text_color }};
    max-width: 750px;
    margin: 0;
    opacity: 0.85;
    line-height: 1.6;
    font-weight: 400;
  }

  /* ── Why Choose Header ── */
  .about-freeze-{{ section.id }} .why-choose-wrap {
    margin-top: clamp(4rem, 10vw, 7rem);
    text-align: center;
    margin-bottom: 4rem;
  }

  .about-freeze-{{ section.id }} .why-choose-title {
    font-size: clamp(2.2rem, 4.5vw, 3.25rem);
    color: {{ heading_color }};
    font-weight: 850;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .about-freeze-{{ section.id }} .why-choose-line {
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, transparent, {{ accent_color }}, transparent);
    margin: 0 auto;
    border-radius: 10px;
    opacity: 0.7;
  }

  /* ── Robust Grid System ── */
  .about-freeze-{{ section.id }} .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: stretch;
  }

  @media screen and (min-width: 768px) {
    .about-freeze-{{ section.id }} .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1100px) {
    .about-freeze-{{ section.id }} .grid {
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    }
  }

  /* ── Premium Card Design ── */
  .about-freeze-{{ section.id }} .card {
    background: linear-gradient(135deg, {{ card_bg }} 0%, rgba(255,255,255,0.7) 100%);
    padding: clamp(2.5rem, 4vw, 4rem) clamp(2rem, 3vw, 3rem);
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.03),
                inset 0 1px 0 rgba(255, 255, 255, 1);
    transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .about-freeze-{{ section.id }} .card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, {{ accent_color | color_modify: 'alpha', 0.08 }}, transparent 70%);
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .about-freeze-{{ section.id }} .card:hover {
    transform: translateY(-15px) scale(1.02);
    border-color: rgba(255, 255, 255, 1);
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.06),
                0 0 0 1px {{ accent_color | color_modify: 'alpha', 0.1 }};
  }

  .about-freeze-{{ section.id }} .card:hover::after {
    opacity: 1;
  }

  .about-freeze-{{ section.id }} .card-icon-wrap {
    width: 80px;
    height: 80px;
    margin: 0 auto 2.5rem;
    background: {{ section_bg }};
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 18px;
    position: relative;
    box-shadow: 0 10px 25px rgba(0,0,0,0.04), inset 0 2px 4px rgba(255,255,255,0.8);
    border: 1px solid rgba(0,0,0,0.03);
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  
  .about-freeze-{{ section.id }} .card:hover .card-icon-wrap {
    transform: scale(1.1) rotate(5deg);
  }

  .about-freeze-{{ section.id }} .card-icon-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.08));
  }

  .about-freeze-{{ section.id }} .card-content {
    text-align: center;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .about-freeze-{{ section.id }} .card-title {
    font-size: clamp(1.4rem, 2vw, 1.75rem);
    font-weight: 850;
    color: {{ heading_color }};
    margin: 0 0 1.25rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .about-freeze-{{ section.id }} .card-text {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    color: {{ text_color }};
    line-height: 1.7;
    margin: 0;
    opacity: 0.85;
    font-weight: 450;
  }

  @media screen and (max-width: 767px) {
    .about-freeze-{{ section.id }} .container { padding: 0 1.25rem; }
    .about-freeze-{{ section.id }} .header-group { margin-bottom: 3rem; }
    .about-freeze-{{ section.id }} .card { padding: 3rem 1.5rem; }
  }
{%- endstyle -%}

<section class="about-freeze-{{ section.id }}" id="AboutFreeze-{{ section.id }}">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <div class="header-group animate-on-load">
        <span class="badge">Innovation</span>
        <h2 class="main-title">{{ section.settings.title }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.why_title != blank -%}
      <div class="why-choose-wrap animate-on-load delay-1">
        <h3 class="why-choose-title">{{ section.settings.why_title }}</h3>
        <div class="why-choose-line"></div>
      </div>
    {%- endif -%}

    <div class="grid">
      {%- for block in section.blocks -%}
        {%- assign anim_delay = forloop.index | modulo: 3 | plus: 1 -%}
        <div class="card animate-on-load delay-{{ anim_delay }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="card-icon-wrap">
              <img src="{{ block.settings.image | image_url: width: 160 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="80" height="80">
            </div>
          {%- else -%}
             <div class="card-icon-wrap" style="background: {{ accent_color | color_modify: 'alpha', 0.05 }}">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="{{ accent_color }}" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v8M8 12h8"></path></svg>
             </div>
          {%- endif -%}
          
          <div class="card-content">
            {%- if block.settings.title != blank -%}
              <h4 class="card-title">{{ block.settings.title }}</h4>
            {%- endif -%}
            
            {%- if block.settings.text != blank -%}
              <div class="card-text">
                {{ block.settings.text }}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Freeze Dried",
  "tag": "section",
  "class": "section-about-freeze",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Heading",
      "default": "About Freeze Dried Fruits & Vegetables"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Creative designed by Sougat maam, can be use in home page."
    },
    {
      "type": "text",
      "id": "why_title",
      "label": "Why Choose Heading",
      "default": "Why Choose Sougat Foods?"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1300
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F8FBFA"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#10A560"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon/Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Describe the benefits of your product here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Freeze Dried",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Built on Experience",
            "text": "<p>Sougat Foods has been in the food industry since 1962, known for quality and trust.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "A New Step Forward",
            "text": "<p>Our freeze-dried range is a new addition — combining modern technology with our long-standing food expertise.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Naturally Preserved",
            "text": "<p>Freeze-drying gently removes moisture while keeping the natural taste, color, and nutrients intact — without added preservatives or artificial ingredients.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Made for Better Choices",
            "text": "<p>Lightweight, convenient, and made from real ingredients, our products offer a cleaner alternative to heavily processed snacks.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
