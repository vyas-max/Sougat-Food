{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: '#F8FBFA' }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .afd-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: center;
  }

  .afd-header-{{ section.id }} {
    margin-bottom: 50px;
  }

  .afd-badge-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 50px;
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
    color: {{ section.settings.accent_color }};
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 20px;
  }

  .afd-title-{{ section.id }} {
    font-size: clamp(32px, 5vw, 48px);
    color: {{ section.settings.heading_color }};
    margin: 0 0 15px;
    font-weight: 800;
    line-height: 1.2;
  }

  .afd-subheading-{{ section.id }} {
    font-size: 18px;
    color: {{ section.settings.text_color }};
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
    opacity: 0.8;
  }

  {% if section.settings.show_divider %}
  .afd-divider-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    margin: 40px 0;
  }

  .afd-divider-line {
    height: 1px;
    width: 60px;
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.3 }};
  }

  .afd-divider-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: {{ section.settings.card_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
    color: {{ section.settings.accent_color }};
  }
  {% endif %}

  .afd-why-title-{{ section.id }} {
    font-size: clamp(28px, 4vw, 36px);
    color: {{ section.settings.heading_color }};
    margin: 0 0 40px;
    font-weight: 700;
    position: relative;
    display: inline-block;
  }

  .afd-why-title-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 50px;
    height: 3px;
    background: {{ section.settings.accent_color }};
    border-radius: 2px;
  }

  .afd-cards-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
    margin: 0 auto;
  }

  .afd-card-{{ section.id }} {
    background: {{ section.settings.card_bg }};
    border-radius: 20px;
    padding: 35px 25px;
    flex: 0 1 calc(100% / {{ section.settings.columns }} - 24px);
    width: 100%;
    min-width: 260px;
    max-width: 360px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    border: 1px solid rgba(0,0,0,0.02);
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .afd-card-{{ section.id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.06);
  }

  .afd-card-number-{{ section.id }} {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
    color: {{ section.settings.accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 12px;
  }

  .afd-card-icon-{{ section.id }} {
    width: 70px;
    height: 70px;
    border-radius: 16px;
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.05 }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .afd-card-icon-{{ section.id }} svg,
  .afd-card-icon-{{ section.id }} img {
    width: 36px;
    height: 36px;
    color: {{ section.settings.accent_color }};
    object-fit: contain;
  }

  .afd-card-title-{{ section.id }} {
    font-size: 20px;
    color: {{ section.settings.heading_color }};
    font-weight: 700;
    margin: 0 0 15px;
    line-height: 1.3;
    text-align: center;
    width: 100%;
  }

  .afd-card-text-{{ section.id }} {
    color: {{ section.settings.text_color }};
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
    opacity: 0.8;
  }

  /* Force elements inside richtext description to perfectly center */
  .afd-card-text-{{ section.id }},
  .afd-card-text-{{ section.id }} p,
  .afd-card-text-{{ section.id }} span,
  .afd-card-text-{{ section.id }} * {
    text-align: center !important;
  }
  
  .afd-card-text-{{ section.id }} p {
    margin-bottom: 10px;
  }
  
  .afd-card-text-{{ section.id }} p:last-child {
    margin-bottom: 0;
  }

  .afd-card-link-{{ section.id }} {
    margin-top: 20px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: {{ section.settings.accent_color }};
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .afd-card-link-{{ section.id }}:hover {
    opacity: 0.7;
  }
  
  .afd-card-link-{{ section.id }} svg {
    width: 14px;
    height: 14px;
  }

  @media (max-width: 768px) {
    .afd-cards-{{ section.id }} {
      gap: 15px;
    }
    .afd-card-{{ section.id }} {
      max-width: 100%;
    }
  }
{%- endstyle -%}

<div class="afd-{{ section.id }}">
  {%- if section.settings.title != blank or section.settings.badge_text != blank -%}
    <div class="afd-header-{{ section.id }}">
      {%- if section.settings.badge_text != blank -%}
        <div class="afd-badge-{{ section.id }}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          {{ section.settings.badge_text }}
        </div>
      {%- endif -%}
      
      {%- if section.settings.title != blank -%}
        <h2 class="afd-title-{{ section.id }}">{{ section.settings.title }}</h2>
      {%- endif -%}
      
      {%- if section.settings.subheading != blank -%}
        <p class="afd-subheading-{{ section.id }}">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.settings.show_divider -%}
    <div class="afd-divider-{{ section.id }}">
      <div class="afd-divider-line"></div>
      <div class="afd-divider-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 3v18M3 12h18M5.636 5.636l12.728 12.728M18.364 5.636L5.636 18.364"/>
        </svg>
      </div>
      <div class="afd-divider-line"></div>
    </div>
  {%- endif -%}

  {%- if section.settings.why_title != blank -%}
    <h3 class="afd-why-title-{{ section.id }}">{{ section.settings.why_title }}</h3>
  {%- endif -%}

  <div class="afd-cards-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="afd-card-{{ section.id }}" {{ block.shopify_attributes }}>
        <div class="afd-card-number-{{ section.id }}">{{ forloop.index }}</div>
        
        <div class="afd-card-icon-{{ section.id }}">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 80 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="40" height="40">
          {%- else -%}
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              {%- case forloop.index -%}
                {%- when 1 -%}
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                {%- when 2 -%}
                  <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                {%- when 3 -%}
                  <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                {%- else -%}
                  <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/>
              {%- endcase -%}
            </svg>
          {%- endif -%}
        </div>
        
        {%- if block.settings.title != blank -%}
          <h4 class="afd-card-title-{{ section.id }}">{{ block.settings.title }}</h4>
        {%- endif -%}
        
        {%- if block.settings.text != blank -%}
          <div class="afd-card-text-{{ section.id }}">
            {{ block.settings.text }}
          </div>
        {%- endif -%}

        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="afd-card-link-{{ section.id }}">
            Learn more
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "About Freeze Dried",
  "tag": "section",
  "class": "section-about-freeze",
  "settings": [
    {
      "type": "header",
      "content": "Header Settings"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Innovation"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Heading",
      "default": "About Freeze Dried Fruits & Vegetables"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover the science and care behind our premium freeze-dried products"
    },
    {
      "type": "header",
      "content": "Why Choose Section"
    },
    {
      "type": "text",
      "id": "why_title",
      "label": "Why Choose Heading",
      "default": "Why Choose Sougat Foods?"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show Decorative Divider",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 4
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F8FBFA"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#14442D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#10A560"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon/Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Describe the benefits of your product here.</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Freeze Dried",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Built on Experience",
            "text": "<p>Sougat Foods has been in the food industry since 1962, known for quality and trust.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "A New Step Forward",
            "text": "<p>Our freeze-dried range is a new addition — combining modern technology with our long-standing food expertise.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Naturally Preserved",
            "text": "<p>Freeze-drying gently removes moisture while keeping the natural taste, color, and nutrients intact — without added preservatives.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Made for Better Choices",
            "text": "<p>Lightweight, convenient, and made from real ingredients, our products offer a cleaner alternative to heavily processed snacks.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}