{% schema %}
{
  "name": "Why Partner With Us",
  "settings": [
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background Gradient",
      "default": "linear-gradient(135deg, #ffffff 0%, #f9fafb 100%)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Why Partner With Sougat?"
    },
    {
      "type": "checkbox",
      "id": "show_dividers",
      "label": "Show Top/Bottom Dividers",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Reason",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Reason Text",
          "default": "List your reason here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Partner With Us",
      "blocks": [
        {
          "type": "reason",
          "settings": {
            "text": "Advanced Freeze-Drying Infrastructure"
          }
        },
        {
          "type": "reason",
          "settings": {
            "text": "International Certifications (BRC, FSSC 22000, HACCP, SEDEX)"
          }
        },
        {
          "type": "reason",
          "settings": {
            "text": "High-Quality Raw Material Sourcing"
          }
        },
        {
          "type": "reason",
          "settings": {
            "text": "Long Shelf-Life, Premium Products"
          }
        },
        {
          "type": "reason",
          "settings": {
            "text": "Professional Export Documentation Support"
          }
        },
        {
          "type": "reason",
          "settings": {
            "text": "Commitment to Long-Term Relationships"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }} {
    background: {{ section.settings.background_gradient }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body-family, sans-serif);
    position: relative;
    overflow: hidden;
  }

  {% if request.design_mode %}
  .section-{{ section.id }} .wpws-fade-up {
    opacity: 1 !important;
    transform: none !important;
  }
  {% endif %}

  .wpws-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Structural Dividers */
  .wpws-main-divider {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0) 100%);
    margin: 0;
    width: 100%;
  }

  .wpws-header {
    margin-top: 3rem;
    margin-bottom: 3.5rem;
    position: relative;
  }

  .wpws-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #111827;
    margin: 0;
    display: inline-block;
    position: relative;
  }

  /* Replicating the dual underline styling logic */
  .wpws-title strong {
    font-weight: 800;
  }
  
  .wpws-title-underline {
    position: relative;
    display: inline-block;
  }
  
  .wpws-title-underline::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 3px;
    bottom: -6px;
    left: 0;
    background: linear-gradient(90deg, #3b82f6, #10b981);
    border-radius: 2px;
  }

  /* List Container: Creating a masonry or staggered grid feel */
  .wpws-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 3.5rem;
  }

  .wpws-list-item {
    display: flex;
    align-items: center;
    background: #ffffff;
    padding: 1.25rem 2rem;
    border-radius: 16px;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
    border: 1px solid rgba(0,0,0,0.03);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    position: relative;
    overflow: hidden;
  }

  /* Subtle background hover effect */
  .wpws-list-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 4px;
    background: #10b981;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .wpws-list-item:hover {
    transform: translateX(10px);
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);
    background: #f8fafc;
  }

  .wpws-list-item:hover::before {
    opacity: 1;
  }

  .wpws-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    margin-right: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e0f2fe; /* Light blue circle */
    border-radius: 50%;
    color: #0ea5e9;
    padding: 4px;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .wpws-list-item:hover .wpws-icon {
    transform: scale(1.1);
    background: #10b981; /* Shift to green on hover */
    color: #ffffff;
  }

  .wpws-text {
    font-size: 1.15rem;
    color: #374151;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: -0.01em;
  }

  @media (max-width: 768px) {
    .wpws-title {
      font-size: 2rem;
    }
    
    .wpws-list-item {
      padding: 1rem 1.25rem;
      border-radius: 12px;
    }
    
    .wpws-icon {
      margin-right: 1rem;
    }
    
    .wpws-text {
      font-size: 1.05rem;
    }
    
    .wpws-list-item:hover {
      transform: translateX(5px);
    }
  }

  /* Reveal Animations */
  .wpws-fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.165, 0.84, 0.44, 1), transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  
  .wpws-fade-up.wpws-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<div class="section-{{ section.id }}">
  <div class="wpws-container">
    
    {% if section.settings.show_dividers %}
      <hr class="wpws-main-divider wpws-fade-up">
    {% endif %}

    <div class="wpws-header wpws-fade-up" style="transition-delay: 100ms;">
      {% if section.settings.title != blank %}
        <h2 class="wpws-title">
          {% assign title_words = section.settings.title | split: ' ' %}
          {% for word in title_words %}
            {% if word == 'With' or word == 'Sougat?' or word == 'Sougat' %}
              <span class="wpws-title-underline">{{ word }}</span>
            {% else %}
              {{ word }}
            {% endif %}
          {% endfor %}
        </h2>
      {% endif %}
    </div>

    <div class="wpws-list">
      {% for block in section.blocks %}
        <div class="wpws-list-item wpws-fade-up" style="transition-delay: {{ forloop.index | times: 100 | plus: 150 }}ms;" {{ block.shopify_attributes }}>
          
          <div class="wpws-icon">
             <!-- Clean, modern check SVG -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          
          <div class="wpws-text">
            {{ block.settings.text }}
          </div>

        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_dividers %}
      <hr class="wpws-main-divider wpws-fade-up" style="transition-delay: {{ section.blocks.size | times: 100 | plus: 250 }}ms;">
    {% endif %}

  </div>
</div>

<script>
  (function() {
    function initWPWS() {
      const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
      };

      const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
              if (entry.isIntersecting) {
                  entry.target.classList.add('wpws-visible');
                  observer.unobserve(entry.target);
              }
          });
      }, observerOptions);

      const fadeElements = document.querySelectorAll('.section-{{ section.id }} .wpws-fade-up');
      fadeElements.forEach(el => observer.observe(el));
    }

    initWPWS();

    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initWPWS();
      }
    });
  })();
</script>
