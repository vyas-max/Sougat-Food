  /* Inline Product Tabs */
  .product-tabs-inline {
    --tab-accent: #0f8a4b;
    grid-column: 1 / -1;
    padding: clamp(1.75rem, 3vw, 2.75rem) 0;
    width: min(1380px, 100%);
    margin: auto;
  }

  .product-tabs-inline__shell {
    background: linear-gradient(135deg, rgba(242, 250, 246, 0.95), rgba(255, 255, 255, 0.98));
    border: 1px solid rgba(17, 71, 46, 0.08);
    border-radius: 28px;
    padding: clamp(1.75rem, 3.5vw, 3rem);
    position: relative;
    overflow: hidden;
  }

  .product-tabs-inline__shell::after {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: 27px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.25), rgba(15, 138, 75, 0.08));
    z-index: 0;
    pointer-events: none;
  }

  .product-tabs-inline__nav,
  .product-tabs-inline__panels {
    position: relative;
    z-index: 1;
  }

  .product-tabs-inline__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid rgba(12, 40, 26, 0.1);
    padding-bottom: 1rem;
  }

  .product-tabs-inline__nav-item {
    appearance: none;
    border: 1px solid transparent;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.3), rgba(230, 244, 237, 0.4));
    border-radius: 999px;
    cursor: pointer;
    padding: 0.55rem 1.5rem;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    color: rgba(12, 40, 26, 0.7);
    font-weight: 600;
    transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }

  .product-tabs-inline__nav-item:is(:hover, :focus-visible) {
    border-color: rgba(15, 138, 75, 0.3);
    color: rgba(12, 40, 26, 0.95);
  }

  .product-tabs-inline__nav-item.is-active {
    color: #0b5a35;
    border-color: rgba(15, 138, 75, 0.4);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(15, 138, 75, 0.2));
    box-shadow: 0 12px 25px rgba(15, 138, 75, 0.12);
  }

  .product-tabs-inline__nav-item.is-active span::after {
    opacity: 1;
  }

  .product-tabs-inline__panels {
    display: grid;
    gap: 1.25rem;
  }

  .product-tabs-inline__panel {
    display: none;
    line-height: 1.7;
    color: rgba(12, 40, 26, 0.85);
    background: #fff;
    border-radius: 22px;
    border: 1px solid rgba(15, 138, 75, 0.08);
    padding: clamp(1.1rem, 2vw, 1.6rem);
    box-shadow: 0 18px 36px rgba(8, 32, 21, 0.05);
  }

  .product-tabs-inline__panel.is-active {
    display: block;
    animation: tabPanelReveal 0.4s ease;
  }

  @media screen and (max-width: 600px) {
    .product-tabs-inline__nav {
      gap: 0.5rem;
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 0.75rem;
    }

    .product-tabs-inline__nav::-webkit-scrollbar {
      display: none;
    }

    .product-tabs-inline__nav-item {
      font-size: 0.9rem;
      white-space: nowrap;
      flex-shrink: 0;
      padding-inline: 1.1rem;
    }
  }
