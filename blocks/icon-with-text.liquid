            <path d="M10 2.5C8.067 2.5 6.5 5.85786 6.5 10C6.5 14.1421 8.067 17.5 10 17.5C11.933 17.5 13.5 14.1421 13.5 10C13.5 5.85786 11.933 2.5 10 2.5Z" />
            <path d="M2 10H18" stroke="currentColor" stroke-width="1" fill="none" />
            <path d="M3.5 6H16.5M3.5 14H16.5" stroke="currentColor" stroke-width="1" fill="none" />
        {%- endcase -%}
      </svg>
    {% elsif block_settings.custom_icon != blank %}
      {% assign image_style = 'width: ' | append: block_settings.icon_size | append: 'px; height: ' | append: block_settings.icon_size | append: 'px; object-fit: contain;' %}
      {{ block_settings.custom_icon | image_url: width: 200 | image_tag: style: image_style, class: icon_block_class }}
    {% endif %}
  </div>

  <div class="icon-with-text__content">
    {% if block_settings.title != blank %}
      <{{ block_settings.title_tag }} class="icon-with-text__title">{{ block_settings.title }}</{{ block_settings.title_tag }}>
    {% endif %}

    {% if block_settings.text != blank %}
      <div class="icon-with-text__text">{{ block_settings.text }}</div>
    {% endif %}

    {% if block_settings.link != blank %}
      <a href="{{ block_settings.link }}" class="icon-with-text__link" {% if block_settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}>
        {{ block_settings.link_text | default: 'Learn more' }}
      </a>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .icon-with-text {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .icon-with-text--centered {
    align-items: center;
  }

  .icon-with-text--vertical {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .icon-with-text__icon-wrapper {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-with-text__icon {
    height: auto;
    fill: currentColor;
  }

  .icon-with-text__content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .icon-with-text__title {
    margin: 0;
    font-weight: 600;
  }

  .icon-with-text__text {
    margin: 0;
    line-height: 1.5;
  }

  .icon-with-text__link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .icon-with-text__link:hover {
    opacity: 0.8;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Icon with Text",
  "class": "icon-with-text-block",
  "settings": [
    {
      "type": "header",
      "content": "Icon Settings"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "map_pin",
          "label": "Address / Location"
        },
        {
          "value": "phone",
          "label": "Phone"
        },
        {
          "value": "email",
          "label": "Email"
        },
        {
          "value": "clock",
          "label": "Clock / Hours"
        },
        {
          "value": "whatsapp",
          "label": "WhatsApp"
        },
        {
          "value": "globe",
          "label": "Website / Globe"
        }
      ],
      "default": "map_pin"
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "Custom icon image",
      "info": "Use a custom image instead of the built-in icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Text Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Contact Us"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Title tag",
      "options": [
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "p",
          "label": "Paragraph"
        },
        {
          "value": "span",
          "label": "Span"
        }
      ],
      "default": "h4"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text content",
      "default": "<p>Your text content here</p>"
    },
    {
      "type": "header",
      "content": "Link Settings"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Learn more"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open link in new tab",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Icon with Text",
      "category": "Contact",
      "settings": {
        "icon": "map_pin",
        "title": "Our Address",
        "text": "<p>123 Street Name<br/>City, State 12345</p>"
      }
    }
  ]
}
{% endschema %}
