
{%- doc -%}
  Renders recently viewed products on the product page.
  Uses localStorage to track and display products the user has previously viewed.
{%- enddoc -%}

<div
  class="recently-viewed-block spacing-style"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
  data-recently-viewed-block
  data-current-product-id="{{ closest.product.id }}"
  data-max-products="{{ block.settings.max_products }}"
  data-columns="{{ block.settings.columns }}"
>
  {% if block.settings.heading != blank %}
    <h2 class="recently-viewed-block__heading">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="recently-viewed-block__grid" data-recently-viewed-grid></div>

  <div class="recently-viewed-block__empty" data-recently-viewed-empty>
    <p>{{ block.settings.empty_text }}</p>
  </div>

  <template id="recently-viewed-card-template-{{ block.id }}">
    <a class="recently-viewed-block__card" href="">
      <div class="recently-viewed-block__card-image-wrapper">
        <img class="recently-viewed-block__card-image" src="" alt="" loading="lazy">
        <span class="recently-viewed-block__card-badge" style="display:none">Sold out</span>
      </div>
      <div class="recently-viewed-block__card-content">
        <h3 class="recently-viewed-block__card-title"></h3>
        <div class="recently-viewed-block__card-price-wrapper">
          <span class="recently-viewed-block__card-price"></span>
          <span class="recently-viewed-block__card-compare-price"></span>
        </div>
      </div>
    </a>
  </template>
</div>

<script>
  (function() {
    var block = document.querySelector('[data-recently-viewed-block]');
    if (!block) return;

    var currentProductId = block.getAttribute('data-current-product-id');
    var maxProducts = parseInt(block.getAttribute('data-max-products')) || 4;
    var grid = block.querySelector('[data-recently-viewed-grid]');
    var emptyState = block.querySelector('[data-recently-viewed-empty]');
    var template = document.getElementById('recently-viewed-card-template-{{ block.id }}');

    try {
      var products = JSON.parse(localStorage.getItem('viewedProductsData') || '[]')
        .filter(function(p) { return p.id !== currentProductId; })
        .slice(0, maxProducts);

      if (products.length === 0) {
        grid.style.display = 'none';
        if (emptyState) emptyState.style.display = 'block';
        return;
      }

      if (emptyState) emptyState.style.display = 'none';

      products.forEach(function(product) {
        var card = template.content.cloneNode(true);
        card.querySelector('.recently-viewed-block__card').href = product.url;

        var img = card.querySelector('.recently-viewed-block__card-image');
        if (product.image && product.image !== '' && product.image !== 'null') {
          img.src = product.image;
          img.alt = product.title || '';
        } else {
          img.parentElement.classList.add('recently-viewed-block__card-image-wrapper--placeholder');
        }

        card.querySelector('.recently-viewed-block__card-title').textContent = product.title;
        card.querySelector('.recently-viewed-block__card-price').textContent = product.priceFormatted;

        var compareEl = card.querySelector('.recently-viewed-block__card-compare-price');
        if (product.compareAtPriceFormatted && product.compareAtPrice && product.compareAtPrice !== product.price) {
          compareEl.textContent = product.compareAtPriceFormatted;
        } else {
          compareEl.remove();
        }

        if (!product.available) {
          var badge = card.querySelector('.recently-viewed-block__card-badge');
          if (badge) badge.style.display = 'block';
        }

        grid.appendChild(card);
      });
    } catch(e) {
      grid.style.display = 'none';
      if (emptyState) emptyState.style.display = 'block';
    }
  })();
</script>

{% stylesheet %}
  .recently-viewed-block {
    width: 100%;
  }

  .recently-viewed-block__heading {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: #1a3e2b;
    margin: 0 0 1.5rem;
    text-align: center;
    position: relative;
  }

  .recently-viewed-block__heading::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, #10a560, #0b6c3c);
    border-radius: 2px;
    margin: 0.6rem auto 0;
  }

  .recently-viewed-block__grid {
    display: grid;
    grid-template-columns: repeat(var(--rv-columns, 4), 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .recently-viewed-block__empty {
    display: none;
    text-align: center;
    padding: 2rem 0;
    color: rgba(23, 56, 38, 0.5);
    font-size: 0.95rem;
  }

  .recently-viewed-block__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: #fff;
    border: 1px solid rgba(20, 68, 45, 0.08);
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    height: 100%;
  }

  .recently-viewed-block__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(8, 32, 21, 0.12);
  }

  .recently-viewed-block__card-image-wrapper {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f7fbf8;
  }

  .recently-viewed-block__card-image-wrapper--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f2faf6, #e8f5ee);
  }

  .recently-viewed-block__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .recently-viewed-block__card:hover .recently-viewed-block__card-image {
    transform: scale(1.05);
  }

  .recently-viewed-block__card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: rgba(20, 68, 45, 0.85);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    letter-spacing: 0.02em;
    z-index: 1;
  }

  .recently-viewed-block__card-content {
    padding: clamp(0.75rem, 1.5vw, 1.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .recently-viewed-block__card-title {
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    font-weight: 600;
    color: #1a3e2b;
    margin: 0;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    line-height: 1.4;
  }

  .recently-viewed-block__card-price-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .recently-viewed-block__card-price {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    font-weight: 700;
    color: #0a4c2a;
  }

  .recently-viewed-block__card-compare-price {
    font-size: 0.85rem;
    color: rgba(23, 56, 38, 0.5);
    text-decoration: line-through;
  }

  @media screen and (max-width: 989px) {
    .recently-viewed-block__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .recently-viewed-block__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .recently-viewed-block__card {
      border-radius: 16px;
    }

    .recently-viewed-block__card-content {
      padding: 0.6rem;
      gap: 0.35rem;
    }

    .recently-viewed-block__card-title {
      font-size: 0.85rem;
    }

    .recently-viewed-block__card-price {
      font-size: 0.9rem;
    }

    .recently-viewed-block__card-badge {
      top: 0.5rem;
      left: 0.5rem;
      font-size: 0.65rem;
      padding: 0.2rem 0.5rem;
    }
  }

  @media screen and (max-width: 389px) {
    .recently-viewed-block__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
    }

    .recently-viewed-block__heading {
      font-size: 1.1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Recently Viewed Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty state text",
      "default": "No recently viewed products yet."
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products to show",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Recently Viewed Products",
      "category": "Product"
    }
  ]
}
{% endschema %}
